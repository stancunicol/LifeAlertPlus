{
    // ── Configurarea nivelului de logare ─────────────────────────────────────────
    // ASP.NET Core scrie mesaje de log în consolă și alte providere (ex: fișiere, Serilog)
    // Nivelele disponibile: Trace, Debug, Information, Warning, Error, Critical, None
    "Logging": {
        "LogLevel": {
            "Default": "Information",       // Toate mesajele de nivel Information și mai sus
            "Microsoft.AspNetCore": "Warning" // Logăm doar avertismente din framework (reduce zgomotul)
        }
    },

    // Domeniile acceptate de aplicație; "*" = toate hostname-urile (permisiv în dev)
    // În producție, ar trebui restricționat la domeniul real al API-ului
    "AllowedHosts": "*",

    // ── Web Push / VAPID (notificări push browser în fundal) ─────────────────────
    // VAPID (Voluntary Application Server Identification) autentifică serverul față de push service.
    // Cheile sunt generate o singură dată și rămân fixe (schimbarea lor invalidează toate abonamentele!).
    // VapidSubject: adresa email a administratorului (cerință VAPID standard)
    "WebPush": {
        "VapidPublicKey": "",  // Cheia publică VAPID (trimisă la browser la abonare)
        "VapidPrivateKey": "", // Cheia privată VAPID (SECRETĂ — nu se expune în cod sursă public)
        "VapidSubject": "mailto:support@lifealertplusiot.com"
    },

    // ── Baza de date PostgreSQL (via Entity Framework Core + Npgsql) ──────────────
    // Connection string complet: "Host=...;Port=5432;Database=...;Username=...;Password=..."
    // Completat din user secrets (dev) sau variabile de mediu (producție)
    "ConnectionStrings": {
        "Default": ""
    },

    // ── URL-urile serviciilor sistemului ─────────────────────────────────────────
    // ApiBaseUrl: URL-ul propriu al acestui API (folosit la generarea link-urilor absolute)
    // ClientBaseUrl: URL-ul aplicației Blazor WASM (pentru redirect-uri OAuth și CORS)
    // EspDeviceUrl: URL-ul pentru comunicare cu dispozitivul ESP32 (dacă e cazul)
    // AiServiceUrl: URL-ul serviciului AI extern (Python/FastAPI pentru detectare cădere)
    // EspDeviceSecret: cheia secretă HMAC-SHA256 pentru autentificarea pachetelor ESP32
    "Urls": {
        "ApiBaseUrl": "http://localhost:5176",
        "ClientBaseUrl": "http://localhost:5254",
        "EspDeviceUrl": "http://localhost:5000",
        "AiServiceUrl": "http://localhost:8000",
        "EspDeviceSecret": "change-me-to-a-strong-random-key" // ← SCHIMBĂ ÎN PRODUCȚIE!
    },

    // ── JWT Bearer Authentication ─────────────────────────────────────────────────
    // Tokenele JWT sunt semnate cu cheia Key (HS256) și validate după Issuer/Audience.
    // ExpiresInMinutes: durata de viață a token-ului; după expirare utilizatorul trebuie să re-autentifice.
    // IMPORTANT: Key trebuie să fie cel puțin 32 caractere pentru securitate adecvată (256 biți)
    "Jwt": {
        "Key": "",                          // Secretul de semnare JWT (SECRETĂ — ≥32 caractere)
        "Issuer": "LifeAlertPlus",          // Emițătorul token-ului (verificat la validare)
        "Audience": "LifeAlertPlusUsers",   // Publicul țintă al token-ului (verificat la validare)
        "ExpiresInMinutes": 60              // Token valid 60 minute de la emitere
    },

    // ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
    // Folosit pentru autentificarea cu contul Google ("Sign in with Google").
    // ClientId și ClientSecret se obțin din Google Cloud Console → Credentials → OAuth 2.0.
    // Redirect URI configurat în Google Console: {ApiBaseUrl}/signin-google
    "Authentication": {
        "Google": {
            "ClientId": "",     // ID-ul clientului OAuth Google
            "ClientSecret": ""  // Secretul clientului OAuth Google (SECRETĂ)
        }
    },

    // ── Anthropic Claude API (chatbot medical AI) ─────────────────────────────────
    // Folosit de ChatbotService pentru a trimite mesajele utilizatorului la modelul Claude Haiku.
    // ApiKey se obține din console.anthropic.com → API Keys
    "Anthropic": {
        "ApiKey": "" // Cheia API Anthropic (SECRETĂ — niciodată în codul sursă public)
    },

    // ── Twilio SMS ────────────────────────────────────────────────────────────────
    // Folosit pentru trimiterea alertelor critice prin SMS la îngrijitori.
    // AccountSid și AuthToken se obțin din Twilio Console.
    // FromNumber: numărul de telefon Twilio din care se trimit SMS-urile (format E.164: +40...)
    "Twilio": {
        "AccountSid": "",    // Identificatorul contului Twilio
        "AuthToken": "",     // Token-ul de autentificare Twilio (SECRETĂ)
        "FromNumber": ""     // Numărul Twilio sursă (ex: "+40700123456")
    },

    // ── Email SMTP (Gmail) ────────────────────────────────────────────────────────
    // Folosit pentru: confirmarea emailului, rapoarte zilnice, invitații medici, alerte.
    // SmtpPort: 587 = STARTTLS (recomandat); 465 = SSL/TLS implicit
    // Username/Password: credențialele contului Gmail (sau "App Password" dacă 2FA e activ)
    "Email": {
        "SmtpHost": "smtp.gmail.com",
        "SmtpPort": 587,             // Port STARTTLS Gmail
        "Username": "",              // Emailul contului Gmail expeditor
        "Password": "",              // Parola Gmail sau App Password (SECRETĂ)
        "FromEmail": "",             // Adresa expeditorului (afișată în câmpul "De la:" al emailului)
        "FromName": "LifeAlertPlus"  // Numele expeditorului afișat în email
    },

    // ── Raport zilnic de sănătate ─────────────────────────────────────────────────
    // Raportul este trimis la miezul nopții ORA LOCALĂ configurată aici.
    // LocalTimeZone: ID-ul fusului orar (IANA pe Linux/Mac, Windows pe Windows)
    // Ex: "Europe/Bucharest" (EET, UTC+2/UTC+3 vară) sau "Eastern Standard Time" (Windows)
    "DailyReport": {
        "LocalTimeZone": "Europe/Bucharest" // Trimitem raportul la 00:00 ora României
    },

    // ── Log debug dispozitive ESP32 ───────────────────────────────────────────────
    // Activat numai în dezvoltare pentru a inspecta datele brute de la ESP fără a accesa DB-ul.
    // Enabled: false = dezactivat complet (zero overhead în producție)
    // Path: calea fișierului JSON acumulativ; dacă e gol → AppContext.BaseDirectory/device_test_log.json
    "DeviceTestLog": {
        "Enabled": false,
        "Path": "/tmp/device_test_log.json"
    },

    // ── CORS (Cross-Origin Resource Sharing) ─────────────────────────────────────
    // Lista originilor permise să apeleze API-ul din browser.
    // IMPORTANT: în producție, înlocuiți cu URL-ul real al aplicației Blazor/mobile.
    // Fără CORS corect, browser-ul blochează cererile din frontend.
    "Cors": {
        "AllowedOrigins": [
            "http://localhost:5254",   // Blazor WASM dev (HTTP)
            "https://localhost:5254",  // Blazor WASM dev (HTTPS)
            "http://localhost:8081",   // Port alternativ dev
            "https://localhost:8081",  // Port alternativ dev (HTTPS)
            "https://localhost:8444"   // Port HTTPS suplimentar (proxy/reverse proxy local)
        ]
    }
}
