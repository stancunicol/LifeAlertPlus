{
    // ── Fișier de configurare pentru mediul de DEZVOLTARE (Development) ───────────
    // Valorile din acest fișier suprascriu cele din appsettings.json când ASPNETCORE_ENVIRONMENT=Development.
    // NU includeți secrete reale aici dacă folosiți git — utilizați "dotnet user-secrets" în schimb.

    // Logare mai detaliată față de producție:
    // - "LifeAlertPlus": "Debug" → vedem toate mesajele de debug ale aplicației noastre
    // - "Microsoft": "Warning" → reducem zgomotul din framework
    "Logging": {
        "LogLevel": {
            "Default": "Information",        // Nivel general: Information și mai sus
            "Microsoft": "Warning",           // Framework-ul ASP.NET Core: doar avertismente
            "Microsoft.AspNetCore": "Warning",// Middleware ASP.NET Core: doar avertismente
            "LifeAlertPlus": "Debug"         // Codul nostru: mesaje Debug (cel mai detaliat în dev)
        }
    },

    // Connection string-ul bazei de date PostgreSQL pentru mediul local de dezvoltare.
    // Completat din user secrets: dotnet user-secrets set "ConnectionStrings:Default" "Host=..."
    "ConnectionStrings": {
        "Default": ""
    },

    // URL-urile serviciilor în mediul local de dezvoltare
    "Urls": {
        "ApiBaseUrl": "http://localhost:5176",   // API rulează local pe portul 5176
        "ClientBaseUrl": "http://localhost:5254", // Blazor WASM rulează local pe portul 5254
        "EspDeviceSecret": "idontknowwhattoputhere" // Secretul HMAC pentru ESP32 în dev (nu contează, schimbat în prod)
    },

    // JWT pentru autentificare în mediul de dezvoltare
    // Key: din user secrets (dotnet user-secrets set "Jwt:Key" "cheie-lunga-de-cel-putin-32-caractere")
    "Jwt": {
        "Key": "",                         // Secretul de semnare (completat din user secrets)
        "Issuer": "LifeAlertPlus",
        "Audience": "LifeAlertPlusUsers",
        "ExpiresInMinutes": 60
    },

    // ── Configurare AlertMonitorService pentru dezvoltare ─────────────────────────
    // În development, dezactivăm trimiterea SMS-urilor pentru a nu cheltui credite Twilio
    // și pentru a nu deranja cu notificări false în timpul testării.
    // SendCriticalSmsImmediately: true în producție (trimite SMS imediat la alertă critică)
    // SendAlertSmsImmediately: true în producție (trimite SMS la alertă normală)
    "AlertMonitor": {
        "SendCriticalSmsImmediately": false, // Dezactivat în dev — nu trimite SMS la alerte critice
        "SendAlertSmsImmediately": false     // Dezactivat în dev — nu trimite SMS la alerte normale
    },

    // Email SMTP pentru trimiterea emailurilor în dev (aceleași credențiale Gmail ca prod)
    // Recomandare: în dev, folosiți un cont Gmail de test sau un server SMTP local (ex: Mailhog)
    "Email": {
        "SmtpHost": "smtp.gmail.com",
        "SmtpPort": "587",    // STARTTLS
        "Username": "",       // Completat din user secrets
        "Password": "",       // Completat din user secrets
        "FromEmail": "",      // Adresa expeditorului
        "FromName": "LifeAlert+"
    },

    // API key Anthropic pentru chatbot-ul medical (Claude Haiku)
    // Completat din user secrets: dotnet user-secrets set "Anthropic:ApiKey" "sk-ant-..."
    "Anthropic": {
        "ApiKey": ""
    }
}
