@page "/reset-password"
@layout EmptyLayout

<div class="auth-bg"></div>
<div class="login-rect">
    <div class="login-left">
        <div class="login-logo">@T("login.title")</div>
        <div class="login-description">@T("login.tagline")</div>
        <p class="login-version">v @Version</p>
    </div>

    <div class="login-right">
        <div class="login-right-header">
            <h2 class="login-right-title">@T("reset.title")</h2>
            <p class="login-right-subtitle">@T("reset.subtitle")</p>
        </div>

        <div class="form-group">
            <label class="form-label">@T("reset.password")</label>
            <div class="input-wrapper">
                <div class="password-field">
                    <input type="@(_showPassword ? "text" : "password")"
                           class="form-input form-input-icon form-input-password"
                           placeholder="password123"
                           @bind="Password"
                           @bind:event="oninput" />
                    <button type="button" class="password-toggle" @onclick="ToggleShowPassword" aria-label="Toggle password visibility">
                        @if (_showPassword)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        }
                    </button>
                </div>
            </div>
        </div>

        @if (Password.Length > 0)
        {
            <div class="password-strength-bar">
                <div class="strength-fill @PasswordStrengthClass" style="width:@(PasswordStrength * 25)%"></div>
            </div>
            <p class="strength-label @PasswordStrengthClass">@PasswordStrengthLabel</p>
        }

        <div class="form-group">
            <label class="form-label">@T("reset.confirmPassword")</label>
            <div class="input-wrapper">
                <div class="password-field">
                    <input type="@(_showConfirmPassword ? "text" : "password")"
                           class="form-input form-input-icon form-input-password"
                           placeholder="password123"
                           @bind="ConfirmPassword"
                           @bind:event="oninput" />
                    <button type="button" class="password-toggle" @onclick="ToggleShowConfirmPassword" aria-label="Toggle confirm password visibility">
                        @if (_showConfirmPassword)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        }
                    </button>
                </div>
            </div>
        </div>

        <button class="login-button" @onclick="OnResetPassword">@T("reset.button")</button>

        @if (!string.IsNullOrEmpty(SuccessMessage))
        {
            <div class="success-message">
                @SuccessMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="error-message">
                @ErrorMessage
            </div>
        }

        <div class="form-links">
            <a class="form-link" href="/login">@T("reset.backToLogin")</a>
        </div>
    </div>
</div>