@page "/about"
@using LifeAlertPlus.Client.Components.Header
@layout MainLayout

<HeaderComponent UserName="@UserFullName" ProfilePictureUrl="@ProfilePictureUrl"/>

<div class="about-page">
    <div class="about-container">
        <h2 class="section-title">@T("about.title")</h2>
        <p style="font-size:18px;color:#fff;opacity:0.95;margin:0;font-family:'Jua',sans-serif;">@T("about.intro")</p>
    </div>

    <div class="about-content">
        <div class="cards-grid">
                <div class="info-card">
                    <div class="card-icon">🎯</div>
                    <h3 class="card-title">@T("about.missionTitle")</h3>
                    <p>@T("about.missionText")</p>
                </div>

                <div class="info-card">
                    <div class="card-icon">⚡</div>
                    <h3 class="card-title">@T("about.problemTitle")</h3>
                    <p>@T("about.problemText")</p>
                </div>

                <div class="info-card">
                    <div class="card-icon">🔬</div>
                    <h3 class="card-title">@T("about.visionTitle")</h3>
                    <p>@T("about.visionText")</p>
                </div>
            </div>

            <div class="solution-section">
                <h3 class="subsection-title">🛠️ @T("about.solutionTitle")</h3>
                <p>@T("about.solutionIntro")</p>
                <div class="features-row">
                    <div class="feature-pill">
                        <span class="pill-icon">⌚</span>
                        <span>@T("about.solutionWearable")</span>
                    </div>
                    <div class="feature-pill">
                        <span class="pill-icon">🖥️</span>
                        <span>@T("about.solutionWeb")</span>
                    </div>
                    <div class="feature-pill">
                        <span class="pill-icon">🔔</span>
                        <span>@T("about.solutionAlerts")</span>
                    </div>
                </div>
            </div>

            <div class="features-section">
                <h3 class="subsection-title">✨ @T("about.featuresTitle")</h3>
                <div class="features-grid">
                    <div class="feature-item">
                        <span class="feature-check">✓</span>
                        <span>@T("about.feature1")</span>
                    </div>
                    <div class="feature-item">
                        <span class="feature-check">✓</span>
                        <span>@T("about.feature2")</span>
                    </div>
                    <div class="feature-item">
                        <span class="feature-check">✓</span>
                        <span>@T("about.feature3")</span>
                    </div>
                    <div class="feature-item">
                        <span class="feature-check">✓</span>
                        <span>@T("about.feature4")</span>
                    </div>
                    <div class="feature-item">
                        <span class="feature-check">✓</span>
                        <span>@T("about.feature5")</span>
                    </div>
                </div>
            </div>

            <div class="disclaimer-box">
                <div class="disclaimer-icon">⚠️</div>
                <div>
                    <h3 class="disclaimer-title">@T("about.disclaimerTitle")</h3>
                    <p>@T("about.disclaimerText")</p>
                </div>
            </div>
    </div>
</div>
