@page "/settings"
@using LifeAlertPlus.Client.Components.Header
@layout MainLayout

@using LifeAlertPlus.Domain.Entities
@using LifeAlertPlus.Client

<HeaderComponent UserName="@UserFullName" ProfilePictureUrl="@ProfilePictureUrl"/>

<div class="settings-container">
    <div class="settings-header">
        <h1>⚙️ Settings</h1>
        <p>Personalize your application according to your preferences</p>
    </div>

    <div class="settings-content">
        <div class="settings-section">
            <div class="section-header">
                <h2>🎨 Appearance</h2>
            </div>
            <div class="section-content">
                <div class="setting-item">
                    <div class="setting-info">
                        <h3>Theme</h3>
                        <p>Choose between light and dark themes</p>
                    </div>
                    <select @bind="Settings.Theme" class="select-input">
                        <option value="pink">Verde deschis</option>
                        <option value="yellow">Green</option>
                        <option value="green">Yellow</option>
                        <option value="lilac">Lilac</option>
                        <option value="blue">Blue</option>
                        <option value="dark">Dark</option>
                        <option value="light">Light</option>
                    </select>
                </div>
                <div class="setting-item">
                    <div class="setting-info">
                        <h3>First Day of the Week</h3>
                    </div>
                    <select @bind="Settings.FirstDayOfWeek" class="select-input">
                        <option value="monday">Monday</option>
                        <option value="tuesday">Tuesday</option>
                        <option value="wednesday">Wednesday</option>
                        <option value="thursday">Thursday</option>
                        <option value="friday">Friday</option>
                        <option value="saturday">Saturday</option>
                        <option value="sunday">Sunday</option>
                    </select>
                </div>
                <div class="setting-item">
                    <div class="setting-info">
                        <h3>Font Size</h3>
                        <p>Adjust the text size in the application</p>
                    </div>
                    <select @bind="Settings.FontSize" class="select-input">
                        <option value="small">Small</option>
                        <option value="medium">Medium</option>
                        <option value="large">Large</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="settings-section">
            <div class="section-header">
                <h2>🚨 Alert Thresholds</h2>
            </div>
            <div class="section-content">
                <div class="alert-threshold-group">
                    <h3>❤️ Heart Rate</h3>
                    <div class="threshold-inputs">
                        <div class="threshold-input-group">
                            <label>Heart Rate Min</label>
                            <input type="number" @bind="Settings.HeartRateMin" class="number-input" min="40" max="150" />
                            <span class="unit">bpm</span>
                        </div>
                        <div class="threshold-input-group">
                            <label>Heart Rate Max</label>
                            <input type="number" @bind="Settings.HeartRateMax" class="number-input" min="40" max="150" />
                            <span class="unit">bpm</span>
                        </div>
                    </div>
                </div>

                <div class="alert-threshold-group">
                    <h3>🌡️ Temperature</h3>
                    <div class="threshold-inputs">
                        <div class="threshold-input-group">
                            <label>Temperature Min</label>
                            <input type="number" @bind="Settings.TemperatureMin" class="number-input" min="35" max="42" step="0.1" />
                            <span class="unit">°C</span>
                        </div>
                        <div class="threshold-input-group">
                            <label>Temperature Max</label>
                            <input type="number" @bind="Settings.TemperatureMax" class="number-input" min="35" max="42" step="0.1" />
                            <span class="unit">°C</span>
                        </div>
                    </div>
                </div>

                <button class="btn-reset-thresholds" @onclick="ResetThresholds">🔄 Reset to default values</button>
            </div>
        </div>

        <div class="settings-section">
            <div class="section-header">
                <h2>💾 Data Management</h2>
            </div>
            <div class="section-content">
                <div class="setting-item">
                    <div class="setting-info">
                        <h3>Data Update Frequency</h3>
                        <p>How often vital signs data is refreshed (in seconds)</p>
                    </div>
                    <select @bind="Settings.UpdateFrequency" class="select-input">
                        <option value="10">Every 10 seconds</option>
                        <option value="15">Every 15 seconds</option>
                        <option value="30">Every 30 seconds</option>
                        <option value="60">Every 1 minute</option>
                        <option value="120">Every 2 minutes</option>
                        <option value="300">Every 5 minutes</option>
                    </select>
                </div>
                <div class="setting-item">
                    <div class="setting-info">
                        <h3>History Retention Duration</h3>
                        <p>How long to keep old data</p>
                    </div>
                    <select @bind="Settings.HistoryRetention" class="select-input">
                        <option value="30">30 days</option>
                        <option value="90">90 days</option>
                        <option value="180">6 months</option>
                        <option value="365">1 year</option>
                        <option value="0">Unlimited</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="settings-section">
            <div class="section-header">
                <h2>🔧 System</h2>
            </div>
            <div class="section-content">
                <div class="setting-item">
                    <div class="setting-info">
                        <h3>Language</h3>
                        <p>Select the application language</p>
                    </div>
                    <select @bind="Settings.Language" class="select-input">
                        <option value="ro">Română</option>
                        <option value="en">English</option>
                    </select>
                </div>
                <div class="system-info">
                    <h3>📊 System Information</h3>
                    <div class="info-row">
                        <span>Application Version:</span>
                        <span class="info-value">@Version</span>
                    </div>
                    <div class="info-row">
                        <span>Last Update:</span>
                        <span class="info-value">24 November 2025</span>
                    </div>
                    <div class="info-row">
                        <span>Used Space:</span>
                        <span class="info-value">47.2 MB</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="settings-footer">
        <button class="btn-save-settings" @onclick="SaveSettings">💾 Save All Settings</button>
        <button class="btn-reset-settings" @onclick="ResetAllSettings">🔄 Reset All</button>
    </div>
</div>

@if (ShowSaveConfirmation)
{
    <div class="toast-notification">
        ✅ Settings have been saved successfully!
    </div>
}
