@page "/settings"
@using LifeAlertPlus.Client.Components.Header
@layout MainLayout

<HeaderComponent UserName="@UserFullName" ProfilePictureUrl="@ProfilePictureUrl"/>

<div class="settings-container">
    <div class="settings-header">
        <h1>@T("settings.title")</h1>
        <p>@T("settings.subtitle")</p>
    </div>

    <div class="settings-content">
        <div class="settings-section">
            <div class="section-header">
                <h2>@T("settings.alertThresholds")</h2>
            </div>
            <div class="section-content">
                <div class="alert-threshold-group">
                    <h3>@T("settings.heartRate")</h3>
                    <div class="threshold-inputs">
                        <div class="threshold-input-group">
                            <label>@T("settings.heartRateMin")</label>
                            <input type="number" @bind="Settings.HeartRateMin" class="number-input" min="40" max="150" />
                            <span class="unit">bpm</span>
                        </div>
                        <div class="threshold-input-group">
                            <label>@T("settings.heartRateMax")</label>
                            <input type="number" @bind="Settings.HeartRateMax" class="number-input" min="40" max="150" />
                            <span class="unit">bpm</span>
                        </div>
                    </div>
                </div>

                <div class="alert-threshold-group">
                    <h3>@T("settings.temperatureSection")</h3>
                    <div class="threshold-inputs">
                        <div class="threshold-input-group">
                            <label>@T("settings.tempMin")</label>
                            <input type="number" @bind="Settings.TemperatureMin" class="number-input" min="35" max="42" step="0.1" />
                            <span class="unit">°C</span>
                        </div>
                        <div class="threshold-input-group">
                            <label>@T("settings.tempMax")</label>
                            <input type="number" @bind="Settings.TemperatureMax" class="number-input" min="35" max="42" step="0.1" />
                            <span class="unit">°C</span>
                        </div>
                    </div>
                </div>

                <div class="alert-threshold-group">
                    <h3>@T("settings.spo2Section")</h3>
                    <div class="threshold-inputs">
                        <div class="threshold-input-group">
                            <label>@T("settings.spo2Min")</label>
                            <input type="number" @bind="Settings.SpO2Min" class="number-input" min="70" max="100" />
                            <span class="unit">%</span>
                        </div>
                        <div class="threshold-input-group">
                            <label>@T("settings.spo2Max")</label>
                            <input type="number" @bind="Settings.SpO2Max" class="number-input" min="70" max="100" />
                            <span class="unit">%</span>
                        </div>
                    </div>
                </div>

                <button class="btn-reset-thresholds" @onclick="ResetThresholds">@T("settings.resetDefaults")</button>
            </div>
        </div>

        <div class="settings-section">
            <div class="section-header">
                <h2>@T("settings.notifications")</h2>
            </div>
            <div class="section-content">
                <div class="setting-item">
                    <div class="setting-info">
                        <h3>@T("settings.notifyEmail")</h3>
                        <p>@T("settings.notifyEmailDesc")</p>
                    </div>
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="Settings.NotifyByEmail" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
                <div class="setting-item">
                    <div class="setting-info">
                        <h3>@T("settings.notifyPush")</h3>
                        <p>@T("settings.notifyPushDesc")</p>
                    </div>
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="Settings.NotifyByPush" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
                <div class="setting-item">
                    <div class="setting-info">
                        <h3>@T("profile.webPushTitle")</h3>
                        <p>@T("profile.webPushDesc")</p>
                    </div>
                    <div>
                        @if (_webPushSupported)
                        {
                            @if (_webPushPermission == "denied")
                            {
                                <span class="push-status denied">@T("profile.webPushDenied")</span>
                            }
                            else if (_webPushSubscribed)
                            {
                                <button class="btn-security" @onclick="UnsubscribeWebPushAsync">@T("profile.webPushDisable")</button>
                            }
                            else
                            {
                                <button class="btn-security" @onclick="SubscribeWebPushAsync">@T("profile.webPushEnable")</button>
                            }
                        }
                        else
                        {
                            <span class="push-status unsupported">@T("profile.webPushUnsupported")</span>
                        }
                    </div>
                </div>
                <div class="setting-item">
                    <div class="setting-info">
                        <h3>@T("settings.notifySms")</h3>
                        <p>@T("settings.notifySmsDesc")</p>
                    </div>
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="Settings.NotifyBySms" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
                <div class="setting-item">
                    <div class="setting-info">
                        <h3>@T("settings.dailyReport")</h3>
                        <p>@T("settings.dailyReportDesc")</p>
                    </div>
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="Settings.EnableDailyReport" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>
        </div>

        <div class="settings-section">
            <div class="section-header">
                <h2>@T("settings.dataManagement")</h2>
            </div>
            <div class="section-content">
                <div class="setting-item">
                    <div class="setting-info">
                        <h3>@T("settings.updateFrequency")</h3>
                        <p>@T("settings.updateFrequencyDesc")</p>
                    </div>
                    <select @bind="Settings.UpdateFrequency" class="select-input">
                        <option value="10">@T("settings.every10s")</option>
                        <option value="15">@T("settings.every15s")</option>
                        <option value="30">@T("settings.every30s")</option>
                        <option value="60">@T("settings.every1m")</option>
                        <option value="120">@T("settings.every2m")</option>
                        <option value="300">@T("settings.every5m")</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="settings-section">
            <div class="section-header">
                <h2>@T("settings.system")</h2>
            </div>
            <div class="section-content">
                <div class="setting-item">
                    <div class="setting-info">
                        <h3>@T("settings.language")</h3>
                        <p>@T("settings.languageDesc")</p>
                    </div>
                    <select @bind="Settings.Language" class="select-input">
                        <option value="ro">Română</option>
                        <option value="en">English</option>
                    </select>
                </div>
                <div class="setting-item">
                    <div class="setting-info">
                        <h3>@T("settings.firstDay")</h3>
                    </div>
                    <select @bind="Settings.FirstDayOfWeek" class="select-input">
                        <option value="monday">@T("settings.monday")</option>
                        <option value="tuesday">@T("settings.tuesday")</option>
                        <option value="wednesday">@T("settings.wednesday")</option>
                        <option value="thursday">@T("settings.thursday")</option>
                        <option value="friday">@T("settings.friday")</option>
                        <option value="saturday">@T("settings.saturday")</option>
                        <option value="sunday">@T("settings.sunday")</option>
                    </select>
                </div>
                <div class="system-info">
                    <h3>@T("settings.systemInfo")</h3>
                    <div class="info-row">
                        <span>@T("settings.appVersion")</span>
                        <span class="info-value">@Version</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="settings-footer">
        <button class="btn-save-settings" @onclick="SaveSettings">@T("settings.saveAll")</button>
        <button class="btn-reset-settings" @onclick="ResetAllSettings">@T("settings.resetAll")</button>
    </div>
</div>

@if (ShowSaveConfirmation)
{
    <div class="toast-notification">
        @T("settings.saved")
    </div>
}
