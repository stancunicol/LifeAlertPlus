@page "/invite/patient"
@page "/invite/accept"
@layout EmptyLayout

@using LifeAlertPlus.Domain.Entities
@using LifeAlertPlus.Shared.DTOs.Responses.Email
@using LifeAlertPlus.Shared.DTOs.Responses.Measurement

<PageTitle>@T("invite.patientDataTitle")</PageTitle>

<div class="invite-page-shell">
    <div class="selected-monitored-container invite-container">
        @if (IsLoading)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <p>@T("invite.loading")</p>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="message-card error">@ErrorMessage</div>
        }
        else if (InvitationInfo == null || Patient == null)
        {
            <div class="message-card error">@T("invite.invalid")</div>
        }
        else
        {
            var patientName = GetPatientFullName();
            var age = GetAge();

            <div class="invite-report-heading">
                <div class="invite-heading-actions">
                    <span>@Ui("Doctor invitation", "Invitatie doctor")</span>
                    <button class="invite-export-btn" @onclick="ExportPdfAsync">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                            <line x1="12" y1="18" x2="12" y2="12"/>
                            <line x1="9" y1="15" x2="15" y2="15"/>
                        </svg>
                        <span>@T("selected.export") PDF</span>
                    </button>
                </div>
                <h1>@T("invite.patientDataTitle")</h1>
            </div>

            <div class="person-profile-header invite-hero">
                <div class="profile-left">
                    <div class="profile-info-main">
                        <span class="invite-eyebrow">@Ui("Shared patient view", "Vizualizare pacient partajata")</span>
                        <h1 class="person-name-main">@patientName</h1>
                        <div class="person-meta invite-person-details">
                            @if (age.HasValue)
                            {
                                <span>
                                    <small>@Ui("Age", "Varsta")</small>
                                    <strong>@age @T("selected.years")</strong>
                                </span>
                            }
                            @if (!string.IsNullOrWhiteSpace(Patient.Gender))
                            {
                                <span>
                                    <small>@T("selected.gender")</small>
                                    <strong>@Patient.Gender</strong>
                                </span>
                            }
                            @if (!string.IsNullOrWhiteSpace(Patient.Address))
                            {
                                <span class="wide">
                                    <small>@T("export.address")</small>
                                    <strong>@Patient.Address</strong>
                                </span>
                            }
                        </div>
                    </div>
                </div>
                <div class="invite-meta-panel">
                    <div class="invite-meta-item">
                        <span>@Ui("Last update", "Ultima actualizare")</span>
                        <strong>@(LatestMeasurement?.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm") ?? "-")</strong>
                    </div>
                    <div class="invite-meta-item">
                        <span>@Ui("Caregiver", "Aparținător")</span>
                        <strong>@(string.IsNullOrWhiteSpace(InvitationInfo.CaregiverEmail) ? "-" : InvitationInfo.CaregiverEmail)</strong>
                    </div>
                    <div class="invite-meta-item">
                        <span>@Ui("Device", "Dispozitiv")</span>
                        <strong>@(string.IsNullOrWhiteSpace(Patient.DeviceSerialNumber) ? "-" : Patient.DeviceSerialNumber)</strong>
                    </div>
                </div>
            </div>


            <div class="content-grid invite-content-grid">
                <div class="chart-section">
                    <div class="section-card">
                        <div class="section-header">
                            <h2>@Ui("Clinical summary", "Rezumat clinic")</h2>
                        </div>
                        <div class="summary-grid">
                            <div class="summary-tile">
                                <span>@Ui("Measurements", "Masuratori")</span>
                                <strong>@TotalMeasurements</strong>
                            </div>
                            <div class="summary-tile">
                                <span>@Ui("Days with data", "Zile cu date")</span>
                                <strong>@DaysWithData</strong>
                            </div>
                            <div class="summary-tile alert">
                                <span>@Ui("Alerts", "Alerte")</span>
                                <strong>@AlertCount</strong>
                            </div>
                            <div class="summary-tile critical">
                                <span>@Ui("Critical", "Critice")</span>
                                <strong>@CriticalCount</strong>
                            </div>
                            <div class="summary-tile">
                                <span>@Ui("Avg. pulse", "Puls mediu")</span>
                                <strong>@AveragePulse.ToString("F0") bpm</strong>
                            </div>
                            <div class="summary-tile">
                                <span>@Ui("Avg. SpO2", "SpO2 mediu")</span>
                                <strong>@AverageSpO2.ToString("F0")%</strong>
                            </div>
                        </div>
                    </div>

                    <div class="section-card">
                        <div class="section-header">
                            <h2>@T("selected.vitalSigns")</h2>
                            <div class="chart-view-toggle">
                                <button class="btn-chart-view @(CurrentChartView == ChartViewMode.Daily ? "active" : "")"
                                        @onclick="() => SwitchChartView(ChartViewMode.Daily)">@T("selected.daily")</button>
                                <button class="btn-chart-view @(CurrentChartView == ChartViewMode.Weekly ? "active" : "")"
                                        @onclick="() => SwitchChartView(ChartViewMode.Weekly)">@T("selected.weekly")</button>
                            </div>
                        </div>
                        <div class="charts-wrapper">
                            <div class="chart-week-nav">
                                @if (CurrentChartView == ChartViewMode.Weekly)
                                {
                                    <button class="btn-week-arrow @(_hasPrevWeekData ? "" : "disabled")"
                                            @onclick="GoToPreviousWeek" disabled="@(!_hasPrevWeekData)">
                                        <span>&lt;</span>
                                    </button>
                                    <span class="chart-week-label">@_chartWeekLabel</span>
                                    <button class="btn-week-arrow @(_weekOffset >= 0 ? "disabled" : "")"
                                            @onclick="GoToNextWeek" disabled="@(_weekOffset >= 0)">
                                        <span>&gt;</span>
                                    </button>
                                }
                                else
                                {
                                    <button class="btn-week-arrow @(_hasPrevDayData ? "" : "disabled")"
                                            @onclick="GoToPreviousDay" disabled="@(!_hasPrevDayData)">
                                        <span>&lt;</span>
                                    </button>
                                    <span class="chart-week-label">@_chartDayLabel</span>
                                    <button class="btn-week-arrow @(_dayOffset >= 0 ? "disabled" : "")"
                                            @onclick="GoToNextDay" disabled="@(_dayOffset >= 0)">
                                        <span>&gt;</span>
                                    </button>
                                }
                            </div>

                            <div class="chart-item">
                                <div class="chart-item-title">
                                    <span class="chart-color-dot hr"></span>
                                    @T("selected.heartRate")
                                    <span class="chart-unit-badge">bpm</span>
                                </div>
                                <svg class="chart-svg" viewBox="0 0 800 200" preserveAspectRatio="xMidYMid meet">
                                    <defs>
                                        <linearGradient id="inviteHrGradient" x1="0" y1="0" x2="0" y2="1">
                                            <stop offset="0%" stop-color="#A5D6A7" stop-opacity="0.3" />
                                            <stop offset="100%" stop-color="#A5D6A7" stop-opacity="0.02" />
                                        </linearGradient>
                                    </defs>
                                    <line x1="90" y1="15" x2="785" y2="15" class="grid-line" />
                                    <line x1="90" y1="51" x2="785" y2="51" class="grid-line" />
                                    <line x1="90" y1="88" x2="785" y2="88" class="grid-line" />
                                    <line x1="90" y1="124" x2="785" y2="124" class="grid-line" />
                                    <line x1="90" y1="160" x2="785" y2="160" class="grid-line" />
                                    <line x1="90" y1="15" x2="90" y2="160" class="axis-line" />
                                    <line x1="90" y1="160" x2="785" y2="160" class="axis-line" />
                                    <g>@((MarkupString)"<text x=\"58\" y=\"19\" class=\"chart-y-label\">120</text>")</g>
                                    <g>@((MarkupString)"<text x=\"58\" y=\"55\" class=\"chart-y-label\">100</text>")</g>
                                    <g>@((MarkupString)"<text x=\"58\" y=\"92\" class=\"chart-y-label\">80</text>")</g>
                                    <g>@((MarkupString)"<text x=\"58\" y=\"128\" class=\"chart-y-label\">60</text>")</g>
                                    <g>@((MarkupString)"<text x=\"58\" y=\"164\" class=\"chart-y-label\">40</text>")</g>
                                    @if (HeartRatePoints.Count >= 1)
                                    {
                                        <path d="@GenerateAreaPath(HeartRatePoints)" class="chart-area" fill="url(#inviteHrGradient)" />
                                        <path d="@GenerateSmoothPath(HeartRatePoints)" class="chart-line hr-line" />
                                        @foreach (var pt in HeartRatePoints)
                                        {
                                            var cx = pt.X.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
                                            var cy = pt.Y.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
                                            <circle cx="@cx" cy="@cy" r="4.5" class="chart-dot hr-dot" />
                                        }
                                    }
                                    @foreach (var lbl in GetXAxisLabels())
                                    {
                                        var lx = lbl.X.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);
                                        <line x1="@lx" y1="160" x2="@lx" y2="166" class="axis-tick" />
                                        <g>@((MarkupString)$"<text x=\"{lx}\" y=\"180\" class=\"chart-x-label\" text-anchor=\"middle\">{lbl.Label}</text>")</g>
                                    }
                                </svg>
                                @if (HeartRatePoints.Count == 0)
                                {
                                    <p class="no-data-note">@T("invite.notEnoughData")</p>
                                }
                            </div>

                            <div class="chart-item">
                                <div class="chart-item-title">
                                    <span class="chart-color-dot temp"></span>
                                    @T("selected.temperature")
                                    <span class="chart-unit-badge">C</span>
                                </div>
                                <svg class="chart-svg" viewBox="0 0 800 200" preserveAspectRatio="xMidYMid meet">
                                    <defs>
                                        <linearGradient id="inviteTempGradient" x1="0" y1="0" x2="0" y2="1">
                                            <stop offset="0%" stop-color="#FF9A6C" stop-opacity="0.3" />
                                            <stop offset="100%" stop-color="#FF9A6C" stop-opacity="0.02" />
                                        </linearGradient>
                                    </defs>
                                    <line x1="90" y1="15" x2="785" y2="15" class="grid-line" />
                                    <line x1="90" y1="51" x2="785" y2="51" class="grid-line" />
                                    <line x1="90" y1="88" x2="785" y2="88" class="grid-line" />
                                    <line x1="90" y1="124" x2="785" y2="124" class="grid-line" />
                                    <line x1="90" y1="160" x2="785" y2="160" class="grid-line" />
                                    <line x1="90" y1="15" x2="90" y2="160" class="axis-line" />
                                    <line x1="90" y1="160" x2="785" y2="160" class="axis-line" />
                                    <g>@((MarkupString)"<text x=\"58\" y=\"19\" class=\"chart-y-label\">39</text>")</g>
                                    <g>@((MarkupString)"<text x=\"58\" y=\"55\" class=\"chart-y-label\">38</text>")</g>
                                    <g>@((MarkupString)"<text x=\"58\" y=\"92\" class=\"chart-y-label\">37</text>")</g>
                                    <g>@((MarkupString)"<text x=\"58\" y=\"128\" class=\"chart-y-label\">36</text>")</g>
                                    <g>@((MarkupString)"<text x=\"58\" y=\"164\" class=\"chart-y-label\">35</text>")</g>
                                    @if (TemperaturePoints.Count >= 1)
                                    {
                                        <path d="@GenerateAreaPath(TemperaturePoints)" class="chart-area" fill="url(#inviteTempGradient)" />
                                        <path d="@GenerateSmoothPath(TemperaturePoints)" class="chart-line temp-line" />
                                        @foreach (var pt in TemperaturePoints)
                                        {
                                            var cx = pt.X.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
                                            var cy = pt.Y.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
                                            <circle cx="@cx" cy="@cy" r="4.5" class="chart-dot temp-dot" />
                                        }
                                    }
                                    @foreach (var lbl in GetXAxisLabels())
                                    {
                                        var lx = lbl.X.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);
                                        <line x1="@lx" y1="160" x2="@lx" y2="166" class="axis-tick" />
                                        <g>@((MarkupString)$"<text x=\"{lx}\" y=\"180\" class=\"chart-x-label\" text-anchor=\"middle\">{lbl.Label}</text>")</g>
                                    }
                                </svg>
                                @if (TemperaturePoints.Count == 0)
                                {
                                    <p class="no-data-note">@T("invite.notEnoughData")</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="sidebar-section">
                    <div class="section-card">
                        <div class="section-header">
                            <h2>@Ui("Key moments", "Momente cheie")</h2>
                        </div>
                        @if (!KeyMoments.Any())
                        {
                            <p class="no-data-note">@Ui("No critical moments were detected in the available measurements.", "Nu au fost detectate momente critice in masuratorile disponibile.")</p>
                        }
                        else
                        {
                            <div class="moments-list">
                                @foreach (var moment in KeyMoments)
                                {
                                    <div class="moment-item @moment.Severity">
                                        <div class="moment-icon">@GetStatusIcon(moment.Severity)</div>
                                        <div class="moment-content">
                                            <h4>@moment.Title</h4>
                                            <p>@moment.Description</p>
                                            <span>@moment.Time.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                </div>
            </div>

            <div class="section-card measurements-card">
                <div class="section-header">
                    <h2>@T("invite.recentMeasurements") (@RecentMeasurements.Count)</h2>
                    @if (RecentMeasurements.Any())
                    {
                        <span class="page-count">@Ui("Page", "Pagina") @CurrentPage / @TotalPages</span>
                    }
                </div>
                @if (!RecentMeasurements.Any())
                {
                    <p class="no-data-note">@T("selected.noRecentMeasurements")</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="recent-table">
                            <thead>
                                <tr>
                                    <th>@T("export.date")</th>
                                    <th>@T("selected.heartRate")</th>
                                    <th>@T("selected.temperature")</th>
                                    <th>@T("meas.spo2")</th>
                                    <th>@T("export.activity")</th>
                                    <th>@T("export.fall")</th>
                                    <th>@Ui("Status", "Status")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var m in PagedMeasurements)
                                {
                                    var status = GetStatus(m);
                                    <tr class="@status">
                                        <td class="cell-date">@m.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</td>
                                        <td class="@GetCellClass(m, "hr")">@m.Pulse.ToString("F0") bpm</td>
                                        <td class="@GetCellClass(m, "temp")">@m.Temperature.ToString("F1") C</td>
                                        <td class="@GetCellClass(m, "spo2")">@m.SpO2.ToString("F0")%</td>
                                        <td>@(string.IsNullOrWhiteSpace(m.Activity) ? "-" : m.Activity)</td>
                                        <td>@(m.IsFall ? Ui("Yes", "Da") : "-")</td>
                                        <td><span class="status-pill @status">@GetStatusLabel(status)</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (TotalPages > 1)
                    {
                        <div class="pagination">
                            <button class="page-btn" @onclick="() => GoToPage(1)" disabled="@(!HasPrevious)">&lt;&lt;</button>
                            <button class="page-btn" @onclick="() => GoToPage(CurrentPage - 1)" disabled="@(!HasPrevious)">&lt;</button>
                            @foreach (var p in GetPageNumbers())
                            {
                                @if (p == -1)
                                {
                                    <span class="page-ellipsis">...</span>
                                }
                                else
                                {
                                    <button class="page-btn @(p == CurrentPage ? "active" : "")" @onclick="() => GoToPage(p)">@p</button>
                                }
                            }
                            <button class="page-btn" @onclick="() => GoToPage(CurrentPage + 1)" disabled="@(!HasNext)">&gt;</button>
                            <button class="page-btn" @onclick="() => GoToPage(TotalPages)" disabled="@(!HasNext)">&gt;&gt;</button>
                        </div>
                    }
                }
            </div>

            @* ── Doctor sticky note ── *@
            <div class="section-card doctor-note-card" style="margin-top:1.5rem;">
                <div class="doctor-note-header">
                    <span class="doctor-note-icon">📝</span>
                    <strong>@T("selected.doctorNotes")</strong>
                    @if (_noteUpdatedAt.HasValue)
                    {
                        <span style="margin-left:auto;font-size:0.8rem;color:#8d6e63;">@_noteUpdatedAt.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
                    }
                </div>
                <textarea class="doctor-note-textarea"
                          placeholder="@T("selected.doctorNotesPlaceholder")"
                          @bind="_noteContent"
                          rows="5"></textarea>
                <div class="doctor-note-footer">
                    @if (!string.IsNullOrEmpty(_noteStatus))
                    {
                        <span class="doctor-note-status">@_noteStatus</span>
                    }
                    <button class="doctor-note-save" @onclick="SaveNoteAsync" disabled="@_noteSaving">
                        @(_noteSaving ? T("selected.doctorNotesSaving") : T("selected.doctorNotesSave"))
                    </button>
                </div>
            </div>

        }
    </div>
</div>

@if (_showExportModal)
{
    <div class="modal-overlay" @onclick="CloseExportModal">
        <div class="modal-content export-modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>@T("export.selectPeriod")</h2>
                <button class="modal-close" @onclick="CloseExportModal">x</button>
            </div>
            <div class="modal-body">
                <div class="export-date-range">
                    <div class="form-group">
                        <label>@T("export.startDate")</label>
                        <input type="date" @bind="_exportStartDate" @bind:after="UpdateExportStats" min="@_exportMinDate?.ToString("yyyy-MM-dd")" max="@_exportEndDate?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="form-group">
                        <label>@T("export.endDate")</label>
                        <input type="date" @bind="_exportEndDate" @bind:after="UpdateExportStats" min="@_exportStartDate?.ToString("yyyy-MM-dd")" max="@_exportMaxDate?.ToString("yyyy-MM-dd")" />
                    </div>
                </div>
                @if (_exportMeasurementCount.HasValue)
                {
                    <p class="export-info">@string.Format(T("export.measurementsInPeriod"), _exportMeasurementCount.Value)</p>
                    <p class="export-info">@string.Format(T("export.daysWithData"), _exportDistinctDays)</p>
                    @if (_exportDistinctDays < 7)
                    {
                        <p class="export-warning">@T("export.minDaysWarning")</p>
                    }
                }
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseExportModal">@T("common.cancel")</button>
                <button class="btn-save" @onclick="GenerateExportPdfAsync" disabled="@(_isExporting || _exportDistinctDays < 7)">
                    @(_isExporting ? T("export.generating") : T("export.generate"))
                </button>
            </div>
        </div>
    </div>
}
