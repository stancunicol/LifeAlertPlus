@page "/support"
@using LifeAlertPlus.Client.Components.Header
@layout MainLayout

<HeaderComponent UserName="@UserFullName" ProfilePictureUrl="@ProfilePictureUrl"/>

<div class="support-page">
    <div class="support-container">
        <h2 class="section-title">@T("support.title")</h2>
        <p class="support-intro-text">@T("support.intro")</p>
    </div>

    <div class="support-content">
        <div class="contact-card">
                <div class="contact-icon">📧</div>
                <div class="contact-body">
                    <h3>@T("support.contactTitle")</h3>
                    <p>@T("support.contactText")</p>
                    <a href="mailto:support@lifealertplusiot.com" class="email-link">support&#64;lifealertplusiot.com</a>
                    <p class="contact-note">@T("support.contactNote")</p>
                </div>
            </div>

            <div class="checklist-section">
                <h3 class="subsection-title">📋 @T("support.beforeTitle")</h3>
                <p>@T("support.beforeText")</p>
                <div class="checklist-grid">
                    <div class="checklist-item">
                        <span class="check-icon">🔋</span>
                        <span>@T("support.checkCharged")</span>
                    </div>
                    <div class="checklist-item">
                        <span class="check-icon">🔄</span>
                        <span>@T("support.checkRestart")</span>
                    </div>
                    <div class="checklist-item">
                        <span class="check-icon">📶</span>
                        <span>@T("support.checkInternet")</span>
                    </div>
                    <div class="checklist-item">
                        <span class="check-icon">⬆️</span>
                        <span>@T("support.checkUpdate")</span>
                    </div>
                </div>
            </div>

            <div class="issues-section">
                <h3 class="subsection-title">🔧 @T("support.commonTitle")</h3>
                <div class="issues-grid">
                    <div class="issue-card">
                        <div class="issue-header">
                            <span class="issue-icon">📡</span>
                            <h4>@T("support.issueNoData")</h4>
                        </div>
                        <ul class="issue-steps">
                            <li>@T("support.issueBattery")</li>
                            <li>@T("support.issueRestart")</li>
                        </ul>
                    </div>

                    <div class="issue-card">
                        <div class="issue-header">
                            <span class="issue-icon">🖥️</span>
                            <h4>@T("support.issueNotLoading")</h4>
                        </div>
                        <ul class="issue-steps">
                            <li>@T("support.issueRefresh")</li>
                            <li>@T("support.issueConnection")</li>
                        </ul>
                    </div>

                    <div class="issue-card">
                        <div class="issue-header">
                            <span class="issue-icon">🔐</span>
                            <h4>@T("support.issueLogin")</h4>
                        </div>
                        <ul class="issue-steps">
                            <li>@T("support.issueResetPw")</li>
                            <li>@T("support.issueVerifyEmail")</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="technical-section">
                <h3 class="subsection-title">🛠️ @T("support.techTitle")</h3>
                <p>@T("support.techText")</p>
                <div class="tech-items">
                    <div class="tech-item">
                        <span class="tech-num">1</span>
                        <span>@T("support.techDesc")</span>
                    </div>
                    <div class="tech-item">
                        <span class="tech-num">2</span>
                        <span>@T("support.techSteps")</span>
                    </div>
                    <div class="tech-item">
                        <span class="tech-num">3</span>
                        <span>@T("support.techScreenshots")</span>
                    </div>
                </div>
                <a href="mailto:support@lifealertplusiot.com" class="email-link">support&#64;lifealertplusiot.com</a>
            </div>

            <div class="automated-section">
                <h3 class="subsection-title">📬 @T("support.autoTitle")</h3>
                <p>@T("support.autoText")</p>
                <div class="noreply-badge">
                    <span>noreply&#64;lifealertplusiot.com</span>
                </div>
                <p class="small-note">@T("support.autoNote")</p>
            </div>

            <div class="notice-box">
                <div class="notice-icon">⚠️</div>
                <div>
                    <h3 class="notice-title">@T("support.noticeTitle")</h3>
                    <p>@T("support.noticeText")</p>
                </div>
            </div>
    </div>
</div>
