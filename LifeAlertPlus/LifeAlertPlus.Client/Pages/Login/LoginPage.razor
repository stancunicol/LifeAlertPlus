@page "/"
@page "/login"
@layout EmptyLayout

<div class="login-rect">
    <div class="login-left">
        <div class="login-logo">LifeAlert +</div>
        <div class="login-description">Because every heartbeat matters</div>
        <div class="login-version">v @Version</div>
    </div>

    <div class="login-right">
        <div class="form-group">
            <label class="form-label">Email</label>
            <div class="input-wrapper">
                <input type="email" class="form-input form-input-icon"
                       placeholder="user@email.com"
                       @bind="Email"
                       @bind:event="oninput"
                       @onkeydown="HandleKeyDown" />
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Password</label>
            <div class="input-wrapper">
                <input type="@(_showPassword ? "text" : "password")"
                       class="form-input form-input-icon form-input-password"
                       placeholder="password123"
                       @bind="Password"
                       @bind:event="oninput"
                       @onkeydown="HandleKeyDown" />
            </div>
        </div>


        <button class="login-button" @onclick="OnLogin">Login</button>

        <div style="text-align:center; margin: 1px 0; color: #888; font-weight: bold;">or</div>

        <button class="login-button google-login" @onclick="LoginWithGoogle">
            <img src="/google-logo.png" alt="Google" style="height:20px; margin-right:8px; vertical-align:middle;" />
            Login with Google
        </button>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="error-message">
                @ErrorMessage
            </div>
        }

        <div class="form-links">
            <a class="form-link" @onclick="OpenForgotPasswordModal" @onclick:preventDefault>Forgot your password?</a>
            <a class="form-link" href="/register">Create a new account</a>
        </div>
    </div>
</div>

@if (ShowForgotPasswordModal)
{
    <div class="modal-overlay" @onclick="CloseForgotPasswordModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Reset Password</h3>
            </div>
            <div class="modal-body">
                @if (!IsForgotPasswordSuccess)
                {
                    <p>Enter your email address and we'll send you a link to reset your password.</p>
                    <div class="form-group">
                        <label class="form-label">Email</label>
                        <div class="input-wrapper">
                            <input type="email" class="form-input"
                                   placeholder="user@email.com"
                                   @bind="ForgotPasswordEmail" />
                        </div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(ForgotPasswordMessage))
                {
                    <div class="@(IsForgotPasswordSuccess ? "success-message" : "error-message")">
                        @ForgotPasswordMessage
                    </div>
                }
            </div>
            <div class="modal-footer">
                @if (!IsForgotPasswordSuccess)
                {
                    <button class="modal-button" @onclick="OnSendResetEmail">Send Reset Link</button>
                    <button class="modal-button-secondary" @onclick="CloseForgotPasswordModal">Cancel</button>
                }
                else
                {
                    <button class="modal-button" @onclick="CloseForgotPasswordModal">Close</button>
                }
            </div>
        </div>
    </div>
}