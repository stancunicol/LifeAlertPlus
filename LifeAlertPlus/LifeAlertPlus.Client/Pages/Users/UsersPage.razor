@page "/users"
@using System.Linq
@using LifeAlertPlus.Client.Components.HeaderAdmin
@using LifeAlertPlus.Shared.DTOs.Responses.User

<HeaderAdminComponent UserName="@UserFullName" ProfilePictureUrl="@ProfilePictureUrl" />

<div class="users-page">
	<div class="admin-container">
		<div class="admin-header">
			<div class="header-title-section">
				<h1>@T("users.title")</h1>
				<p class="admin-subtitle">@T("users.subtitle")</p>
			</div>
			<span class="tag chip-muted">@T("users.liveOverview")</span>
		</div>

		<div class="stats-grid admin-stats">
			<div class="stat-card">
				<div class="stat-icon users">👥</div>
				<div class="stat-info">
					<span class="stat-label">@T("users.totalUsers")</span>
					<span class="stat-value">@TotalUsers</span>
				</div>
			</div>
			<div class="stat-card">
				<div class="stat-icon online">🟢</div>
				<div class="stat-info">
					<span class="stat-label">@T("users.activeUsers")</span>
					<span class="stat-value">@ActiveUsers</span>
				</div>
			</div>
			<div class="stat-card">
				<div class="stat-icon alert">⚠️</div>
				<div class="stat-info">
					<span class="stat-label">@T("users.inactiveUsers")</span>
					<span class="stat-value critical">@(TotalUsers - ActiveUsers)</span>
				</div>
			</div>
			<div class="stat-card">
				<div class="stat-icon monitored">✅</div>
				<div class="stat-info">
					<span class="stat-label">@T("users.emailConfirmed")</span>
					<span class="stat-value">@ConfirmedUsers</span>
				</div>
			</div>
		</div>

		@if (IsLoading)
		{
			<div class="message-card">@T("users.loading")</div>
		}
		else if (!string.IsNullOrEmpty(ErrorMessage))
		{
			<div class="message-card error">
				<span>@ErrorMessage</span>
				<button @onclick="LoadUsersAsync">@T("users.retry")</button>
			</div>
		}
		else
		{
			<div class="section">
				<div class="section-header">
					<div>
						<h2>@T("users.usersTitle")</h2>
						<span class="section-note">@ActiveUsers active • @ConfirmedUsers email confirmed</span>
					</div>
					<div class="section-actions">
						<input class="search" @bind="SearchText" @bind:event="oninput" placeholder="@T("users.searchPh")" />
						<div class="filters">
							<button class="@GetFilterClass("all")" @onclick='@(() => SetFilter("all"))'>@T("users.all")</button>
							<button class="@GetFilterClass("active")" @onclick='@(() => SetFilter("active"))'>@T("users.active")</button>
							<button class="@GetFilterClass("inactive")" @onclick='@(() => SetFilter("inactive"))'>@T("users.inactive")</button>
						</div>
					</div>
				</div>

				@if (!FilteredUsers.Any())
				{
					<div class="message-card">@T("users.noUsersFound")</div>
				}
				else
				{
					<div class="table-container">
						<table class="admin-table users-table">
							<thead>
								<tr>
									<th>@T("users.thUser")</th>
									<th>@T("users.thEmail")</th>
									<th>@T("users.thMonitored")</th>
									<th>@T("users.thProvider")</th>
									<th>@T("users.thStatus")</th>
									<th>@T("users.thEmailConfirmed")</th>
									<th>@T("users.thActions")</th>
								</tr>
							</thead>
							<tbody>
								@foreach (var user in FilteredUsers)
								{
									<tr class="@GetRowClass(user)">
										<td>
											<div class="person-inline">
												<div class="mini-avatar">@GetInitials(user)</div>
												<div class="person-inline-info">
													<span class="person-name">@user.FirstName @user.LastName</span>
												</div>
											</div>
										</td>
										<td class="mono">@user.Email</td>
										<td class="mono">@(MonitoredCounts.TryGetValue(user.Id, out var c) ? c : 0)</td>
										<td><span class="badge muted">@GetProviderLabel(user)</span></td>
										<td>
											<span class="status-indicator @GetStatusIndicatorClass(user)">@GetStatusLabel(user)</span>
										</td>
										<td><span class="badge @(user.IsEmailConfirmed ? "ok" : "warn")">@GetEmailLabel(user)</span></td>
										<td class="actions-cell">
											<div class="actions-center">
												<button class="btn-details" @onclick:stopPropagation @onclick="() => ViewUser(user)">@T("users.details")</button>
											</div>
											<div class="actions-row">
											<button class="action-btn" @onclick:stopPropagation @onclick="() => ToggleActive(user)">@(user.DeletedAt == null ? T("users.deactivate") : T("users.activate"))</button>
											<button class="action-btn danger" @onclick:stopPropagation @onclick="() => ConfirmDelete(user)">@T("users.delete")</button>
											</div>
										</td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				}
			</div>
		}
	</div>
</div>
