@page "/dashboard"

@using LifeAlertPlus.Domain.Entities

<HeaderComponent UserName="@UserFullName" ProfilePictureUrl="@ProfilePictureUrl" />

<div class="dashboard-container">
    <div class="dashboard-header">
        <h1>@T("dashboard.title")</h1>
        <p class="dashboard-subtitle">@string.Format(T("dashboard.welcome"), UserFullName)</p>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon heart">❤️</div>
            <div class="stat-info">
                <span class="stat-label">@T("dashboard.totalMonitored")</span>
                <span class="stat-value">@TotalMonitored</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon alert">⚠️</div>
            <div class="stat-info">
                <span class="stat-label">@T("dashboard.activeAlerts")</span>
                <span class="stat-value critical">@ActiveAlerts</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon check">✓</div>
            <div class="stat-info">
                <span class="stat-label">@T("dashboard.stableStatus")</span>
                <span class="stat-value ok">@StableCount</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon off">📴</div>
            <div class="stat-info">
                <span class="stat-label">@T("dashboard.usersOffline")</span>
                <span class="stat-value muted">@OfflineCount</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon chart">📊</div>
            <div class="stat-info">
                <span class="stat-label">@T("dashboard.measurementsToday")</span>
                <span class="stat-value">@TodayMeasurements</span>
            </div>
        </div>
    </div>

    <div class="content-grid">
        <div class="section monitored-section full-width">
            <div class="section-header">
                <h2>@T("dashboard.monitoredPeople")</h2>
                <a href="/monitored" class="view-all-link">@T("dashboard.viewAll")</a>
            </div>

            @if (!MonitoredSamples.Any())
            {
                <div class="dashboard-empty-state">
                    <img src="dispozitiv_enhanced.jpeg" alt="LifeAlertPlus Device" class="empty-device-img" />
                    <div class="empty-state-content">
                        <h3>@T("dashboard.emptyTitle")</h3>
                        <p>@T("dashboard.emptyText")</p>
                        <ol class="empty-steps">
                            <li>@T("dashboard.emptyStep1")</li>
                            <li>@T("dashboard.emptyStep2")</li>
                            <li>@T("dashboard.emptyStep3")</li>
                        </ol>
                        <div class="empty-support">
                            <span>@T("dashboard.emptySupport")</span>
                            <a href="mailto:support@lifealertplusiot.com" class="empty-email">support&#64;lifealertplusiot.com</a>
                        </div>
                        <a href="/monitored" class="btn-add-first">@T("dashboard.emptyAddBtn")</a>
                    </div>
                </div>
            }
            <div class="monitored-grid">
                @foreach (var person in MonitoredSamples)
                {
                    <div class="person-card-detailed clickable" @onclick="() => NavigateToMonitored(person.Id)">
                        <div class="card-header-colored @GetCardClass(person.Status, person.Online)">
                            <div class="header-top">
                                <div class="person-avatar-big">@GetInitials(person.Name)</div>
                                <div class="person-basic-info">
                                    <h3 class="person-name-big">@person.Name</h3>
                                    <div class="status-row">
                                        <span class="status-dot"></span>
                                        <span class="status-text">@GetStatusText(person.Status, person.Online)</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-body-white">
                            <div class="vitals-grid">
                                <div class="vital-box @(person.HeartRate <= 0 ? "no-data" : "")">
                                    <span class="vital-icon-large">❤️</span>
                                    <div class="vital-info">
                                        <span class="vital-value-large">@(person.HeartRate > 0 ? person.HeartRate.ToString() : T("card.na"))</span>
                                        <span class="vital-label-large">@T("card.pulse")</span>
                                    </div>
                                </div>
                                <div class="vital-box @(person.SpO2 == "N/A" ? "no-data" : "")">
                                    <span class="vital-icon-large">🩸</span>
                                    <div class="vital-info">
                                        <span class="vital-value-large">@person.SpO2</span>
                                        <span class="vital-label-large">@T("card.spo2")</span>
                                    </div>
                                </div>
                                <div class="vital-box @(person.Temperature == "N/A" ? "no-data" : "")">
                                    <span class="vital-icon-large">🌡️</span>
                                    <div class="vital-info">
                                        <span class="vital-value-large">@person.Temperature</span>
                                        <span class="vital-label-large">@T("card.temperature")</span>
                                    </div>
                                </div>
                            </div>
                            <div class="additional-info">
                                <div class="info-item">
                                    <span class="info-label">@T("card.gps")</span>
                                    <span class="info-value">@person.GPS</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">@T("card.fallDetection")</span>
                                    <span class="info-value">@person.FallDetection</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">@T("card.lastUpdate")</span>
                                    <span class="info-value">@person.LastUpdateFull</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (_showOnboarding)
{
    <div class="modal-overlay onboarding-overlay" @onclick="DismissOnboarding">
        <div class="onboarding-modal" @onclick:stopPropagation="true">
            <button class="onboarding-close" @onclick="DismissOnboarding">✕</button>
            <div class="onboarding-icon">👋</div>
            <h2>@T("onboarding.title")</h2>
            <p>@T("onboarding.subtitle")</p>
            <div class="onboarding-steps">
                <div class="onboarding-step">
                    <div class="onboarding-step-num">1</div>
                    <div>
                        <strong>@T("onboarding.step1Title")</strong>
                        <p>@T("onboarding.step1Text")</p>
                    </div>
                </div>
                <div class="onboarding-step">
                    <div class="onboarding-step-num">2</div>
                    <div>
                        <strong>@T("onboarding.step2Title")</strong>
                        <p>@T("onboarding.step2Text")</p>
                    </div>
                </div>
                <div class="onboarding-step">
                    <div class="onboarding-step-num">3</div>
                    <div>
                        <strong>@T("onboarding.step3Title")</strong>
                        <p>@T("onboarding.step3Text")</p>
                    </div>
                </div>
            </div>
            <div class="onboarding-actions">
                <a href="/monitored" class="onboarding-btn-primary" @onclick="DismissOnboarding">@T("onboarding.getStarted")</a>
                <button class="onboarding-btn-secondary" @onclick="DismissOnboarding">@T("onboarding.later")</button>
            </div>
        </div>
    </div>
}