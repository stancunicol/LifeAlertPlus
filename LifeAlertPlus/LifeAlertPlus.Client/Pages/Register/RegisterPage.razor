@page "/register"
@layout EmptyLayout

<div class="auth-bg"></div>
<div class="login-rect">
    <div class="login-left">
        <div class="login-logo">@T("login.title")</div>
        <div class="login-description">@T("login.tagline")</div>
        <p class="login-version">v @Version</p>
    </div>

    <div class="login-right">
        <h2 class="page-title">@T("register.title")</h2>
        <div class="form-row">
            <div class="form-group form-group-half">
                <label class="form-label">@T("register.firstName")</label>
                <div class="input-wrapper">
                    <input type="text" class="form-input form-input-icon"
                           placeholder="John"
                           @bind="FirstName"
                           @bind:event="oninput"
                           @onkeydown="HandleKeyDown" />
                </div>
            </div>

            <div class="form-group form-group-half">
                <label class="form-label">@T("register.lastName")</label>
                <div class="input-wrapper">
                    <input type="text" class="form-input form-input-icon"
                           placeholder="Doe"
                           @bind="LastName"
                           @bind:event="oninput"
                           @onkeydown="HandleKeyDown" />
                </div>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label">@T("register.email")</label>
                <div class="input-wrapper">
                    <input type="email" class="form-input form-input-icon"
                           placeholder="user@email.com"
                           @bind="Email"
                           @bind:event="oninput"
                           @onkeydown="HandleKeyDown" />
                </div>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label">@T("register.phoneNumber")</label>
                <div class="input-wrapper">
                    <input type="tel" class="form-input form-input-icon"
                           placeholder="+40 7XX XXX XXX"
                           @bind="PhoneNumber"
                           @bind:event="oninput"
                           @onkeydown="HandleKeyDown" />
                </div>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group form-group-half">
                <label class="form-label">@T("register.password")</label>
                <div class="input-wrapper">
                    <div class="password-field">
                        <input type="password"
                               class="form-input form-input-icon"
                               placeholder="password123"
                               @bind="Password"
                               @bind:event="oninput"
                               @onkeydown="HandleKeyDown" />
                    </div>
                </div>
            </div>

            <div class="form-group form-group-half">
                <label class="form-label">@T("register.confirmPassword")</label>
                <div class="input-wrapper">
                    <div class="password-field">
                        <input type="password"
                               class="form-input form-input-icon"
                               placeholder="password123"
                               @bind="ConfirmPassword"
                               @bind:event="oninput"
                               @onkeydown="HandleKeyDown" />
                    </div>
                </div>
            </div>
        </div>

        @if (Password.Length > 0)
        {
            <div class="password-strength-bar">
                <div class="strength-fill @PasswordStrengthClass" style="width:@(PasswordStrength * 25)%"></div>
            </div>
            <p class="strength-label @PasswordStrengthClass">@PasswordStrengthLabel</p>
        }

        <button class="login-button" @onclick="OnRegister" disabled="@IsLoading">@(IsLoading ? T("register.loading") : T("register.title"))</button>

        @if (!string.IsNullOrEmpty(SuccessMessage))
        {
            <div class="success-message" style="color: green; margin-top: 10px; text-align: center;">
                @SuccessMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="error-message">
                @ErrorMessage
            </div>
        }

        <div class="form-links">
            <a class="form-link" href="/login">@T("register.hasAccount")</a>
        </div>
    </div>
</div>

@if (ShowConsentModal)
{
    <div class="modal-overlay consent-overlay" @onclick="CloseConsentModal">
        <div class="modal-content consent-modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>🔒 @T("register.consentModalTitle")</h3>
                <button class="consent-close-btn" @onclick="CloseConsentModal" title="Close">✕</button>
            </div>
            <div class="modal-body consent-body">
                <p class="consent-lead">@T("register.consentLead")</p>

                <div class="consent-items">
                    <div class="consent-item">
                        <span class="consent-item-icon">❤️</span>
                        <span>@T("register.consentItem1")</span>
                    </div>
                    <div class="consent-item">
                        <span class="consent-item-icon">📍</span>
                        <span>@T("register.consentItem2")</span>
                    </div>
                    <div class="consent-item">
                        <span class="consent-item-icon">🔔</span>
                        <span>@T("register.consentItem3")</span>
                    </div>
                </div>

                <div class="consent-art9-box">
                    <strong>⚠ @T("register.consentArt9Title")</strong>
                    <p>@T("register.consentArt9Body")</p>
                </div>

                <label class="consent-checkbox-row">
                    <input type="checkbox" @bind="ConsentChecked" class="consent-checkbox" />
                    <span>@T("register.consentCheckboxLabel")</span>
                </label>
            </div>
            <div class="modal-footer consent-footer">
                <button class="modal-button consent-cancel" @onclick="CloseConsentModal">@T("register.consentDecline")</button>
                <button class="modal-button consent-accept" @onclick="ConfirmConsentAndRegister" disabled="@(!ConsentChecked)">
                    @T("register.consentAccept")
                </button>
            </div>
        </div>
    </div>
}

@if (ShowModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@T("register.success")</h3>
            </div>
            <div class="modal-body">
                <p>@T("register.emailSent")</p>
            </div>
            <div class="modal-footer">
                <button class="modal-button" @onclick="CloseModal">@T("register.ok")</button>
            </div>
        </div>
    </div>
}
