@page "/monitored/{PersonId:guid}/measurements"
@using LifeAlertPlus.Client.Components.Header
@layout MainLayout
@using LifeAlertPlus.Domain.Entities

<HeaderComponent UserName="@UserFullName" ProfilePictureUrl="@ProfilePictureUrl" />

<div class="meas-page">

    <!-- Header -->
    <div class="meas-header">
        <div>
            <a href="/monitored/@PersonId" class="meas-back-link">← @T("meas.back")</a>
            <h1 class="meas-title">@T("meas.title")</h1>
            <p class="meas-subtitle">@PersonName</p>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="meas-loading">
            <div class="loading-ring"></div>
            <span>@T("meas.loading")</span>
        </div>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="meas-empty">
            <span class="empty-icon">⚠️</span>
            <h3>@ErrorMessage</h3>
            <button class="btn-retry" @onclick="LoadAllAsync">@T("meas.retry")</button>
        </div>
    }
    else
    {
        <!-- Stats -->
        <div class="meas-stats">
            <div class="stat-card normal">
                <span class="stat-icon">💚</span>
                <div class="stat-body">
                    <span class="stat-num">@NormalCount</span>
                    <span class="stat-lbl">@T("meas.normal")</span>
                </div>
            </div>
            <div class="stat-card alert">
                <span class="stat-icon">⚠️</span>
                <div class="stat-body">
                    <span class="stat-num">@AlertCount</span>
                    <span class="stat-lbl">@T("meas.alert")</span>
                </div>
            </div>
            <div class="stat-card critical">
                <span class="stat-icon">🚨</span>
                <div class="stat-body">
                    <span class="stat-num">@CriticalCount</span>
                    <span class="stat-lbl">@T("meas.critical")</span>
                </div>
            </div>
            <div class="stat-card total">
                <span class="stat-icon">📋</span>
                <div class="stat-body">
                    <span class="stat-num">@TotalLoaded</span>
                    <span class="stat-lbl">@T("meas.total")</span>
                </div>
            </div>
        </div>

        <!-- Filters -->
        <div class="meas-filters">
            <button class="filter-btn @(StatusFilter == "all" && TypeFilter == "all" ? "active" : "")"
                    @onclick='() => { SetStatusFilter("all"); SetTypeFilter("all"); }'>
                @T("meas.all")
            </button>
            <button class="filter-btn normal-btn @(StatusFilter == "normal" ? "active" : "")"
                    @onclick='() => SetStatusFilter("normal")'>
                💚 @T("meas.normal")
            </button>
            <button class="filter-btn alert-btn @(StatusFilter == "alert" ? "active" : "")"
                    @onclick='() => SetStatusFilter("alert")'>
                ⚠️ @T("meas.alert")
            </button>
            <button class="filter-btn critical-btn @(StatusFilter == "critical" ? "active" : "")"
                    @onclick='() => SetStatusFilter("critical")'>
                🚨 @T("meas.critical")
            </button>
            <button class="filter-btn fall-btn @(TypeFilter == "fall" ? "active" : "")"
                    @onclick='() => SetTypeFilter(TypeFilter == "fall" ? "all" : "fall")'>
                🤕 @T("meas.falls")
            </button>
            <button class="filter-btn @(TypeFilter == "hr" ? "active" : "")"
                    @onclick='() => SetTypeFilter(TypeFilter == "hr" ? "all" : "hr")'>
                ❤️ @T("meas.hr")
            </button>
            <button class="filter-btn @(TypeFilter == "spo2" ? "active" : "")"
                    @onclick='() => SetTypeFilter(TypeFilter == "spo2" ? "all" : "spo2")'>
                🫁 @T("meas.spo2")
            </button>
            <button class="filter-btn @(TypeFilter == "temp" ? "active" : "")"
                    @onclick='() => SetTypeFilter(TypeFilter == "temp" ? "all" : "temp")'>
                🌡️ @T("meas.temp")
            </button>
        </div>

        <!-- Feed -->
        @if (!FilteredMeasurements.Any())
        {
            <div class="meas-empty">
                <span class="empty-icon">📋</span>
                <h3>@T("meas.noMatch")</h3>
            </div>
        }
        else
        {
            <div class="meas-feed">
                @foreach (var m in FilteredMeasurements)
                {
                    var status = GetStatus(m);
                    <div class="meas-card @status">
                        <div class="meas-icon @status">
                            @(m.IsFall ? "🤕" : status == "critical" ? "🚨" : status == "alert" ? "⚠️" : "💚")
                        </div>
                        <div class="meas-body">
                            <div class="meas-meta-row">
                                <span class="meas-badge @status">@GetStatusLabel(status)</span>
                                @if (m.IsFall)
                                {
                                    <span class="fall-badge">⚠️ @T("meas.fall")</span>
                                }
                                <span class="meas-time">🕐 @m.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</span>
                            </div>
                            <div class="meas-vitals">
                                <span class="vital @GetCellClass(m, "hr")">❤️ @m.Pulse.ToString("F0") bpm</span>
                                <span class="vital @GetCellClass(m, "temp")">🌡️ @m.Temperature.ToString("F1")°C</span>
                                <span class="vital @GetCellClass(m, "spo2")">🫁 @m.SpO2.ToString("F0")%</span>
                                @if (!string.IsNullOrWhiteSpace(m.Activity))
                                {
                                    <span class="vital activity">🏃 @m.Activity</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (TotalPages > 1)
            {
                <div class="meas-pagination">
                    <button class="page-btn nav" disabled="@(!HasPrevious)" @onclick="() => GoToPage(CurrentPage - 1)">←</button>
                    @foreach (var p in GetPageNumbers())
                    {
                        @if (p == -1)
                        {
                            <span class="page-ellipsis">…</span>
                        }
                        else
                        {
                            <button class="page-btn @(p == CurrentPage ? "active" : "")" @onclick="() => GoToPage(p)">@p</button>
                        }
                    }
                    <button class="page-btn nav" disabled="@(!HasNext)" @onclick="() => GoToPage(CurrentPage + 1)">→</button>
                </div>
                <p class="pagination-info">
                    @string.Format("{0} / {1} ({2} {3})", CurrentPage, TotalPages, TotalLoaded, T("meas.total"))
                </p>
            }
        }
    }
</div>
