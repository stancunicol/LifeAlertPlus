@page "/profile"
@using LifeAlertPlus.Client.Components.Header
@layout MainLayout

<HeaderComponent UserName="@CurrentUser.FirstName"/>

<div class="profile-container">
    <div class="profile-header">
        <div class="profile-avatar-section">
            <div class="profile-avatar-large">@GetUserInitials(CurrentUser.FirstName)</div>
            <button class="btn-change-photo">📸 Change Picture</button>
        </div>
        <div class="profile-info">
            <h1>@CurrentUser.FirstName @CurrentUser.LastName</h1>
            <p class="profile-email">@CurrentUser.Email</p>
            <div class="profile-stats-mini">
                <div class="stat-mini">
                    <span class="stat-mini-value">@MonitoredCount</span>
                    <span class="stat-mini-label">Monitored</span>
                </div>
                <div class="stat-mini">
                    <span class="stat-mini-value">@AlertsCount</span>
                    <span class="stat-mini-label">Active Alerts</span>
                </div>
                <div class="stat-mini">
                    <span class="stat-mini-value">@DaysActive</span>
                    <span class="stat-mini-label">Active Days</span>
                </div>
            </div>
        </div>
    </div>

    <div class="profile-content">
        <div class="profile-section">
            <div class="section-header">
                <h2>📋 Personal information</h2>
                @if (!IsEditingPersonal)
                {
                    <button class="btn-edit" @onclick="EnableEditPersonal">✏️ Edit</button>
                }
                else
                {
                    <div class="edit-actions">
                        <button class="btn-save" @onclick="SavePersonalInfo">💾 Save</button>
                        <button class="btn-cancel" @onclick="CancelEditPersonal">✖️ Cancel</button>
                    </div>
                }
            </div>
            <div class="section-content">
                <div class="info-grid">
                    <div class="info-item">
                        <label>First Name</label>
                        @if (!IsEditingPersonal)
                        {
                            <p>@CurrentUser.FirstName</p>
                        }
                        else
                        {
                            <input type="text" @bind="EditUser.FirstName" class="input-edit" />
                        }
                        <label>Last Name</label>
                        @if (!IsEditingPersonal)
                        {
                            <p>@CurrentUser.LastName</p>
                        }
                        else
                        {
                            <input type="text" @bind="EditUser.LastName" class="input-edit" />
                        }
                    </div>
                    <div class="info-item">
                        <label>Telephone</label>
                        @if (!IsEditingPersonal)
                        {
                            <p>@CurrentUser.Telephone</p>
                        }
                        else
                        {
                            <input type="tel" @bind="EditUser.Telephone" class="input-edit" />
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="profile-section">
            <div class="section-header">
                <h2>🔒 Security</h2>
            </div>
            <div class="section-content">
                <div class="security-item">
                    <div class="security-info">
                        <h3>Change Password</h3>
                        <p>Last changed 3 months ago</p>
                    </div>
                    <button class="btn-security" @onclick="OpenChangePasswordModal">Change Password</button>
                </div>
                <div class="security-item">
                    <div class="security-info">
                        <h3>Change Email</h3>
                        <p>Update your email address</p>
                    </div>
                    <button class="btn-security" @onclick="OpenChangeEmailModal">Change Email</button>
                </div>
                <div class="security-item">
                    <div class="security-info">
                        <h3>Active Sessions</h3>
                        <p>Manage connected devices</p>
                    </div>
                    <button class="btn-security">View Sessions</button>
                </div>
            </div>
        </div>

        <div class="profile-section">
            <div class="section-header">
                <h2>🔔 Notification Preferences</h2>
            </div>
            <div class="section-content">
                <div class="preference-item">
                    <div class="preference-info">
                        <h3>Email Notifications</h3>
                        <p>Receive important alerts via email</p>
                    </div>
                    <label class="switch">
                        <input type="checkbox" @bind="Preferences.EmailNotifications" />
                        <span class="slider"></span>
                    </label>
                </div>
                <div class="preference-item">
                    <div class="preference-info">
                        <h3>Push Notifications</h3>
                        <p>Real-time alerts in your browser</p>
                    </div>
                    <label class="switch">
                        <input type="checkbox" @bind="Preferences.PushNotifications" />
                        <span class="slider"></span>
                    </label>
                </div>
                <div class="preference-item">
                    <div class="preference-info">
                        <h3>Critical Alerts</h3>
                        <p>Priority notifications for emergency situations</p>
                    </div>
                    <label class="switch">
                        <input type="checkbox" @bind="Preferences.CriticalAlerts" />
                        <span class="slider"></span>
                    </label>
                </div>
                <div class="preference-item">
                    <div class="preference-info">
                        <h3>Daily Summary</h3>
                        <p>Receive a daily activity report</p>
                    </div>
                    <label class="switch">
                        <input type="checkbox" @bind="Preferences.DailySummary" />
                        <span class="slider"></span>
                    </label>
                </div>
            </div>
        </div>

        <div class="profile-section danger-section">
            <div class="section-header">
                <h2>⚠️ Danger Zone</h2>
            </div>
            <div class="section-content">
                <div class="danger-item">
                    <div class="danger-info">
                        <h3>Deactivate Account</h3>
                        <p>Your account will be temporarily suspended</p>
                    </div>
                    <button class="btn-danger" disabled>Deactivate</button>
                </div>
                <div class="danger-item">
                    <div class="danger-info">
                        <h3>Delete Account</h3>
                        <p>Permanent action, all data will be deleted</p>
                    </div>
                    <button class="btn-danger" disabled>Delete Permanently</button>
                </div>
            </div>
        </div>
    </div>
</div>

@if (ShowChangePasswordModal)
{
    <div class="modal-overlay" @onclick="CloseChangePasswordModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>🔒 Change Password</h2>
                <button class="modal-close" @onclick="CloseChangePasswordModal">✖️</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Current Password</label>
                    <input type="password" @bind="PasswordChange.CurrentPassword" placeholder="Enter current password" class="input-modal" />
                </div>
                <div class="form-group">
                    <label>New Password</label>
                    <input type="password" @bind="PasswordChange.NewPassword" placeholder="At least 8 characters" class="input-modal" />
                </div>
                <div class="form-group">
                    <label>Confirm New Password</label>
                    <input type="password" @bind="PasswordChange.ConfirmPassword" placeholder="Re-enter new password" class="input-modal" />
                </div>
                @if (!string.IsNullOrEmpty(PasswordError))
                {
                    <div class="error-message">@PasswordError</div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn-modal-cancel" @onclick="CloseChangePasswordModal">Cancel</button>
                <button class="btn-modal-confirm" @onclick="ChangePassword">Change Password</button>
            </div>
        </div>
    </div>
}

@if (ShowChangeEmailModal)
{
    <div class="modal-overlay" @onclick="CloseChangeEmailModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>📧 Change Email</h2>
                <button class="modal-close" @onclick="CloseChangeEmailModal">✖️</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>New Email</label>
                    <input type="email" @bind="EmailChange.NewEmail" placeholder="Enter new email address" class="input-modal" />
                </div>
                <div class="form-group">
                    <label>Confirm New Email</label>
                    <input type="email" @bind="EmailChange.ConfirmEmail" placeholder="Re-enter new email address" class="input-modal" />
                </div>
                <div class="form-group">
                    <label>Current Password</label>
                    <input type="password" @bind="EmailChange.CurrentPassword" placeholder="Enter your password to confirm" class="input-modal" />
                </div>
                @if (!string.IsNullOrEmpty(EmailError))
                {
                    <div class="error-message">@EmailError</div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn-modal-cancel" @onclick="CloseChangeEmailModal">Cancel</button>
                <button class="btn-modal-confirm" @onclick="ChangeEmail">Change Email</button>
            </div>
        </div>
    </div>
}

@* Modal pentru succes schimbare email *@
@if (ShowEmailChangeSuccess)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h3>✅ Email Changed Successfully</h3>
            </div>
            <div class="modal-body">
                <div class="success-content">
                    <p><strong>Your email address has been updated successfully!</strong></p>
                    <p>📧 A confirmation email has been sent to your new email address. Please check your inbox and click the verification link to complete the process.</p>
                    <p><strong>Note:</strong> For security reasons, you will be logged out automatically. Please log in again with your new email address after verification.</p>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-modal-confirm" @onclick="CloseEmailChangeSuccessModal">OK, Log me out</button>
            </div>
        </div>
    </div>
}
