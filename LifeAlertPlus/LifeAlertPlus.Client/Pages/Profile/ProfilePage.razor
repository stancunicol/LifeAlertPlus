@page "/profile"
@using LifeAlertPlus.Client.Components.Header
@layout MainLayout

<HeaderComponent UserName="@($"{CurrentUser.FirstName} {CurrentUser.LastName}")" ProfilePictureUrl="@CurrentUser.ProfilePictureUrl" />

<div class="profile-container">
    <div class="profile-header">
        <div class="profile-avatar-section">
            <div class="profile-avatar-large">
                @if (!string.IsNullOrEmpty(CurrentUser.ProfilePictureUrl))
                {
                    <img src="@CurrentUser.ProfilePictureUrl" alt="Profile" class="profile-avatar-img" />
                }
                else
                {
                    @GetUserInitials($"{CurrentUser.FirstName} {CurrentUser.LastName}")
                }
            </div>
        </div>
        <div class="profile-info">
            <h1>@CurrentUser.FirstName @CurrentUser.LastName</h1>
            <p class="profile-email">@CurrentUser.Email</p>
            <p class="profile-member-since">@string.Format(T("profile.memberSince"), CurrentUser.CreatedAt.ToString("MMMM yyyy", System.Globalization.CultureInfo.InvariantCulture))</p>
            <div class="profile-stats-mini">
                <div class="stat-mini">
                    <span class="stat-mini-value">@MonitoredCount</span>
                    <span class="stat-mini-label">@T("profile.monitored")</span>
                </div>
                <div class="stat-mini">
                    <span class="stat-mini-value">@AlertsCount</span>
                    <span class="stat-mini-label">@T("profile.activeAlerts")</span>
                </div>
            </div>
        </div>
    </div>

    <div class="profile-content">
        <div class="profile-section">
            <div class="section-header">
                <h2>@T("profile.personalInfo")</h2>
                @if (!IsEditingPersonal)
                {
                    <button class="btn-edit" @onclick="EnableEditPersonal">@T("profile.edit")</button>
                }
                else
                {
                    <div class="edit-actions">
                        <button class="btn-save" @onclick="SavePersonalInfo">@T("profile.save")</button>
                        <button class="btn-cancel" @onclick="CancelEditPersonal">@T("profile.cancel")</button>
                    </div>
                }
            </div>
            <div class="section-content">
                <div class="info-grid">
                    <div class="info-item">
                        <label>@T("profile.firstName")</label>
                        @if (!IsEditingPersonal)
                        {
                            <p>@CurrentUser.FirstName</p>
                        }
                        else
                        {
                            <input type="text" @bind="EditUser.FirstName" class="input-edit" />
                        }
                        <label>@T("profile.lastName")</label>
                        @if (!IsEditingPersonal)
                        {
                            <p>@CurrentUser.LastName</p>
                        }
                        else
                        {
                            <input type="text" @bind="EditUser.LastName" class="input-edit" />
                        }
                        <label>@T("profile.phoneNumber")</label>
                        @if (!IsEditingPersonal)
                        {
                            <p>@(string.IsNullOrWhiteSpace(CurrentUser.PhoneNumber) ? "—" : CurrentUser.PhoneNumber)</p>
                        }
                        else
                        {
                            <input type="tel" @bind="EditUser.PhoneNumber" class="input-edit" placeholder="+40 7XX XXX XXX" />
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="profile-section">
            <div class="section-header">
                <h2>@T("profile.security")</h2>
            </div>
            <div class="section-content">
                @if (CurrentUser.Provider == "Local")
                {
                    <div class="security-item">
                        <div class="security-info">
                            <h3>@T("profile.changePassword")</h3>
                            <p>@T("profile.lastChanged") @(CurrentUser.LastChangedPasswordAt.HasValue ? CurrentUser.LastChangedPasswordAt.Value.ToLocalTime().ToString("dd MMMM yyyy", Lang.CurrentLanguage == "ro" ? new System.Globalization.CultureInfo("ro-RO") : System.Globalization.CultureInfo.InvariantCulture) : T("profile.never"))</p>
                        </div>
                        <button class="btn-security" @onclick="OpenChangePasswordModal">@T("profile.changePasswordBtn")</button>
                    </div>
                    <div class="security-item">
                        <div class="security-info">
                            <h3>@T("profile.changeEmailTitle")</h3>
                            <p>@T("profile.updateEmailDesc")</p>
                        </div>
                        <button class="btn-security" @onclick="OpenChangeEmailModal">@T("profile.changeEmailBtn")</button>
                    </div>
                }
                else
                {
                    <div class="security-info">
                        <h3>@T("profile.passwordManaged")</h3>
                        <p>@T("profile.passwordManagedText") @CurrentUser.Provider</p>
                    </div>
                    <div class="security-info">
                        <h3>@T("profile.emailManaged")</h3>
                        <p>@T("profile.emailManagedText") @CurrentUser.Provider</p>
                    </div>
                }
            </div>
        </div>

        <div class="profile-section">
            <div class="section-header">
                <h2>🔔 @T("profile.notificationsTitle")</h2>
            </div>
            <div class="section-content">
                <p style="color:#666;font-size:0.95rem;">
                    @T("profile.notificationsRedirect")
                    <a href="/settings" style="color:#4CAF50;font-weight:600;">@T("profile.notificationsSettingsLink")</a>
                </p>
            </div>
        </div>

        <div class="profile-section danger-section">
            <div class="section-header">
                <h2>🔒 @T("profile.gdprZone")</h2>
            </div>
            <div class="section-content">
                <div class="danger-item">
                    <div class="danger-info">
                        <h3>@T("profile.gdprExportTitle")</h3>
                        <p>@T("profile.gdprExportDesc")</p>
                    </div>
                    <button class="btn-secondary-action" @onclick="DownloadGdprExport" disabled="@_gdprExporting">
                        @(_gdprExporting ? T("profile.gdprExporting") : T("profile.gdprExportBtn"))
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(_gdprExportError))
                {
                    <p class="gdpr-error">@_gdprExportError</p>
                }
            </div>
        </div>

        <div class="profile-section danger-section">
            <div class="section-header">
                <h2>⚠️ @T("profile.dangerZone")</h2>
            </div>
            <div class="section-content">
                <div class="danger-item">
                    <div class="danger-info">
                        <h3>@T("profile.deleteAccount")</h3>
                        <p>@T("profile.deleteAccountDesc")</p>
                    </div>
                    <button class="btn-danger" @onclick="ShowDeleteConfirmModal">@T("profile.deletePermanently")</button>
                </div>
            </div>
        </div>
    </div>
</div>

@if (ShowChangePasswordModal)
{
    <div class="modal-overlay" @onclick="CloseChangePasswordModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>🔒 @T("profile.changePasswordBtn")</h2>
                <button class="modal-close" @onclick="CloseChangePasswordModal">✖️</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>@T("profile.currentPassword")</label>
                    <div class="password-field">
                        <input type="@(_showCurrentPassword ? "text" : "password")" @bind="PasswordChange.CurrentPassword" placeholder="@T("profile.currentPasswordPh")" class="input-modal" />
                        <button type="button" class="password-toggle" @onclick="ToggleCurrentPasswordVisibility" aria-label="Toggle current password visibility">👁</button>
                    </div>
                </div>
                <div class="form-group">
                    <label>@T("profile.newPassword")</label>
                    <div class="password-field">
                        <input type="@(_showNewPassword ? "text" : "password")" @bind="PasswordChange.NewPassword" @bind:event="oninput" placeholder="@T("profile.newPasswordPh")" class="input-modal" />
                        <button type="button" class="password-toggle" @onclick="ToggleNewPasswordVisibility" aria-label="Toggle new password visibility">👁</button>
                    </div>
                    @if (!string.IsNullOrEmpty(PasswordChange.NewPassword))
                    {
                        <div class="password-strength-bar" style="margin-top:6px;">
                            <div class="strength-fill @NewPasswordStrengthClass" style="width:@(NewPasswordStrength * 25)%"></div>
                        </div>
                        <p class="strength-label @NewPasswordStrengthClass">@NewPasswordStrengthLabel</p>
                    }
                </div>
                <div class="form-group">
                    <label>@T("profile.confirmNewPassword")</label>
                    <div class="password-field">
                        <input type="@(_showConfirmPassword ? "text" : "password")" @bind="PasswordChange.ConfirmPassword" placeholder="@T("profile.confirmNewPasswordPh")" class="input-modal" />
                        <button type="button" class="password-toggle" @onclick="ToggleConfirmPasswordVisibility" aria-label="Toggle confirm password visibility">👁</button>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(PasswordError))
                {
                    <div class="error-message">@PasswordError</div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn-modal-cancel" @onclick="CloseChangePasswordModal">@T("common.cancel")</button>
                <button class="btn-modal-confirm" @onclick="ChangePassword">@T("profile.changePasswordBtn")</button>
            </div>
        </div>
    </div>
}

@if (ShowChangeEmailModal)
{
    <div class="modal-overlay" @onclick="CloseChangeEmailModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>📧 @T("profile.changeEmailTitle")</h2>
                <button class="modal-close" @onclick="CloseChangeEmailModal">✖️</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>@T("profile.newEmail")</label>
                    <input type="email" @bind="EmailChange.NewEmail" placeholder="@T("profile.newEmailPh")" class="input-modal" />
                </div>
                <div class="form-group">
                    <label>@T("profile.confirmNewEmail")</label>
                    <input type="email" @bind="EmailChange.ConfirmEmail" placeholder="@T("profile.confirmNewEmailPh")" class="input-modal" />
                </div>
                <div class="form-group">
                    <label>@T("profile.currentPassword")</label>
                    <div class="password-field">
                        <input type="@EmailCurrentPasswordFieldType" @bind="EmailChange.CurrentPassword" placeholder="@T("profile.passwordToConfirmPh")" class="input-modal" />
                        <button type="button" class="password-toggle" @onclick="ToggleEmailCurrentPasswordVisibility" aria-label="Toggle current password visibility">👁</button>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(EmailError))
                {
                    <div class="error-message">@EmailError</div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn-modal-cancel" @onclick="CloseChangeEmailModal">@T("common.cancel")</button>
                <button class="btn-modal-confirm" @onclick="ChangeEmail">@T("profile.changeEmailBtn")</button>
            </div>
        </div>
    </div>
}

@if (ShowEmailChangeSuccess)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h3>✅ @T("profile.emailChangedSuccess")</h3>
            </div>
            <div class="modal-body">
                <div class="success-content">
                    <p><strong>@T("profile.emailChangedText1")</strong></p>
                    <p>📧 @T("profile.emailChangedText2")</p>
                    <p>🔒 @T("profile.emailChangedText3")</p>
                    <p><strong>@T("common.note"):</strong> @T("profile.emailChangedNote")</p>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-modal-confirm" @onclick="CloseEmailChangeSuccessModal">@T("profile.okLogout")</button>
            </div>
        </div>
    </div>
}

@if (ShowPasswordChangeSuccess)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h3>✅ @T("profile.passwordChangedSuccess")</h3>
            </div>
            <div class="modal-body">
                <div class="success-content">
                    <p><strong>@T("profile.passwordChangedText1")</strong></p>
                    <p>🔒 @T("profile.passwordChangedText2")</p>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-modal-confirm" @onclick="ClosePasswordChangeSuccessModal">@T("profile.ok")</button>
            </div>
        </div>
    </div>
}

@if (ShowDeleteConfirmModalBool)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h3>⚠️ @T("profile.areYouSure")</h3>
            </div>
            <div class="modal-body">
                <p>@T("profile.deleteConfirm1")</p>
                <p>@T("profile.deleteConfirm2")</p>
                <p>@T("profile.deleteConfirm3")</p>
                <p>@T("profile.deleteConfirm4")</p>
            </div>
            <div class="modal-footer">
                <button class="btn-modal-cancel" @onclick="CloseDeleteConfirmModal">@T("common.cancel")</button>
                <button class="btn-modal-confirm" @onclick="ConfirmDeleteAccount">@T("profile.yes")</button>
            </div>
        </div>
    </div>
}

@if (ShowDeleteInfoModal)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h3>@T("profile.accountDeleted")</h3>
            </div>
            <div class="modal-body">
                <p>@T("profile.accountDeletedText")</p>
            </div>
            <div class="modal-footer">
                <button class="btn-modal-confirm" @onclick="DeleteAccount">@T("profile.ok")</button>
            </div>
        </div>
    </div>
}