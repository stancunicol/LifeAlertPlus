@page "/monitored/{PersonId:guid}"
@using LifeAlertPlus.Client.Components.Header
@layout MainLayout

@using LifeAlertPlus.Domain.Entities

<HeaderComponent UserName="@UserFullName" ProfilePictureUrl="@ProfilePictureUrl"/>

<div class="selected-monitored-container">
    @if (Person != null)
    {
        <div class="back-navigation">
            <button class="btn-back" @onclick="GoBack">
                <span class="back-icon">←</span> @T("selected.goBack")
            </button>
            <div class="top-actions">
                <button class="btn-action-main">📤 @T("selected.export")</button>
            </div>
        </div>

        <div class="person-profile-header">
            <div class="profile-left">
                <div class="person-avatar-huge">@GetInitials(Person.Name)</div>
                <div class="profile-info-main">
                    <h1 class="person-name-main">@Person.Name</h1>
                    <p class="person-meta">
                        @if (Person.Age > 0)
                        {
                            <span>@Person.Age @T("selected.years")</span>
                            @if (!string.IsNullOrEmpty(Person.Relationship))
                            {
                                <span> • @Person.Relationship</span>
                            }
                        }
                        else if (!string.IsNullOrEmpty(Person.Relationship))
                        {
                            <span>@Person.Relationship</span>
                        }
                        else
                        {
                            <span>@T("selected.noAgeGender")</span>
                        }
                    </p>
                    <div class="status-badge @Person.Status.ToLower()">
                        <span class="status-dot-large"></span>
                        @GetStatusText(Person.Status)
                    </div>
                </div>
            </div>
            <div class="profile-right">
                <div class="contact-info">
                    <div class="contact-item">
                        <span class="contact-icon">📍</span>
                        <span class="contact-text">@Person.Location</span>
                    </div>
                    <div class="contact-item">
                        <span class="contact-icon">⏰</span>
                        <span class="contact-text">@T("selected.lastUpdate") @Person.LastUpdate</span>
                    </div>
                    <div class="contact-item">
                        <span class="contact-icon">🆔</span>
                        <span class="contact-text">@T("selected.device") @Person.DeviceSerial</span>
                    </div>
                </div>
                @if (_showEditButton)
                {
                    <div class="action-buttons">
                        <button class="btn-action-main" @onclick="OpenEditModal">⚙️ @T("selected.editProfile")</button>
                    </div>
                }
            </div>
        </div>

        <div class="stats-overview">
            <div class="stat-card-large heart-rate @(Person.HeartRate <= 0 ? "no-data" : "")">
                <div class="stat-icon-huge">❤️</div>
                <div class="stat-content">
                    <h3>@T("selected.heartRate")</h3>
                    @if (Person.HeartRate > 0)
                    {
                        <div class="stat-value-huge">@Person.HeartRate <span class="stat-unit">bpm</span></div>
                        <p class="stat-status @GetVitalStatus(Person.HeartRate, Person.MinHeartRate, Person.MaxHeartRate)">@GetVitalStatusText(Person.HeartRate, Person.MinHeartRate, Person.MaxHeartRate)</p>
                    }
                    else
                    {
                        <div class="stat-value-huge no-data-value">@T("selected.noRecentMeasurements")</div>
                        <p class="stat-status no-data-status">@T("selected.noData")</p>
                    }
                </div>
            </div>
            <div class="stat-card-large blood-oxygen @(Person.SpO2 <= 0 ? "no-data" : "")">
                <div class="stat-icon-huge">🩸</div>
                <div class="stat-content">
                    <h3>@T("selected.bloodOxygen")</h3>
                    @if (Person.SpO2 > 0)
                    {
                        <div class="stat-value-huge">@Person.SpO2 <span class="stat-unit">%</span></div>
                        <p class="stat-status @GetSpO2Status(Person.SpO2)">@GetSpO2StatusText(Person.SpO2)</p>
                    }
                    else
                    {
                        <div class="stat-value-huge no-data-value">@T("selected.noRecentMeasurements")</div>
                        <p class="stat-status no-data-status">@T("selected.noData")</p>
                    }
                </div>
            </div>
            <div class="stat-card-large temperature @(Person.Temperature <= 0 ? "no-data" : "")">
                <div class="stat-icon-huge">🌡️</div>
                <div class="stat-content">
                    <h3>@T("selected.temperature")</h3>
                    @if (Person.Temperature > 0)
                    {
                        <div class="stat-value-huge">@Person.Temperature <span class="stat-unit">°C</span></div>
                        <p class="stat-status @GetTempStatus(Person.Temperature, Person.MinTemperature, Person.MaxTemperature)">@GetTempStatusText(Person.Temperature, Person.MinTemperature, Person.MaxTemperature)</p>
                    }
                    else
                    {
                        <div class="stat-value-huge no-data-value">@T("selected.noRecentMeasurements")</div>
                        <p class="stat-status no-data-status">@T("selected.noData")</p>
                    }
                </div>
            </div>
            <div class="stat-card-large gps @(GetGPSStatus(Person.GPS) == "disabled" ? "no-data" : "")">
                <div class="stat-icon-huge">📍</div>
                <div class="stat-content">
                    <h3>@T("selected.gpsLocation")</h3>
                    <div class="stat-value-gps">@Person.GPS</div>
                    @if (GetGPSStatus(Person.GPS) == "disabled")
                    {
                        <p class="stat-status no-data-status">@T("selected.noData")</p>
                    }
                    else
                    {
                        <p class="stat-status @GetGPSStatus(Person.GPS)">@GetGPSStatusText(Person.GPS)</p>
                    }
                </div>
            </div>
        </div>

        <div class="content-grid">
            <div class="chart-section">
                <div class="section-card">
                    <div class="section-header">
                        <h2>📊 @T("selected.vitalSigns")</h2>
                        <div class="chart-view-toggle">
                            <button class="btn-chart-view @(CurrentChartView == ChartViewMode.Daily ? "active" : "")"
                                    @onclick="() => SwitchChartView(ChartViewMode.Daily)">@T("selected.daily")</button>
                            <button class="btn-chart-view @(CurrentChartView == ChartViewMode.Weekly ? "active" : "")"
                                    @onclick="() => SwitchChartView(ChartViewMode.Weekly)">@T("selected.weekly")</button>
                        </div>
                    </div>

                    <div class="charts-wrapper">
                        <!-- Heart Rate -->
                        <div class="chart-item">
                            <div class="chart-item-title">
                                <span class="chart-color-dot hr"></span>
                                @T("selected.heartRate")
                                <span class="chart-unit-badge">bpm</span>
                            </div>
                            <svg @ref="_hrSvgRef" class="chart-svg" viewBox="0 0 800 200" preserveAspectRatio="xMidYMid meet">
                                <defs>
                                    <linearGradient id="hrGradient" x1="0" y1="0" x2="0" y2="1">
                                        <stop offset="0%" stop-color="#A5D6A7" stop-opacity="0.3" />
                                        <stop offset="100%" stop-color="#A5D6A7" stop-opacity="0.02" />
                                    </linearGradient>
                                </defs>
                                <line x1="90" y1="15" x2="785" y2="15" class="grid-line" />
                                <line x1="90" y1="51" x2="785" y2="51" class="grid-line" />
                                <line x1="90" y1="88" x2="785" y2="88" class="grid-line" />
                                <line x1="90" y1="124" x2="785" y2="124" class="grid-line" />
                                <line x1="90" y1="160" x2="785" y2="160" class="grid-line" />
                                <line x1="90" y1="15" x2="90" y2="160" class="axis-line" />
                                <line x1="90" y1="160" x2="785" y2="160" class="axis-line" />
                                <g>@((MarkupString)"<text x=\"58\" y=\"19\" class=\"chart-y-label\">120</text>")</g>
                                <g>@((MarkupString)"<text x=\"58\" y=\"55\" class=\"chart-y-label\">100</text>")</g>
                                <g>@((MarkupString)"<text x=\"58\" y=\"92\" class=\"chart-y-label\">80</text>")</g>
                                <g>@((MarkupString)"<text x=\"58\" y=\"128\" class=\"chart-y-label\">60</text>")</g>
                                <g>@((MarkupString)"<text x=\"58\" y=\"164\" class=\"chart-y-label\">40</text>")</g>
                                @if (HeartRatePoints.Count >= 1)
                                {
                                    <path d="@GenerateAreaPath(HeartRatePoints)" class="chart-area" fill="url(#hrGradient)" />
                                    <path d="@GenerateSmoothPath(HeartRatePoints)" class="chart-line hr-line" />
                                    @foreach (var pt in HeartRatePoints)
                                    {
                                        var cx = pt.X.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
                                        var cy = pt.Y.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
                                        <circle cx="@cx" cy="@cy" r="4.5" class="chart-dot hr-dot" />
                                    }
                                }
                                @foreach (var lbl in GetXAxisLabels())
                                {
                                    var lx = lbl.X.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);
                                    <line x1="@lx" y1="160" x2="@lx" y2="166" class="axis-tick" />
                                    <g>@((MarkupString)$"<text x=\"{lx}\" y=\"180\" class=\"chart-x-label\" text-anchor=\"middle\">{lbl.Label}</text>")</g>
                                }
                            </svg>
                        </div>

                        <!-- Temperature -->
                        <div class="chart-item">
                            <div class="chart-item-title">
                                <span class="chart-color-dot temp"></span>
                                @T("selected.temperature")
                                <span class="chart-unit-badge">°C</span>
                            </div>
                            <svg @ref="_tempSvgRef" class="chart-svg" viewBox="0 0 800 200" preserveAspectRatio="xMidYMid meet">
                                <defs>
                                    <linearGradient id="tempGradient" x1="0" y1="0" x2="0" y2="1">
                                        <stop offset="0%" stop-color="#FF9A6C" stop-opacity="0.3" />
                                        <stop offset="100%" stop-color="#FF9A6C" stop-opacity="0.02" />
                                    </linearGradient>
                                </defs>
                                <line x1="90" y1="15" x2="785" y2="15" class="grid-line" />
                                <line x1="90" y1="51" x2="785" y2="51" class="grid-line" />
                                <line x1="90" y1="88" x2="785" y2="88" class="grid-line" />
                                <line x1="90" y1="124" x2="785" y2="124" class="grid-line" />
                                <line x1="90" y1="160" x2="785" y2="160" class="grid-line" />
                                <line x1="90" y1="15" x2="90" y2="160" class="axis-line" />
                                <line x1="90" y1="160" x2="785" y2="160" class="axis-line" />
                                <g>@((MarkupString)"<text x=\"58\" y=\"19\" class=\"chart-y-label\">39°</text>")</g>
                                <g>@((MarkupString)"<text x=\"58\" y=\"55\" class=\"chart-y-label\">38°</text>")</g>
                                <g>@((MarkupString)"<text x=\"58\" y=\"92\" class=\"chart-y-label\">37°</text>")</g>
                                <g>@((MarkupString)"<text x=\"58\" y=\"128\" class=\"chart-y-label\">36°</text>")</g>
                                <g>@((MarkupString)"<text x=\"58\" y=\"164\" class=\"chart-y-label\">35°</text>")</g>
                                @if (TemperaturePoints.Count >= 1)
                                {
                                    <path d="@GenerateAreaPath(TemperaturePoints)" class="chart-area" fill="url(#tempGradient)" />
                                    <path d="@GenerateSmoothPath(TemperaturePoints)" class="chart-line temp-line" />
                                    @foreach (var pt in TemperaturePoints)
                                    {
                                        var cx = pt.X.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
                                        var cy = pt.Y.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
                                        <circle cx="@cx" cy="@cy" r="4.5" class="chart-dot temp-dot" />
                                    }
                                }
                                @foreach (var lbl in GetXAxisLabels())
                                {
                                    var lx = lbl.X.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);
                                    <line x1="@lx" y1="160" x2="@lx" y2="166" class="axis-tick" />
                                    <g>@((MarkupString)$"<text x=\"{lx}\" y=\"180\" class=\"chart-x-label\" text-anchor=\"middle\">{lbl.Label}</text>")</g>
                                }
                            </svg>
                        </div>
                    </div>
                </div>
            </div>

            <div class="sidebar-section">
                <div class="section-card">
                    <div class="section-header">
                        <h2>🔔 @T("selected.recentAlerts")</h2>
                    </div>
                    <div class="alerts-list">
                        @foreach (var alert in RecentAlerts)
                        {
                            <div class="alert-item @alert.Severity.ToLower()">
                                <div class="alert-icon">@GetAlertIcon(alert.Severity)</div>
                                <div class="alert-content">
                                    <h4>@alert.Title</h4>
                                    <p>@alert.Description</p>
                                    <span class="alert-time">@alert.Time</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-header">
                        <h2>📋 @T("selected.recentMeasurements")</h2>
                    </div>
                    <div class="measurements-list">
                        @foreach (var measurement in RecentMeasurements)
                        {
                            <div class="measurement-item">
                                <div class="measurement-icon">@measurement.Icon</div>
                                <div class="measurement-content">
                                    <h4>@measurement.Type</h4>
                                    <p class="measurement-value">@measurement.Value</p>
                                    <span class="measurement-time">@measurement.Time</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else if (IsLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>@T("selected.loading")</p>
        </div>
    }
    else
    {
        <div class="loading-state">
            <p>@(LoadError ?? T("selected.notFound"))</p>
            <button class="btn-back" @onclick="GoBack">
                <span class="back-icon">←</span> @T("selected.goBack")
            </button>
        </div>
    }
</div>

@if (_showEditModal)
{
    <div class="modal-overlay" @onclick="CloseEditModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>✏️ @T("selected.editProfile")</h2>
                <button class="modal-close" @onclick="CloseEditModal">✕</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(_editError))
                {
                    <div class="edit-error">@_editError</div>
                }
                <div class="form-group">
                    <label>@T("selected.firstName")</label>
                    <input type="text" @bind="_editFirstName" placeholder="@T("selected.firstName")" />
                </div>
                <div class="form-group">
                    <label>@T("selected.lastName")</label>
                    <input type="text" @bind="_editLastName" placeholder="@T("selected.lastName")" />
                </div>
                <div class="form-group">
                    <label>@T("selected.gender")</label>
                    <select @bind="_editGender">
                        <option value="">@T("selected.select")</option>
                        <option value="Male">@T("selected.male")</option>
                        <option value="Female">@T("selected.female")</option>
                        <option value="Other">@T("selected.other")</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>@T("selected.birthdate")</label>
                    <input type="date" @bind="_editBirthdate" />
                </div>
                <div class="form-group">
                    <label>@T("selected.address")</label>
                    <input type="text" @bind="_editAddress" placeholder="@T("selected.address")" />
                </div>
                <div class="form-group">
                    <label>@T("selected.deviceSerial")</label>
                    <input type="text" @bind="_editDeviceSerial" placeholder="@T("selected.deviceSerial")" />
                </div>
                <div class="form-group-separator">
                    <span>@T("selected.customRanges")</span>
                </div>
                <div class="form-group form-group-inline">
                    <div>
                        <label>@T("selected.minHr")</label>
                        <input type="number" @bind="_editMinHr" placeholder="@_userMinHr" min="20" max="300" />
                    </div>
                    <div>
                        <label>@T("selected.maxHr")</label>
                        <input type="number" @bind="_editMaxHr" placeholder="@_userMaxHr" min="20" max="300" />
                    </div>
                </div>
                <div class="form-group form-group-inline">
                    <div>
                        <label>@T("selected.minTemp")</label>
                        <input type="number" step="0.1" @bind="_editMinTemp" placeholder="@_userMinTemp" min="30" max="45" />
                    </div>
                    <div>
                        <label>@T("selected.maxTemp")</label>
                        <input type="number" step="0.1" @bind="_editMaxTemp" placeholder="@_userMaxTemp" min="30" max="45" />
                    </div>
                </div>
                <div class="form-group">
                    <label>@string.Format(T("selected.updateFrequency"), _userUpdateFrequency)</label>
                    <select @bind="_editUpdateFrequency">
                        <option value="">@string.Format(T("selected.useDefault"), _userUpdateFrequency)</option>
                        <option value="10">@T("settings.every10s")</option>
                        <option value="15">@T("settings.every15s")</option>
                        <option value="30">@T("settings.every30s")</option>
                        <option value="60">@T("settings.every1m")</option>
                        <option value="120">@T("settings.every2m")</option>
                        <option value="300">@T("settings.every5m")</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseEditModal">@T("common.cancel")</button>
                <button class="btn-save" @onclick="SaveEditAsync" disabled="@_isSaving">
                    @(_isSaving ? T("selected.saving") : "💾 " + T("common.save"))
                </button>
            </div>
        </div>
    </div>
}
