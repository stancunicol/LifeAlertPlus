                        </div>
                        <div class="threshold-preview-item">
                            <span class="threshold-label">🌡️ @T("selected.maxTemp")</span>
                            <span class="threshold-value">@_previewMaxTemp.ToString("F1") °C</span>
                        </div>
                        <div class="threshold-preview-item">
                            <span class="threshold-label">🩸 @T("selected.minSpO2")</span>
                            <span class="threshold-value">@_previewMinSpO2 %</span>
                        </div>
                        <div class="threshold-preview-item">
                            <span class="threshold-label">🩸 @T("selected.maxSpO2")</span>
                            <span class="threshold-value">@_previewMaxSpO2 %</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseConditionsModal">@T("common.cancel")</button>
                <button class="btn-save" @onclick="SaveConditionsAsync" disabled="@_isSavingConditions">
                    @(_isSavingConditions ? T("selected.saving") : "💾 " + T("common.save"))
                </button>
            </div>
        </div>
    </div>
}

@if (_showInviteModal)
{
    <div class="modal-overlay" @onclick="CloseInviteModal">
        <div class="modal-content email-modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>✉️ @T("invite.sendTitle")</h2>
                <button class="modal-close" @onclick="CloseInviteModal">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>@T("invite.doctorEmail")</label>
                    <input type="email" @bind="_inviteDoctorEmail" placeholder="@T("invite.doctorEmailPlaceholder")" />
                </div>
                @if (!string.IsNullOrEmpty(_inviteStatusMessage))
                {
                    <p class="@(_inviteSuccess ? "email-success" : "email-error")">@_inviteStatusMessage</p>
                }
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseInviteModal">@T("common.cancel")</button>
                <button class="btn-save" @onclick="SendInvitationToDoctorAsync" disabled="@(_isSendingInvitation || string.IsNullOrWhiteSpace(_inviteDoctorEmail))">
                    @(_isSendingInvitation ? T("invite.sendingInvitation") : "✉️ " + T("invite.sendInvitation"))
                </button>
            </div>
        </div>
    </div>
}

@if (_showWifiModal)
{
    <div class="modal-overlay" @onclick="CloseWifiModal">
        <div class="modal-content wifi-modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>📶 @T("wifi.modalTitle")</h2>
                <button class="modal-close" @onclick="CloseWifiModal">✕</button>
            </div>
            <div class="modal-body">
                <p class="wifi-hint">@T("wifi.hint")</p>

                @if (_isWifiLoading)
                {
                    <p>@T("wifi.loading")</p>
                }
                else
                {
                    @if (_wifiNetworks.Count == 0)
                    {
                        <p class="wifi-empty">@T("wifi.empty")</p>
                    }
                    else
                    {
                        <ul class="wifi-list">
                            @foreach (var net in _wifiNetworks)
                            {
                                <li class="wifi-item">
                                    <span class="wifi-ssid">📡 @net.Ssid</span>
                                    <button class="wifi-delete" @onclick="() => DeleteWifiNetworkAsync(net.Id)" title="@T("wifi.delete")">🗑️</button>
                                </li>
                            }
                        </ul>
                    }

                    @if (_wifiNetworks.Count < MaxWifiNetworks)
                    {
                        <div class="wifi-add">
                            <h3>@T("wifi.addTitle")</h3>
                            <div class="form-group">
                                <label>@T("wifi.ssid")</label>
                                <input type="text" maxlength="32" @bind="_newWifiSsid" placeholder="@T("wifi.ssidPlaceholder")" />
                            </div>
                            <div class="form-group">
                                <label>@T("wifi.password")</label>
                                <input type="password" maxlength="64" @bind="_newWifiPassword" placeholder="@T("wifi.passwordPlaceholder")" />
                            </div>
                            <button class="btn-save" @onclick="AddWifiNetworkAsync" disabled="@(_isAddingWifi || string.IsNullOrWhiteSpace(_newWifiSsid))">
                                @(_isAddingWifi ? T("wifi.adding") : "➕ " + T("wifi.add"))
                            </button>
                        </div>
                    }
                    else
                    {
                        <p class="wifi-limit">@T("wifi.limitReached")</p>
                    }

                    @if (!string.IsNullOrEmpty(_wifiStatusMessage))
                    {
                        <p class="@(_wifiSuccess ? "email-success" : "email-error")">@_wifiStatusMessage</p>
                    }
                }
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseWifiModal">@T("common.close")</button>
            </div>
        </div>
    </div>
}

@if (_showDoctorNotesModal)
{
    <div class="modal-overlay" @onclick="CloseDoctorNotesModal">
        <div class="modal-content email-modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>📝 @T("doctorNotes.addNote")</h2>
                <button class="modal-close" @onclick="CloseDoctorNotesModal">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>@T("doctorNotes.noteContent")</label>
                    <textarea @bind="_doctorNoteContent" placeholder="@T("doctorNotes.placeholder")" rows="6"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseDoctorNotesModal">@T("common.cancel")</button>
                <button class="btn-save" @onclick="SaveDoctorNoteAsync" disabled="@(_isSavingDoctorNote || string.IsNullOrWhiteSpace(_doctorNoteContent))">
                    @(_isSavingDoctorNote ? T("doctorNotes.saving") : "💾 " + T("common.save"))
                </button>
            </div>
        </div>
    </div>
}

@if (_showDeleteModal)
{
    <div class="modal-overlay" @onclick="CloseDeleteModal">
        <div class="modal-content" @onclick:stopPropagation="true" style="max-width:480px;">
            <div class="modal-header">
                <h2>🗑️ Șterge persoana monitorizată</h2>
                <button class="modal-close" @onclick="CloseDeleteModal">✕</button>
            </div>
            <div class="modal-body">
                <p>Ești sigur că vrei să ștergi <strong>@Person?.Name</strong>?</p>
                <p style="margin-top:8px;color:var(--color-text-secondary);font-size:0.9rem;">
                    Dacă ești singurul utilizator care monitorizează această persoană, aceasta va fi marcată pentru ștergere
                    și eliminată definitiv după 7 zile. Dacă există alți utilizatori, vei fi doar deconectat de la ea.
                </p>
                @if (_deleteError != null)
                {
                    <p class="form-error" style="margin-top:8px;">@_deleteError</p>
                }
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseDeleteModal" disabled="@_isDeleting">Anulează</button>
                <button class="btn-danger" @onclick="ExecuteDeleteAsync" disabled="@_isDeleting">
                    @(_isDeleting ? "Se șterge..." : "🗑️ Confirmă ștergerea")
                </button>
            </div>
        </div>
    </div>
}
