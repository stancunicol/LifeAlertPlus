@page "/monitored/{PersonId:guid}"
@page "/doctor/patient/{PersonId:guid}"
@using LifeAlertPlus.Client.Components.Header
@layout MainLayout

@using LifeAlertPlus.Domain.Entities

<HeaderComponent UserName="@UserFullName" ProfilePictureUrl="@ProfilePictureUrl"/>

<div class="selected-monitored-container">
    @if (Person != null)
    {
        <div class="back-navigation">
            <button class="btn-back" @onclick="GoBack">
                <span class="back-icon">←</span> @T("selected.goBack")
            </button>
            <div class="top-actions">
                <button class="btn-action-main" @onclick="ExportPdfAsync">📤 @T("selected.export")</button>
                @if (_showEditButton)
                {
                    <button class="btn-action-main" @onclick="OpenInviteModal">✉️ @T("invite.sendToDoctor")</button>
                }
            </div>
        </div>

        <div class="person-profile-header">
            <div class="profile-left">
                <div class="person-avatar-huge">@GetInitials(Person.Name)</div>
                <div class="profile-info-main">
                    <h1 class="person-name-main">@Person.Name</h1>
                    <p class="person-meta">
                        @if (Person.Age > 0)
                        {
                            <span>@Person.Age @T("selected.years")</span>
                            @if (!string.IsNullOrEmpty(Person.Relationship))
                            {
                                <span> • @Person.Relationship</span>
                            }
                        }
                        else if (!string.IsNullOrEmpty(Person.Relationship))
                        {
                            <span>@Person.Relationship</span>
                        }
                        else
                        {
                            <span>@T("selected.noAgeGender")</span>
                        }
                    </p>
                    <div class="status-badge @Person.Status.ToLower()">
                        <span class="status-dot-large"></span>
                        @GetStatusText(Person.Status)
                    </div>
                </div>
            </div>
            <div class="profile-right">
                <div class="contact-info">
                    <div class="contact-item">
                        <span class="contact-icon">📍</span>
                        <span class="contact-text">@Person.Location</span>
                    </div>
                    <div class="contact-item">
                        <span class="contact-icon">⏰</span>
                        <span class="contact-text">@T("selected.lastUpdate") @Person.LastUpdate</span>
                    </div>
                    <div class="contact-item">
                        <span class="contact-icon">🆔</span>
                        <span class="contact-text">@T("selected.device") @Person.DeviceSerial</span>
                    </div>
                </div>
                @if (_showEditButton)
                {
                    <div class="action-buttons">
                        <button class="btn-action-main" @onclick="OpenEditModal">⚙️ @T("selected.editProfile")</button>
                    </div>
                }
            </div>
        </div>

        <div class="stats-overview">
            <div class="stat-card-large heart-rate @(Person.HeartRate <= 0 ? "no-data" : "")">
                <div class="stat-icon-huge">❤️</div>
                <div class="stat-content">
                    <h3>@T("selected.heartRate")</h3>
                    @if (Person.HeartRate > 0)
                    {
                        <div class="stat-value-huge">@Person.HeartRate <span class="stat-unit">bpm</span></div>
                        <p class="stat-status @GetVitalStatus(Person.HeartRate, Person.MinHeartRate, Person.MaxHeartRate)">@GetVitalStatusText(Person.HeartRate, Person.MinHeartRate, Person.MaxHeartRate)</p>
                    }
                    else
                    {
                        <div class="stat-value-huge no-data-value">@T("selected.noRecentMeasurements")</div>
                        <p class="stat-status no-data-status">@T("selected.noData")</p>
                    }
                </div>
            </div>
            <div class="stat-card-large blood-oxygen @(Person.SpO2 <= 0 ? "no-data" : "")">
                <div class="stat-icon-huge">🩸</div>
                <div class="stat-content">
                    <h3>@T("selected.bloodOxygen")</h3>
                    @if (Person.SpO2 > 0)
                    {
                        <div class="stat-value-huge">@Person.SpO2 <span class="stat-unit">%</span></div>
                        <p class="stat-status @GetSpO2Status(Person.SpO2, Person.MinSpO2)">@GetSpO2StatusText(Person.SpO2, Person.MinSpO2)</p>
                    }
                    else
                    {
                        <div class="stat-value-huge no-data-value">@T("selected.noRecentMeasurements")</div>
                        <p class="stat-status no-data-status">@T("selected.noData")</p>
                    }
                </div>
            </div>
            <div class="stat-card-large temperature @(Person.Temperature <= 0 ? "no-data" : "")">
                <div class="stat-icon-huge">🌡️</div>
                <div class="stat-content">
                    <h3>@T("selected.temperature")</h3>
                    @if (Person.Temperature > 0)
                    {
                        <div class="stat-value-huge">@Person.Temperature <span class="stat-unit">°C</span></div>
                        <p class="stat-status @GetTempStatus(Person.Temperature, Person.MinTemperature, Person.MaxTemperature)">@GetTempStatusText(Person.Temperature, Person.MinTemperature, Person.MaxTemperature)</p>
                    }
                    else
                    {
                        <div class="stat-value-huge no-data-value">@T("selected.noRecentMeasurements")</div>
                        <p class="stat-status no-data-status">@T("selected.noData")</p>
                    }
                </div>
            </div>
            <div class="stat-card-large gps @(GetGPSStatus(Person.GPS) == "disabled" ? "no-data" : "")">
                <div class="stat-icon-huge">📍</div>
                <div class="stat-content">
                    <h3>@T("selected.gpsLocation")</h3>
                    <div class="stat-value-gps">@Person.GPS</div>
                    @if (GetGPSStatus(Person.GPS) == "disabled")
                    {
                        <p class="stat-status no-data-status">@T("selected.noData")</p>
                    }
                    else
                    {
                        <p class="stat-status @GetGPSStatus(Person.GPS)">@GetGPSStatusText(Person.GPS)</p>
                    }
                </div>
            </div>
        </div>

        <div class="ai-prediction-section section-card">
            <div class="section-header">
                <h2>🤖 @T("selected.aiPrediction")</h2>
            </div>
            @if (AIPredictionLoading)
            {
                <div class="ai-loading">
                    <div class="ai-spinner"></div>
                    <span>@T("selected.aiAnalyzing")</span>
                </div>
            }
            else if (AIPrediction != null)
            {
                <div class="ai-prediction-content">
                    <div class="ai-main-result">
                        <div class="ai-risk-badge @AIPrediction.RiskLevel.ToLower()">
                            <span class="ai-risk-icon">@GetAIRiskIcon(AIPrediction.RiskLevel)</span>
                            <div class="ai-risk-info">
                                <span class="ai-risk-label">@T("selected.aiRiskLevel")</span>
                                <span class="ai-risk-value">@GetAIRiskText(AIPrediction.RiskLevel)</span>
                            </div>
                        </div>
                        <div class="ai-confidence">
                            <span class="ai-confidence-label">@T("selected.aiConfidence")</span>
                            <div class="ai-confidence-bar">
                                <div class="ai-confidence-fill @AIPrediction.RiskLevel.ToLower()" style="width: @((AIPrediction.Confidence * 100).ToString("F0", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                            </div>
                            <span class="ai-confidence-value">@((AIPrediction.Confidence * 100).ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%</span>
                        </div>
                        <div class="ai-state">
                            <span class="ai-state-label">@T("selected.aiDetectedState")</span>
                            <span class="ai-state-value">@AIPrediction.Prediction</span>
                        </div>
                        <div class="ai-health-score">
                            <span class="ai-health-label">@T("selected.aiHealthScore")</span>
                            <span class="ai-health-value @(AIPrediction.HealthScore >= 80 ? "critical" : AIPrediction.HealthScore >= 40 ? "alert" : "normal")">@(100 - AIPrediction.HealthScore) / 100</span>
                        </div>
                    </div>
                    <div class="ai-details">
                        <p>@AIPrediction.Details</p>
                    </div>
                    @if (AIPrediction.AllProbabilities != null && AIPrediction.AllProbabilities.Count > 1)
                    {
                        <button class="ai-prob-toggle" @onclick="() => _showProbabilities = !_showProbabilities">
                            @T("selected.aiProbabilities")
                            <span class="ai-prob-toggle-icon @(_showProbabilities ? "expanded" : "")">▾</span>
                        </button>
                        @if (_showProbabilities)
                        {
                            <div class="ai-probabilities">
                                <div class="ai-prob-bars">
                                    @foreach (var prob in AIPrediction.AllProbabilities.OrderByDescending(p => p.Value))
                                    {
                                        <div class="ai-prob-item">
                                            <span class="ai-prob-label">@prob.Key</span>
                                            <div class="ai-prob-bar">
                                                <div class="ai-prob-fill" style="width: @((prob.Value * 100).ToString("F0", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                                            </div>
                                            <span class="ai-prob-value">@((prob.Value * 100).ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            }
            else
            {
                <div class="ai-unavailable">
                    <span class="ai-unavailable-icon">🤖</span>
                    <p>@T("selected.aiUnavailable")</p>
                </div>
            }
        </div>

        <div class="trend-prediction-section section-card">
            <div class="section-header">
                <h2>📈 @T("selected.trendTitle")</h2>
            </div>
            @if (TrendPredictionsLoading)
            {
                <div class="ai-loading">
                    <div class="ai-spinner"></div>
                    <span>@T("selected.aiAnalyzing")</span>
                </div>
            }
            else if (TrendPredictions == null || TrendPredictions.BufferDataPoints < 3)
            {
                <div class="trend-no-data">
                    <span class="trend-no-data-icon">📊</span>
                    <p>@T("selected.trendNoData")</p>
                </div>
            }
            else if (!TrendPredictions.Predictions.Any())
            {
                <div class="trend-stable">
                    <span class="trend-stable-icon">✅</span>
                    <p>@T("selected.trendNone")</p>
                    <span class="trend-buffer-info">@TrendPredictions.BufferDataPoints @T("selected.trendDataPoints") / @((int)TrendPredictions.BufferDurationSeconds)s</span>
                </div>
            }
            else
            {
                <div class="trend-predictions-list">
                    @foreach (var pred in TrendPredictions.Predictions)
                    {
                        <div class="trend-prediction-card @pred.Severity">
                            <div class="trend-card-header">
                                <span class="trend-metric-icon">@GetTrendMetricIcon(pred.Metric)</span>
                                <span class="trend-label">@GetTrendLabel(pred)</span>
                                <span class="trend-direction-badge @pred.Direction">
                                    @(pred.Direction == "rising" ? "↑" : "↓") @T(pred.Direction == "rising" ? "selected.trendRising" : "selected.trendFalling")
                                </span>
                            </div>
                            <div class="trend-card-body">
                                <div class="trend-stat">
                                    <span class="trend-stat-label">@T("selected.trendRate")</span>
                                    <span class="trend-stat-value">@FormatTrendRate(pred.Metric, pred.ChangeRatePerMinute)</span>
                                </div>
                                <div class="trend-stat">
                                    <span class="trend-stat-label">@T("selected.trendThreshold")</span>
                                    <span class="trend-stat-value">@GetTrendThreshold(pred)</span>
                                </div>
                                @if (pred.SecondsToThreshold.HasValue)
                                {
                                    <div class="trend-stat trend-time">
                                        <span class="trend-stat-label">@T("selected.trendTimeToThreshold")</span>
                                        <span class="trend-stat-value trend-time-value @pred.Severity">
                                            @FormatSecondsToThreshold(pred.SecondsToThreshold.Value, T("selected.trendMinutes"), T("selected.trendSeconds"))
                                        </span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
                <div class="trend-buffer-footer">
                    @TrendPredictions.BufferDataPoints @T("selected.trendDataPoints") / @((int)TrendPredictions.BufferDurationSeconds)s
                </div>
            }
        </div>

        <div class="activity-profile-section section-card">
            <div class="section-header">
                <h2>🕐 @T("selected.activityProfile")</h2>
                @if (ActivityProfile?.LastUpdated != null)
                {
                    <span class="profile-updated-at">@T("selected.activityProfileUpdated") @ActivityProfile.LastUpdated.Value.ToLocalTime().ToString("dd MMM yyyy")</span>
                }
            </div>
            @if (ActivityProfileLoading)
            {
                <div class="ai-loading">
                    <div class="ai-spinner"></div>
                    <span>@T("selected.activityProfileLoading")</span>
                </div>
            }
            else if (ActivityProfile == null || !ActivityProfile.HourlyProfiles.Any())
            {
                <div class="trend-no-data">
                    <span class="trend-no-data-icon">📊</span>
                    <p>@T("selected.activityProfileNoData")</p>
                </div>
            }
            else
            {
                <div class="activity-timeline">
                    @for (int h = 0; h < 24; h++)
                    {
                        var hour = h;
                        var slot = ActivityProfile.HourlyProfiles.FirstOrDefault(p => p.HourOfDay == hour);
                        var slotClass = slot != null ? GetActivitySlotClass(slot.Label) : "slot-nodata";
                        var tooltip = GetSlotTooltip(slot, hour);
                        <div class="activity-slot @slotClass" title="@tooltip">
                            <span class="activity-slot-hour">@hour.ToString("D2")</span>
                            @if (slot != null && slot.DataPoints >= 10)
                            {
                                <span class="activity-slot-pulse">@slot.AveragePulse.ToString("F0")</span>
                            }
                        </div>
                    }
                </div>
                <div class="activity-legend">
                    <div class="legend-item"><span class="legend-dot slot-sleep"></span>@T("selected.activitySleep")</div>
                    <div class="legend-item"><span class="legend-dot slot-active"></span>@T("selected.activityActive")</div>
                    <div class="legend-item"><span class="legend-dot slot-moderate"></span>@T("selected.activityModerate")</div>
                    <div class="legend-item"><span class="legend-dot slot-rest"></span>@T("selected.activityRest")</div>
                    <div class="legend-item"><span class="legend-dot slot-nodata"></span>@T("selected.activityNoData")</div>
                </div>
            }
        </div>

        <div class="conditions-section section-card">
            <div class="section-header">
                <h2>🩺 @T("conditions.title")</h2>
                @if (_showEditButton)
                {
                    <button class="btn-action-secondary" @onclick="OpenConditionsModal">✏️ @T("conditions.edit")</button>
                }
            </div>

            @if (_conditionsLoading)
            {
                <div class="conditions-loading">
                    <div class="ai-spinner"></div>
                </div>
            }
            else if (_conditions.Count == 0)
            {
                <div class="conditions-empty">
                    <span>@T("conditions.none")</span>
                    @if (_showEditButton)
                    {
                        <button class="btn-add-condition" @onclick="OpenConditionsModal">+ @T("conditions.add")</button>
                    }
                </div>
            }
            else
            {
                <div class="conditions-groups">
                    @foreach (var group in ConditionGroups)
                    {
                        var active = group.Keys.Where(k => _conditions.Contains(k)).ToList();
                        @if (active.Any())
                        {
                            <div class="condition-group">
                                <span class="condition-group-label">@group.Icon @T(group.CategoryKey)</span>
                                <div class="condition-chips">
                                    @foreach (var key in active)
                                    {
                                        <span class="condition-chip @group.ColorClass">@T("conditions." + key)</span>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            }
        </div>

        <div class="map-section section-card">
            <div class="section-header">
                <h2>📍 @T("selected.currentLocation")</h2>
            </div>
            <div class="map-wrapper">
                @if (GetGPSStatus(Person.GPS) == "disabled")
                {
                    <div class="map-no-data">
                        <span class="map-no-data-icon">📍</span>
                        <p>@T("selected.noCoordinates")</p>
                    </div>
                }
                else
                {
                    <div class="map-container" @ref="_mapRef"></div>
                }
            </div>
        </div>

        <div class="content-grid">
            <div class="chart-section">
                <div class="section-card">
                    <div class="section-header">
                        <h2>📊 @T("selected.vitalSigns")</h2>
                        <div class="chart-view-toggle">
                            <button class="btn-chart-view @(CurrentChartView == ChartViewMode.Daily ? "active" : "")"
                                    @onclick="() => SwitchChartView(ChartViewMode.Daily)">@T("selected.daily")</button>
                            <button class="btn-chart-view @(CurrentChartView == ChartViewMode.Weekly ? "active" : "")"
                                    @onclick="() => SwitchChartView(ChartViewMode.Weekly)">@T("selected.weekly")</button>
                        </div>
                    </div>

                    <div class="charts-wrapper">
                        <div class="chart-week-nav">
                            @if (CurrentChartView == ChartViewMode.Weekly)
                            {
                                <button class="btn-week-arrow @(_hasPrevWeekData ? "" : "disabled")"
                                        @onclick="GoToPreviousWeek" disabled="@(!_hasPrevWeekData)">
                                    <span>◀</span>
                                </button>
                                <span class="chart-week-label">@_chartWeekLabel</span>
                                <button class="btn-week-arrow @(_weekOffset >= 0 ? "disabled" : "")"
                                        @onclick="GoToNextWeek" disabled="@(_weekOffset >= 0)">
                                    <span>▶</span>
                                </button>
                            }
                            else
                            {
                                <button class="btn-week-arrow @(_hasPrevDayData ? "" : "disabled")"
                                        @onclick="GoToPreviousDay" disabled="@(!_hasPrevDayData)">
                                    <span>◀</span>
                                </button>
                                <span class="chart-week-label">@_chartDayLabel</span>
                                <button class="btn-week-arrow @(_dayOffset >= 0 ? "disabled" : "")"
                                        @onclick="GoToNextDay" disabled="@(_dayOffset >= 0)">
                                    <span>▶</span>
                                </button>
                            }
                        </div>
                        <div class="charts-scroll-outer">
                        <!-- Heart Rate -->
                        <div class="chart-item">
                            <div class="chart-item-title">
                                <span class="chart-color-dot hr"></span>
                                @T("selected.heartRate")
                                <span class="chart-unit-badge">bpm</span>
                            </div>
                            <svg @ref="_hrSvgRef" class="chart-svg" viewBox="0 0 800 200" preserveAspectRatio="xMidYMid meet">
                                <defs>
                                    <linearGradient id="hrGradient" x1="0" y1="0" x2="0" y2="1">
                                        <stop offset="0%" stop-color="#66BB6A" stop-opacity="0.35" />
                                        <stop offset="100%" stop-color="#66BB6A" stop-opacity="0.03" />
                                    </linearGradient>
                                </defs>
                                <rect x="90" y="15" width="695" height="145" rx="3" class="chart-bg" />
                                <line x1="90" y1="15" x2="785" y2="15" class="grid-line" />
                                <line x1="90" y1="51" x2="785" y2="51" class="grid-line" />
                                <line x1="90" y1="88" x2="785" y2="88" class="grid-line" />
                                <line x1="90" y1="124" x2="785" y2="124" class="grid-line" />
                                <line x1="90" y1="160" x2="785" y2="160" class="grid-line" />
                                <line x1="90" y1="15" x2="90" y2="160" class="axis-line" />
                                <line x1="90" y1="160" x2="785" y2="160" class="axis-line" />
                                <g>@((MarkupString)"<text x=\"58\" y=\"19\" class=\"chart-y-label\">140</text>")</g>
                                <g>@((MarkupString)"<text x=\"58\" y=\"55\" class=\"chart-y-label\">115</text>")</g>
                                <g>@((MarkupString)"<text x=\"58\" y=\"92\" class=\"chart-y-label\">90</text>")</g>
                                <g>@((MarkupString)"<text x=\"58\" y=\"128\" class=\"chart-y-label\">65</text>")</g>
                                <g>@((MarkupString)"<text x=\"58\" y=\"164\" class=\"chart-y-label\">40</text>")</g>
                                @if (HeartRatePoints.Count >= 1)
                                {
                                    <path d="@GenerateAreaPath(HeartRatePoints)" class="chart-area" fill="url(#hrGradient)" />
                                    <path d="@GenerateSmoothPath(HeartRatePoints)" class="chart-line hr-line" />
                                    @foreach (var pt in HeartRatePoints)
                                    {
                                        var cx = pt.X.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
                                        var cy = pt.Y.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
                                        <circle cx="@cx" cy="@cy" r="4.5" class="chart-dot hr-dot" />
                                    }
                                }
                                @foreach (var lbl in GetXAxisLabels())
                                {
                                    var lx = lbl.X.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);
                                    <line x1="@lx" y1="160" x2="@lx" y2="166" class="axis-tick" />
                                    <g>@((MarkupString)$"<text x=\"{lx}\" y=\"180\" class=\"chart-x-label\" text-anchor=\"middle\">{lbl.Label}</text>")</g>
                                }
                            </svg>
                        </div>

                        <!-- Temperature -->
                        <div class="chart-item">
                            <div class="chart-item-title">
                                <span class="chart-color-dot temp"></span>
                                @T("selected.temperature")
                                <span class="chart-unit-badge">°C</span>
                            </div>
                            <svg @ref="_tempSvgRef" class="chart-svg" viewBox="0 0 800 200" preserveAspectRatio="xMidYMid meet">
                                <defs>
                                    <linearGradient id="tempGradient" x1="0" y1="0" x2="0" y2="1">
                                        <stop offset="0%" stop-color="#FF7043" stop-opacity="0.35" />
                                        <stop offset="100%" stop-color="#FF7043" stop-opacity="0.03" />
                                    </linearGradient>
                                </defs>
                                <rect x="90" y="15" width="695" height="145" rx="3" class="chart-bg" />
                                <line x1="90" y1="15" x2="785" y2="15" class="grid-line" />
                                <line x1="90" y1="51" x2="785" y2="51" class="grid-line" />
                                <line x1="90" y1="88" x2="785" y2="88" class="grid-line" />
                                <line x1="90" y1="124" x2="785" y2="124" class="grid-line" />
                                <line x1="90" y1="160" x2="785" y2="160" class="grid-line" />
                                <line x1="90" y1="15" x2="90" y2="160" class="axis-line" />
                                <line x1="90" y1="160" x2="785" y2="160" class="axis-line" />
                                <g>@((MarkupString)"<text x=\"58\" y=\"19\" class=\"chart-y-label\">39°</text>")</g>
                                <g>@((MarkupString)"<text x=\"58\" y=\"55\" class=\"chart-y-label\">38°</text>")</g>
                                <g>@((MarkupString)"<text x=\"58\" y=\"92\" class=\"chart-y-label\">37°</text>")</g>
                                <g>@((MarkupString)"<text x=\"58\" y=\"128\" class=\"chart-y-label\">36°</text>")</g>
                                <g>@((MarkupString)"<text x=\"58\" y=\"164\" class=\"chart-y-label\">35°</text>")</g>
                                @if (TemperaturePoints.Count >= 1)
                                {
                                    <path d="@GenerateAreaPath(TemperaturePoints)" class="chart-area" fill="url(#tempGradient)" />
                                    <path d="@GenerateSmoothPath(TemperaturePoints)" class="chart-line temp-line" />
                                    @foreach (var pt in TemperaturePoints)
                                    {
                                        var cx = pt.X.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
                                        var cy = pt.Y.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
                                        <circle cx="@cx" cy="@cy" r="4.5" class="chart-dot temp-dot" />
                                    }
                                }
                                @foreach (var lbl in GetXAxisLabels())
                                {
                                    var lx = lbl.X.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);
                                    <line x1="@lx" y1="160" x2="@lx" y2="166" class="axis-tick" />
                                    <g>@((MarkupString)$"<text x=\"{lx}\" y=\"180\" class=\"chart-x-label\" text-anchor=\"middle\">{lbl.Label}</text>")</g>
                                }
                            </svg>
                        </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="sidebar-section">
                <div class="section-card">
                    <div class="section-header">
                        <h2>🔔 @T("selected.recentAlerts")</h2>
                        <a class="view-all-link" href="/monitored/@PersonId/alerts">→</a>
                    </div>
                    <div class="alerts-list">
                        @foreach (var alert in RecentAlerts)
                        {
                            <div class="alert-item @alert.Severity.ToLower()">
                                <div class="alert-icon">@GetAlertIcon(alert.Severity)</div>
                                <div class="alert-content">
                                    <h4>@alert.Title</h4>
                                    <p>@alert.Description</p>
                                    <span class="alert-time">@alert.Time</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-header">
                        <h2>📋 @T("selected.recentMeasurements")</h2>
                        <a class="view-all-link" href="/monitored/@PersonId/measurements">→</a>
                    </div>
                    <div class="measurements-list">
                        @foreach (var measurement in RecentMeasurements)
                        {
                            <div class="measurement-item">
                                <div class="measurement-icon">@measurement.Icon</div>
                                <div class="measurement-content">
                                    <h4>@measurement.Type</h4>
                                    <p class="measurement-value">@measurement.Value</p>
                                    <span class="measurement-time">@measurement.Time</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else if (IsLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>@T("selected.loading")</p>
        </div>
    }
    else
    {
        <div class="loading-state">
            <p>@(LoadError ?? T("selected.notFound"))</p>
            <button class="btn-back" @onclick="GoBack">
                <span class="back-icon">←</span> @T("selected.goBack")
            </button>
        </div>
    }
</div>

@if (_showEditModal)
{
    <div class="modal-overlay" @onclick="CloseEditModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>✏️ @T("selected.editProfile")</h2>
                <button class="modal-close" @onclick="CloseEditModal">✕</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(_editError))
                {
                    <div class="edit-error">@_editError</div>
                }
                <div class="form-group">
                    <label>@T("selected.firstName")</label>
                    <input type="text" @bind="_editFirstName" placeholder="@T("selected.firstName")" />
                </div>
                <div class="form-group">
                    <label>@T("selected.lastName")</label>
                    <input type="text" @bind="_editLastName" placeholder="@T("selected.lastName")" />
                </div>
                <div class="form-group">
                    <label>@T("selected.gender")</label>
                    <select @bind="_editGender">
                        <option value="">@T("selected.select")</option>
                        <option value="Male">@T("selected.male")</option>
                        <option value="Female">@T("selected.female")</option>
                        <option value="Other">@T("selected.other")</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>@T("selected.birthdate")</label>
                    <input type="date" @bind="_editBirthdate" />
                </div>
                <div class="form-group">
                    <label>@T("selected.address")</label>
                    <input type="text" @bind="_editAddress" placeholder="@T("selected.address")" />
                </div>
                <div class="form-group">
                    <label>@T("selected.deviceSerial")</label>
                    <input type="text" @bind="_editDeviceSerial" placeholder="@T("selected.deviceSerial")" />
                </div>
                <div class="form-group-separator">
                    <span>@T("selected.customRanges")</span>
                </div>
                <div class="form-group form-group-inline">
                    <div>
                        <label>@T("selected.minHr")</label>
                        <input type="number" @bind="_editMinHr" placeholder="@_userMinHr" min="20" max="300" />
                    </div>
                    <div>
                        <label>@T("selected.maxHr")</label>
                        <input type="number" @bind="_editMaxHr" placeholder="@_userMaxHr" min="20" max="300" />
                    </div>
                </div>
                <div class="form-group form-group-inline">
                    <div>
                        <label>@T("selected.minTemp")</label>
                        <input type="number" step="0.1" @bind="_editMinTemp" placeholder="@_userMinTemp" min="30" max="45" />
                    </div>
                    <div>
                        <label>@T("selected.maxTemp")</label>
                        <input type="number" step="0.1" @bind="_editMaxTemp" placeholder="@_userMaxTemp" min="30" max="45" />
                    </div>
                </div>
                <div class="form-group form-group-inline">
                    <div>
                        <label>@T("selected.minSpO2") (%)</label>
                        <input type="number" @bind="_editMinSpO2" placeholder="95" min="70" max="100" />
                    </div>
                    <div>
                        <label>@T("selected.maxSpO2") (%)</label>
                        <input type="number" @bind="_editMaxSpO2" placeholder="100" min="70" max="100" />
                    </div>
                </div>
                <div class="form-group">
                    <label>@string.Format(T("selected.updateFrequency"), _userUpdateFrequency)</label>
                    <select @bind="_editUpdateFrequency">
                        <option value="">@string.Format(T("selected.useDefault"), _userUpdateFrequency)</option>
                        <option value="10">@T("settings.every10s")</option>
                        <option value="15">@T("settings.every15s")</option>
                        <option value="30">@T("settings.every30s")</option>
                        <option value="60">@T("settings.every1m")</option>
                        <option value="120">@T("settings.every2m")</option>
                        <option value="300">@T("settings.every5m")</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseEditModal">@T("common.cancel")</button>
                <button class="btn-save" @onclick="SaveEditAsync" disabled="@_isSaving">
                    @(_isSaving ? T("selected.saving") : "💾 " + T("common.save"))
                </button>
            </div>
        </div>
    </div>
}

@if (_showExportModal)
{
    <div class="modal-overlay" @onclick="CloseExportModal">
        <div class="modal-content export-modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>📤 @T("export.selectPeriod")</h2>
                <button class="modal-close" @onclick="CloseExportModal">✕</button>
            </div>
            <div class="modal-body">
                <div class="export-date-range">
                    <div class="form-group">
                        <label>@T("export.startDate")</label>
                        <input type="date" @bind="_exportStartDate" min="@_exportMinDate?.ToString("yyyy-MM-dd")" max="@_exportEndDate?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="form-group">
                        <label>@T("export.endDate")</label>
                        <input type="date" @bind="_exportEndDate" min="@_exportStartDate?.ToString("yyyy-MM-dd")" max="@_exportMaxDate?.ToString("yyyy-MM-dd")" />
                    </div>
                </div>
                @if (_exportMeasurementCount.HasValue)
                {
                    <p class="export-info">@string.Format(T("export.measurementsInPeriod"), _exportMeasurementCount.Value)</p>
                    <p class="export-info">@string.Format(T("export.daysWithData"), _exportDistinctDays)</p>
                    @if (_exportDistinctDays < 7)
                    {
                        <p class="export-warning">@T("export.minDaysWarning")</p>
                    }
                }
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseExportModal">@T("common.cancel")</button>
                <button class="btn-save" @onclick="GenerateExportPdfAsync" disabled="@(_isExporting || _exportDistinctDays < 7)">
                    @(_isExporting ? T("export.generating") : "📄 " + T("export.generate"))
                </button>
            </div>
        </div>
    </div>
}

@if (_showEmailModal)
{
    <div class="modal-overlay" @onclick="CloseEmailModal">
        <div class="modal-content email-modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>📧 @T("email.sendToDoctor")</h2>
                <button class="modal-close" @onclick="CloseEmailModal">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>@T("email.doctorEmail")</label>
                    <input type="email" @bind="_doctorEmail" placeholder="@T("email.placeholder")" />
                </div>
                @if (!string.IsNullOrEmpty(_emailStatusMessage))
                {
                    <p class="@(_emailSuccess ? "email-success" : "email-error")">@_emailStatusMessage</p>
                }
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseEmailModal">@T("common.cancel")</button>
                <button class="btn-save" @onclick="SendEmailToDoctorAsync" disabled="@(_isSendingEmail || string.IsNullOrWhiteSpace(_doctorEmail))">
                    @(_isSendingEmail ? T("email.sending") : "📧 " + T("email.send"))
                </button>
            </div>
        </div>
