@page "/monitored/{PersonId:guid}"
@page "/doctor/patient/{PersonId:guid}"
@using LifeAlertPlus.Client.Components.Header
@layout MainLayout

@using LifeAlertPlus.Domain.Entities

<HeaderComponent UserName="@UserFullName" ProfilePictureUrl="@ProfilePictureUrl"/>

<div class="selected-monitored-container">
    @if (Person != null)
    {
        <div class="back-navigation">
            <button class="btn-back" @onclick="GoBack">
                <span class="back-icon">←</span> @T("selected.goBack")
            </button>
            <div class="top-actions">
                <button class="btn-action-main" @onclick="ExportPdfAsync">📤 @T("selected.export")</button>
                @if (_showEditButton && !(Person?.IsReadOnly ?? false))
                {
                    <button class="btn-action-main" @onclick="OpenInviteModal">✉️ @T("invite.sendToDoctor")</button>
                    <button class="btn-action-main" @onclick="OpenWifiModalAsync">📶 @T("wifi.manage")</button>
                }
            </div>
        </div>

        <div class="person-profile-header">
            <div class="profile-left">
                <div class="person-avatar-huge">@GetInitials(Person.Name)</div>
                <div class="profile-info-main">
                    <h1 class="person-name-main">@Person.Name</h1>
                    <p class="person-meta">
                        @if (Person.Age > 0)
                        {
                            <span>@Person.Age @T("selected.years")</span>
                        }
                        else
                        {
                            <span>@T("selected.noAgeGender")</span>
                        }
                    </p>
                    <div class="status-badge @Person.Status.ToLower()">
                        <span class="status-dot-large"></span>
                        @GetStatusText(Person.Status)
                    </div>
                </div>
            </div>
            <div class="profile-right">
                <div class="contact-info">
                    <div class="contact-item">
                        <span class="contact-icon">📍</span>
                        <span class="contact-text">@Person.Location</span>
                    </div>
                    <div class="contact-item">
                        <span class="contact-icon">⏰</span>
                        <span class="contact-text">@T("selected.lastUpdate") @Person.LastUpdate</span>
                    </div>
                    <div class="contact-item">
                        <span class="contact-icon">🆔</span>
                        <span class="contact-text">@T("selected.device") @Person.DeviceSerial</span>
                    </div>
                </div>
                @if (_showEditButton && !(Person?.IsReadOnly ?? false) && !_isDoctorUser)
                {
                    <div class="action-buttons">
                        <button class="btn-action-main" @onclick="OpenEditModal">⚙️ @T("selected.editProfile")</button>
                        <button class="btn-danger" @onclick="OpenDeleteModal">🗑️ Șterge</button>
                    </div>
                }
            </div>
        </div>

        @* ── Pending deletion banner ── *@
        @if (Person.DeletedAt.HasValue)
        {
            var daysLeft = (int)Math.Ceiling((Person.DeletedAt.Value.AddDays(7) - DateTime.UtcNow).TotalDays);
            <div class="deletion-pending-banner">
                <span>🗑️</span>
                <span>
                    Această persoană este programată pentru ștergere definitivă.
                    @if (daysLeft > 0)
                    {
                        <span> Va fi eliminată în <strong>@daysLeft @(daysLeft == 1 ? "zi" : "zile")</strong>.</span>
                    }
                    else
                    {
                        <span> Ștergerea este iminentă.</span>
                    }
                    Contactați un administrator pentru reactivare.
                </span>
            </div>
        }

        @* ── False-alarm feedback banner ── *@
        @if (_pendingFeedback != null)
        {
            <div class="feedback-inline-banner">
                <div class="feedback-inline-header">
                    <span class="feedback-inline-icon">@(_pendingFeedback.NotificationType == "Critical" ? "🚨" : "⚠️")</span>
                    <strong>@T("feedback.title")</strong>
                    <span class="feedback-inline-time">@_pendingFeedback.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</span>
                </div>
                <p class="feedback-inline-msg">@_pendingFeedback.Message</p>
                <p class="feedback-inline-prompt">@T("feedback.prompt")</p>
                <div class="feedback-inline-actions">
                    <button class="feedback-inline-btn real" @onclick='() => SubmitFeedbackAsync(true)' disabled="@_feedbackSubmitting">
                        ✓ @T("feedback.wasReal")
                    </button>
                    <button class="feedback-inline-btn false" @onclick='() => SubmitFeedbackAsync(false)' disabled="@_feedbackSubmitting">
                        ✗ @T("feedback.wasFalse")
                    </button>
                    <button class="feedback-inline-skip" @onclick="DismissFeedback" disabled="@_feedbackSubmitting">
                        @T("feedback.skip")
                    </button>
                </div>
            </div>
        }

        <div class="stats-overview">
            @if (!Person.IsReadOnly)
            {
            <div class="stat-card-large heart-rate @(Person.HeartRate <= 0 ? "no-data" : "")">
                <div class="stat-icon-huge">❤️</div>
                <div class="stat-content">
                    <h3>@T("selected.heartRate")</h3>
                    @if (Person.HeartRate > 0)
                    {
                        <div class="stat-value-huge">@Person.HeartRate <span class="stat-unit">bpm</span></div>
                        <p class="stat-status @GetVitalStatus(Person.HeartRate, Person.MinHeartRate, Person.MaxHeartRate)">@GetVitalStatusText(Person.HeartRate, Person.MinHeartRate, Person.MaxHeartRate)</p>
                    }
                    else
                    {
                        <div class="stat-value-huge no-data-value">@T("selected.noRecentMeasurements")</div>
                        <p class="stat-status no-data-status">@T("selected.noData")</p>
                    }
                </div>
            </div>
            <div class="stat-card-large blood-oxygen @(Person.SpO2 <= 0 ? "no-data" : "")">
                <div class="stat-icon-huge">🩸</div>
                <div class="stat-content">
                    <h3>@T("selected.bloodOxygen")</h3>
                    @if (Person.SpO2 > 0)
                    {
                        <div class="stat-value-huge">@Person.SpO2 <span class="stat-unit">%</span></div>
                        <p class="stat-status @GetSpO2Status(Person.SpO2, Person.MinSpO2)">@GetSpO2StatusText(Person.SpO2, Person.MinSpO2)</p>
                    }
                    else
                    {
                        <div class="stat-value-huge no-data-value">@T("selected.noRecentMeasurements")</div>
                        <p class="stat-status no-data-status">@T("selected.noData")</p>
                    }
                </div>
            </div>
            <div class="stat-card-large temperature @(Person.Temperature <= 0 ? "no-data" : "")">
                <div class="stat-icon-huge">🌡️</div>
                <div class="stat-content">
                    <h3>@T("selected.temperature")</h3>
                    @if (Person.Temperature > 0)
                    {
                        <div class="stat-value-huge">@Person.Temperature <span class="stat-unit">°C</span></div>
                        <p class="stat-status @GetTempStatus(Person.Temperature, Person.MinTemperature, Person.MaxTemperature)">@GetTempStatusText(Person.Temperature, Person.MinTemperature, Person.MaxTemperature)</p>
                    }
                    else
                    {
                        <div class="stat-value-huge no-data-value">@T("selected.noRecentMeasurements")</div>
                        <p class="stat-status no-data-status">@T("selected.noData")</p>
                    }
                </div>
            </div>
            <div class="stat-card-large gps @(GetGPSStatus(Person.GPS) == "disabled" ? "no-data" : "")">
                <div class="stat-icon-huge">📍</div>
                <div class="stat-content">
                    <h3>@T("selected.gpsLocation")</h3>
                    @if (GetGPSStatus(Person.GPS) == "disabled")
                    {
                        <div class="stat-value-huge no-data-value">@T("selected.noRecentMeasurements")</div>
                        <p class="stat-status no-data-status">@T("selected.noData")</p>
                    }
                    else
                    {
                        <div class="stat-value-gps">@Person.GPS</div>
                        <p class="stat-status normal gps-last-coords">@(_isLastKnownGps ? T("selected.gpsLastKnown") : T("selected.gpsLastCoords"))</p>
                    }
                </div>
            </div>
            } @* end !IsArchived vital signs *@

            @* Device diagnostics card — shown only when at least one heartbeat field is present *@
            @if (!Person.IsReadOnly && _espData != null && _espData.RssiDbm.HasValue)
            {
                <div class="stat-card-device-diag">
                    <div class="device-diag-title">
                        <span>📡</span> @T("selected.deviceDiag")
                    </div>
                    <div class="device-diag-grid">
                        @if (_espData.RssiDbm.HasValue)
                        {
                            var rssi = _espData.RssiDbm.Value;
                            var rssiClass = rssi < -80 ? "diag-val-danger" : rssi < -65 ? "diag-val-warn" : "diag-val-ok";
                            var rssiLabel = rssi < -80 ? T("selected.signalWeak") : rssi < -65 ? T("selected.signalFair") : T("selected.signalGood");
                            <div class="device-diag-item">
                                <span class="diag-icon">📶</span>
                                <span class="diag-label">WiFi</span>
                                <span class="diag-val @rssiClass">@rssi dBm (@rssiLabel)</span>
                            </div>
                        }
                        @if (_espData.UptimeSeconds.HasValue)
                        {
                            var up = _espData.UptimeSeconds.Value;
                            var upStr = up < 3600 ? $"{up/60}m" : $"{up/3600}h {(up%3600)/60}m";
                            <div class="device-diag-item">
                                <span class="diag-icon">⏱</span>
                                <span class="diag-label">@T("selected.uptime")</span>
                                <span class="diag-val diag-val-ok">@upStr</span>
                            </div>
                        }
                        @if (_espData.HeartbeatAge.HasValue)
                        {
                            var age = _espData.HeartbeatAge.Value;
                            var ageClass = age > 120 ? "diag-val-danger" : age > 60 ? "diag-val-warn" : "diag-val-ok";
                            <div class="device-diag-item">
                                <span class="diag-icon">🕐</span>
                                <span class="diag-label">@T("selected.lastHeartbeat")</span>
                                <span class="diag-val @ageClass">@age s @T("selected.ago")</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        @if (Person.IsArchived)
        {
            <div class="archived-notice section-card">
                <span class="archived-notice-icon">📦</span>
                <div>
                    <strong>@T("archive.statusArchived")</strong>
                    @if (Person.ArchivedAt.HasValue)
                    {
                        <span> — @T("archive.archivedAt"): @Person.ArchivedAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                    }
                    <p>@T("archive.selectedNotice")</p>
                </div>
            </div>
        }

        @if (GetRetentionExpiryText() is string retentionText)
        {
            <div class="retention-banner">
                <span class="retention-icon">🗓️</span>
                <span>@retentionText</span>
            </div>
        }

        @if (!Person.IsReadOnly)
        {
        <div class="ai-prediction-section section-card">
            <div class="section-header">
                <h2>🤖 @T("selected.aiPrediction")</h2>
            </div>
            @if (AIPredictionLoading)
            {
                <div class="ai-loading">
                    <div class="ai-spinner"></div>
                    <span>@T("selected.aiAnalyzing")</span>
                </div>
            }
            else if (AIPrediction != null)
            {
                <div class="ai-prediction-content">
                    <div class="ai-main-result">
                        <div class="ai-risk-badge @AIPrediction.RiskLevel.ToLower()">
                            <span class="ai-risk-icon">@GetAIRiskIcon(AIPrediction.RiskLevel)</span>
                            <div class="ai-risk-info">
                                <span class="ai-risk-label">@T("selected.aiRiskLevel")</span>
                                <span class="ai-risk-value">@GetAIRiskText(AIPrediction.RiskLevel)</span>
                            </div>
                        </div>
                        <div class="ai-confidence">
                            <span class="ai-confidence-label">@T("selected.aiConfidence")</span>
                            <div class="ai-confidence-bar">
                                <div class="ai-confidence-fill @AIPrediction.RiskLevel.ToLower()" style="width: @((AIPrediction.Confidence * 100).ToString("F0", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                            </div>
                            <span class="ai-confidence-value">@((AIPrediction.Confidence * 100).ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%</span>
                        </div>
                        <div class="ai-state">
                            <span class="ai-state-label">@T("selected.aiDetectedState")</span>
                            <span class="ai-state-value">@AIPrediction.Prediction</span>
                        </div>
                        @if (_isCurrentDataFresh)
                        {
                        <div class="ai-health-score">
                            <span class="ai-health-label">@T("selected.aiHealthScore")</span>
                            <span class="ai-health-value @(AIPrediction.HealthScore >= 80 ? "critical" : AIPrediction.HealthScore >= 40 ? "alert" : "normal")">@(100 - AIPrediction.HealthScore) / 100</span>
                        </div>
                        }
                    </div>
                    <div class="ai-details">
                        <p>@AIPrediction.Details</p>
                    </div>
                    @if (AIPrediction.AllProbabilities != null && AIPrediction.AllProbabilities.Count > 1)
                    {
                        <button class="ai-prob-toggle" @onclick="() => _showProbabilities = !_showProbabilities">
                            @T("selected.aiProbabilities")
                            <span class="ai-prob-toggle-icon @(_showProbabilities ? "expanded" : "")">▾</span>
                        </button>
                        @if (_showProbabilities)
                        {
                            <div class="ai-probabilities">
                                <div class="ai-prob-bars">
                                    @foreach (var prob in AIPrediction.AllProbabilities.OrderByDescending(p => p.Value))
                                    {
                                        <div class="ai-prob-item">
                                            <span class="ai-prob-label">@prob.Key</span>
                                            <div class="ai-prob-bar">
                                                <div class="ai-prob-fill" style="width: @((prob.Value * 100).ToString("F0", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                                            </div>
                                            <span class="ai-prob-value">@((prob.Value * 100).ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            }
            else
            {
                <div class="ai-unavailable">
                    <span class="ai-unavailable-icon">🤖</span>
                    <p>@T("selected.aiUnavailable")</p>
                </div>
            }
        </div>

        <div class="trend-prediction-section section-card">
            <div class="section-header">
                <h2>📈 @T("selected.trendTitle")</h2>
            </div>
            @if (TrendPredictionsLoading)
            {
                <div class="ai-loading">
                    <div class="ai-spinner"></div>
                    <span>@T("selected.aiAnalyzing")</span>
                </div>
            }
            else if (TrendPredictions == null || TrendPredictions.BufferDataPoints < 3)
            {
                <div class="trend-no-data">
                    <span class="trend-no-data-icon">📊</span>
                    <p>@T("selected.trendNoData")</p>
                </div>
            }
            else if (!TrendPredictions.Predictions.Any())
            {
                <div class="trend-stable">
                    <span class="trend-stable-icon">✅</span>
                    <p>@T("selected.trendNone")</p>
                    <span class="trend-buffer-info">@TrendPredictions.BufferDataPoints @T("selected.trendDataPoints") / @((int)TrendPredictions.BufferDurationSeconds)s</span>
                </div>
            }
            else
            {
                <div class="trend-predictions-list">
                    @foreach (var pred in TrendPredictions.Predictions)
                    {
                        <div class="trend-prediction-card @pred.Severity">
                            <div class="trend-card-header">
                                <span class="trend-metric-icon">@GetTrendMetricIcon(pred.Metric)</span>
                                <span class="trend-label">@GetTrendLabel(pred)</span>
                                <span class="trend-direction-badge @pred.Direction">
                                    @(pred.Direction == "rising" ? "↑" : "↓") @T(pred.Direction == "rising" ? "selected.trendRising" : "selected.trendFalling")
                                </span>
                            </div>
                            <div class="trend-card-body">
                                <div class="trend-stat">
                                    <span class="trend-stat-label">@T("selected.trendRate")</span>
                                    <span class="trend-stat-value">@FormatTrendRate(pred.Metric, pred.ChangeRatePerMinute)</span>
                                </div>
                                <div class="trend-stat">
                                    <span class="trend-stat-label">@T("selected.trendThreshold")</span>
                                    <span class="trend-stat-value">@GetTrendThreshold(pred)</span>
                                </div>
                                @if (pred.SecondsToThreshold.HasValue)
                                {
                                    <div class="trend-stat trend-time">
                                        <span class="trend-stat-label">@T("selected.trendTimeToThreshold")</span>
                                        <span class="trend-stat-value trend-time-value @pred.Severity">
                                            @FormatSecondsToThreshold(pred.SecondsToThreshold.Value, T("selected.trendMinutes"), T("selected.trendSeconds"))
                                        </span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
                <div class="trend-buffer-footer">
                    @TrendPredictions.BufferDataPoints @T("selected.trendDataPoints") / @((int)TrendPredictions.BufferDurationSeconds)s
                </div>
            }
        </div>

        <div class="activity-profile-section section-card">
            <div class="section-header">
                <h2>🕐 @T("selected.activityProfile")</h2>
                @if (ActivityProfile?.LastUpdated != null)
                {
                    <span class="profile-updated-at">@T("selected.activityProfileUpdated") @ActivityProfile.LastUpdated.Value.ToLocalTime().ToString("dd MMM yyyy")</span>
                }
            </div>
            @if (ActivityProfileLoading)
            {
                <div class="ai-loading">
                    <div class="ai-spinner"></div>
                    <span>@T("selected.activityProfileLoading")</span>
                </div>
            }
            else if (ActivityProfile == null || !ActivityProfile.HourlyProfiles.Any())
            {
                @* Show a friendly onboarding message for new patients instead of a bare "no data" *@
                <div class="profile-warmup-card">
                    <span class="profile-warmup-icon">🌱</span>
                    <div>
                        <strong>@T("selected.profileWarmupTitle")</strong>
                        <p>@T("selected.profileWarmupBody")</p>
                        @if (RecentMeasurements.Count > 0)
                        {
                            <span class="profile-warmup-progress">
                                @string.Format(T("selected.profileWarmupMeasurements"), RecentMeasurements.Count)
                            </span>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="activity-timeline">
                    @for (int h = 0; h < 24; h++)
                    {
                        var hour = h;
                        var slot = ActivityProfile.HourlyProfiles.FirstOrDefault(p => p.HourOfDay == hour);
                        var slotClass = slot != null ? GetActivitySlotClass(slot.Label) : "slot-nodata";
                        var tooltip = GetSlotTooltip(slot, hour);
                        <div class="activity-slot @slotClass" title="@tooltip">
                            <span class="activity-slot-hour">@hour.ToString("D2")</span>
                            @if (slot != null && slot.DataPoints >= 10)
                            {
                                <span class="activity-slot-pulse">@slot.AveragePulse.ToString("F0")</span>
                            }
                        </div>
                    }
                </div>
                <div class="activity-legend">
                    <div class="legend-item"><span class="legend-dot slot-sleep"></span>@T("selected.activitySleep")</div>
                    <div class="legend-item"><span class="legend-dot slot-active"></span>@T("selected.activityActive")</div>
                    <div class="legend-item"><span class="legend-dot slot-moderate"></span>@T("selected.activityModerate")</div>
                    <div class="legend-item"><span class="legend-dot slot-rest"></span>@T("selected.activityRest")</div>
                    <div class="legend-item"><span class="legend-dot slot-nodata"></span>@T("selected.activityNoData")</div>
                </div>
            }
        </div>

        <div class="conditions-section section-card">
            <div class="section-header">
                <h2>🩺 @T("conditions.title")</h2>
                @if (_showEditButton)
                {
                    <button class="btn-action-secondary" @onclick="OpenConditionsModal">✏️ @T("conditions.edit")</button>
                }
            </div>

            @if (_conditionsLoading)
            {
                <div class="conditions-loading">
                    <div class="ai-spinner"></div>
                </div>
            }
            else if (_conditions.Count == 0)
            {
                <div class="conditions-empty">
                    <span>@T("conditions.none")</span>
                    @if (_showEditButton)
                    {
                        <button class="btn-add-condition" @onclick="OpenConditionsModal">+ @T("conditions.add")</button>
                    }
                </div>
            }
            else
            {
                <div class="conditions-groups">
                    @foreach (var group in ConditionGroups)
                    {
                        var active = group.Keys.Where(k => _conditions.Contains(k)).ToList();
                        @if (active.Any())
                        {
                            <div class="condition-group">
                                <span class="condition-group-label">@group.Icon @T(group.CategoryKey)</span>
                                <div class="condition-chips">
                                    @foreach (var key in active)
                                    {
                                        <span class="condition-chip @group.ColorClass">@T("conditions." + key)</span>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            }
        </div>

        <div class="doctor-notes-section section-card">
            <div class="section-header">
                <h2>📝 @T("doctorNotes.title")</h2>
                @if (_isDoctorUser)
                {
                    <button class="btn-action-secondary" @onclick="OpenDoctorNotesModal">✏️ @T("doctorNotes.add")</button>
                }
            </div>

            @if (_doctorNotesLoading)
            {
                <div class="doctor-notes-loading">
                    <div class="ai-spinner"></div>
                </div>
            }
            else if (_doctorNotes.Count == 0)
            {
                <div class="doctor-notes-empty">
                    <span class="doctor-notes-empty-icon">📝</span>
                    <p>@T("doctorNotes.none")</p>
                </div>
            }
            else
            {
                <div class="doctor-notes-list">
                    @foreach (var note in _doctorNotes.OrderByDescending(n => n.CreatedAt))
                    {
                        <div class="doctor-note-card">
                            <div class="doctor-note-header">
                                <div class="doctor-note-doctor">
                                    <span class="doctor-note-email">@note.DoctorEmail</span>
                                </div>
                                <span class="doctor-note-date">@note.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</span>
                            </div>
                            <div class="doctor-note-content">@note.Content</div>
                        </div>
                    }
                </div>
            }
        </div>

        @if (!Person.IsReadOnly)
        {
        <div class="map-section section-card">
            <div class="section-header">
                <h2>📍 @(_isLastKnownGps ? T("selected.gpsLastKnown") : T("selected.currentLocation"))</h2>
            </div>
            <div class="map-wrapper">
                @if (GetGPSStatus(Person.GPS) == "disabled")
                {
                    <div class="map-no-data">
                        <span class="map-no-data-icon">📍</span>
                        <p>@T("selected.noCoordinates")</p>
                    </div>
                }
                else
                {
                    <div class="map-container" @ref="_mapRef"></div>
                }
            </div>
        </div>
        } @* end !IsArchived map *@
        } @* end !IsArchived ai/trend/activity/map *@

        <div class="content-grid">
            <div class="chart-section">
                <div class="section-card">
                    <div class="section-header">
                        <h2>📊 @T("selected.vitalSigns")</h2>
                        <div class="chart-view-toggle">
                            <button class="btn-chart-view @(CurrentChartView == ChartViewMode.Daily ? "active" : "")"
                                    @onclick="() => SwitchChartView(ChartViewMode.Daily)">@T("selected.daily")</button>
                            <button class="btn-chart-view @(CurrentChartView == ChartViewMode.Weekly ? "active" : "")"
                                    @onclick="() => SwitchChartView(ChartViewMode.Weekly)">@T("selected.weekly")</button>
                        </div>
                    </div>

                    <div class="charts-wrapper">
                        <div class="chart-week-nav">
                            @if (CurrentChartView == ChartViewMode.Weekly)
                            {
                                <button class="btn-week-arrow @(_hasPrevWeekData ? "" : "disabled")"
                                        @onclick="GoToPreviousWeek" disabled="@(!_hasPrevWeekData)">
