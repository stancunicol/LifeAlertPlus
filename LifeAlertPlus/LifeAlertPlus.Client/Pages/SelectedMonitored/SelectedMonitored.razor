}

@if (_showConditionsModal)
{
    <div class="modal-overlay" @onclick="CloseConditionsModal">
        <div class="modal-content conditions-modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>🩺 @T("conditions.editTitle")</h2>
                <button class="modal-close" @onclick="CloseConditionsModal">✕</button>
            </div>
            <div class="modal-body">
                @foreach (var group in ConditionGroups)
                {
                    <div class="conditions-modal-group">
                        <h4 class="conditions-modal-category @group.ColorClass">@group.Icon @T(group.CategoryKey)</h4>
                        <div class="conditions-modal-items">
                            @foreach (var key in group.Keys)
                            {
                                var k = key;
                                var isChecked = _editConditions.Contains(k);
                                <label class="condition-checkbox-label">
                                    <input type="checkbox" checked="@isChecked"
                                           @onchange="e => ToggleCondition(k, (bool)(e.Value ?? false))" />
                                    <span class="condition-checkbox-text">@T("conditions." + k)</span>
                                </label>
                            }
                        </div>
                    </div>
                }
                <div class="condition-threshold-preview">
                    <h4>@T("selected.conditionPreview")</h4>
                    <div class="threshold-preview-grid">
                        <div class="threshold-preview-item">
                            <span class="threshold-label">❤️ @T("selected.minHr")</span>
                            <span class="threshold-value">@_previewMinHr bpm</span>
                        </div>
                        <div class="threshold-preview-item">
                            <span class="threshold-label">❤️ @T("selected.maxHr")</span>
                            <span class="threshold-value">@_previewMaxHr bpm</span>
                        </div>
                        <div class="threshold-preview-item">
                            <span class="threshold-label">🌡️ @T("selected.minTemp")</span>
                            <span class="threshold-value">@_previewMinTemp.ToString("F1") °C</span>
                        </div>
                        <div class="threshold-preview-item">
                            <span class="threshold-label">🌡️ @T("selected.maxTemp")</span>
                            <span class="threshold-value">@_previewMaxTemp.ToString("F1") °C</span>
                        </div>
                        <div class="threshold-preview-item">
                            <span class="threshold-label">🩸 @T("selected.minSpO2")</span>
                            <span class="threshold-value">@_previewMinSpO2 %</span>
                        </div>
                        <div class="threshold-preview-item">
                            <span class="threshold-label">🩸 @T("selected.maxSpO2")</span>
                            <span class="threshold-value">@_previewMaxSpO2 %</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseConditionsModal">@T("common.cancel")</button>
                <button class="btn-save" @onclick="SaveConditionsAsync" disabled="@_isSavingConditions">
                    @(_isSavingConditions ? T("selected.saving") : "💾 " + T("common.save"))
                </button>
            </div>
        </div>
    </div>
}

