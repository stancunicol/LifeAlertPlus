@page "/monitored/{PersonId:guid}"
@using LifeAlertPlus.Client.Components.Header
@layout MainLayout

@using LifeAlertPlus.Domain.Entities

<HeaderComponent UserName="@UserFullName" ProfilePictureUrl="@ProfilePictureUrl"/>

<div class="selected-monitored-container">
    @if (Person != null)
    {
        <div class="back-navigation">
            <button class="btn-back" @onclick="GoBack">
                <span class="back-icon">←</span> Go Back to Monitored List
            </button>
            <div class="top-actions">
                <button class="btn-action-main">📤 Export</button>
            </div>
        </div>

        <div class="person-profile-header">
            <div class="profile-left">
                <div class="person-avatar-huge">@GetInitials(Person.Name)</div>
                <div class="profile-info-main">
                    <h1 class="person-name-main">@Person.Name</h1>
                    <p class="person-meta">
                        @if (Person.Age > 0)
                        {
                            <span>@Person.Age years</span>
                            @if (!string.IsNullOrEmpty(Person.Relationship))
                            {
                                <span> • @Person.Relationship</span>
                            }
                        }
                        else if (!string.IsNullOrEmpty(Person.Relationship))
                        {
                            <span>@Person.Relationship</span>
                        }
                        else
                        {
                            <span>No age/gender info</span>
                        }
                    </p>
                    <div class="status-badge @Person.Status.ToLower()">
                        <span class="status-dot-large"></span>
                        @GetStatusText(Person.Status)
                    </div>
                </div>
            </div>
            <div class="profile-right">
                <div class="contact-info">
                    <div class="contact-item">
                        <span class="contact-icon">📍</span>
                        <span class="contact-text">@Person.Location</span>
                    </div>
                    <div class="contact-item">
                        <span class="contact-icon">⏰</span>
                        <span class="contact-text">Last Update: @Person.LastUpdate</span>
                    </div>
                    <div class="contact-item">
                        <span class="contact-icon">🆔</span>
                        <span class="contact-text">Device: @Person.DeviceSerial</span>
                    </div>
                </div>
                <div class="action-buttons">
                    <button class="btn-action-main">⚙️ Edit Profile</button>
                </div>
            </div>
        </div>

        <div class="stats-overview">
            <div class="stat-card-large heart-rate">
                <div class="stat-icon-huge">❤️</div>
                <div class="stat-content">
                    <h3>Heart Rate</h3>
                    <div class="stat-value-huge">@Person.HeartRate <span class="stat-unit">bpm</span></div>
                    <p class="stat-status @GetVitalStatus(Person.HeartRate, 60, 100)">@GetVitalStatusText(Person.HeartRate, 60, 100)</p>
                </div>
            </div>
            <div class="stat-card-large blood-oxygen">
                <div class="stat-icon-huge">🩸</div>
                <div class="stat-content">
                    <h3>Blood Oxygen (SpO₂)</h3>
                    <div class="stat-value-huge">@Person.SpO2 <span class="stat-unit">%</span></div>
                    <p class="stat-status @GetSpO2Status(Person.SpO2)">@GetSpO2StatusText(Person.SpO2)</p>
                </div>
            </div>
            <div class="stat-card-large temperature">
                <div class="stat-icon-huge">🌡️</div>
                <div class="stat-content">
                    <h3>Temperature</h3>
                    <div class="stat-value-huge">@Person.Temperature <span class="stat-unit">°C</span></div>
                    <p class="stat-status @GetTempStatus(Person.Temperature)">@GetTempStatusText(Person.Temperature)</p>
                </div>
            </div>
            <div class="stat-card-large gps">
                <div class="stat-icon-huge">📍</div>
                <div class="stat-content">
                    <h3>GPS Location</h3>
                    <div class="stat-value-gps">@Person.GPS</div>
                    <p class="stat-status @GetGPSStatus(Person.GPS)">@GetGPSStatusText(Person.GPS)</p>
                </div>
            </div>
        </div>

        <div class="content-grid">
            <div class="chart-section">
                <div class="section-card">
                    <div class="section-header">
                        <h2>📊 Vital Signs Evolution</h2>
                        <div class="chart-controls">
                            <div class="chart-view-toggle">
                                <button class="btn-chart-view @(CurrentChartView == ChartViewMode.Daily ? "active" : "")" 
                                        @onclick="() => SwitchChartView(ChartViewMode.Daily)">
                                    Daily
                                </button>
                                <button class="btn-chart-view @(CurrentChartView == ChartViewMode.Weekly ? "active" : "")" 
                                        @onclick="() => SwitchChartView(ChartViewMode.Weekly)">
                                    Weekly
                                </button>
                            </div>
                            <div class="chart-legend">
                                <div class="legend-item">
                                    <span class="legend-dot heart-rate"></span>
                                    <span class="legend-label">Heart Rate</span>
                                </div>
                                <div class="legend-item">
                                    <span class="legend-dot temperature"></span>
                                    <span class="legend-label">Temperature</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="chart-pair">
                        <!-- Heart Rate Chart -->
                        <div class="chart-sub">
                            <div class="chart-sub-title">❤️ Heart Rate <span class="chart-unit">bpm</span></div>
                            <svg class="chart-svg" viewBox="0 0 800 200" preserveAspectRatio="xMidYMid meet">
                                <line x1="70" y1="15" x2="70" y2="160" class="axis-line" />
                                <line x1="70" y1="160" x2="785" y2="160" class="axis-line" />
                                <line x1="70" y1="15" x2="785" y2="15" class="grid-line" />
                                <line x1="70" y1="51" x2="785" y2="51" class="grid-line" />
                                <line x1="70" y1="88" x2="785" y2="88" class="grid-line" />
                                <line x1="70" y1="124" x2="785" y2="124" class="grid-line" />
                                <line x1="70" y1="160" x2="785" y2="160" class="grid-line" />
                                <g>@((MarkupString)"<text x=\"66\" y=\"19\" class=\"chart-y-label\">120</text>")</g>
                                <g>@((MarkupString)"<text x=\"66\" y=\"55\" class=\"chart-y-label\">100</text>")</g>
                                <g>@((MarkupString)"<text x=\"66\" y=\"92\" class=\"chart-y-label\">80</text>")</g>
                                <g>@((MarkupString)"<text x=\"66\" y=\"128\" class=\"chart-y-label\">60</text>")</g>
                                <g>@((MarkupString)"<text x=\"66\" y=\"164\" class=\"chart-y-label\">40</text>")</g>
                                @if (HeartRatePoints.Any())
                                {
                                    <path d="@GenerateSmoothPath(HeartRatePoints)" class="chart-line heart-rate-line" />
                                }
                                @foreach (var xlabel in GetXAxisLabels())
                                {
                                    var xlX = xlabel.X.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);
                                    <line x1="@xlX" y1="160" x2="@xlX" y2="167" class="axis-tick" />
                                    <g>@((MarkupString)$"<text x=\"{xlX}\" y=\"182\" class=\"chart-x-label\" text-anchor=\"middle\">{xlabel.Label}</text>")</g>
                                }
                            </svg>
                        </div>
                        <!-- Temperature Chart -->
                        <div class="chart-sub">
                            <div class="chart-sub-title">🌡️ Temperature <span class="chart-unit">°C</span></div>
                            <svg class="chart-svg" viewBox="0 0 800 200" preserveAspectRatio="xMidYMid meet">
                                <line x1="70" y1="15" x2="70" y2="160" class="axis-line" />
                                <line x1="70" y1="160" x2="785" y2="160" class="axis-line" />
                                <line x1="70" y1="15" x2="785" y2="15" class="grid-line" />
                                <line x1="70" y1="51" x2="785" y2="51" class="grid-line" />
                                <line x1="70" y1="88" x2="785" y2="88" class="grid-line" />
                                <line x1="70" y1="124" x2="785" y2="124" class="grid-line" />
                                <line x1="70" y1="160" x2="785" y2="160" class="grid-line" />
                                <g>@((MarkupString)"<text x=\"66\" y=\"19\" class=\"chart-y-label\">39°</text>")</g>
                                <g>@((MarkupString)"<text x=\"66\" y=\"55\" class=\"chart-y-label\">38°</text>")</g>
                                <g>@((MarkupString)"<text x=\"66\" y=\"92\" class=\"chart-y-label\">37°</text>")</g>
                                <g>@((MarkupString)"<text x=\"66\" y=\"128\" class=\"chart-y-label\">36°</text>")</g>
                                <g>@((MarkupString)"<text x=\"66\" y=\"164\" class=\"chart-y-label\">35°</text>")</g>
                                @if (TemperaturePoints.Any())
                                {
                                    <path d="@GenerateSmoothPath(TemperaturePoints)" class="chart-line temperature-line" />
                                }
                                @foreach (var xlabel in GetXAxisLabels())
                                {
                                    var xlX = xlabel.X.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);
                                    <line x1="@xlX" y1="160" x2="@xlX" y2="167" class="axis-tick" />
                                    <g>@((MarkupString)$"<text x=\"{xlX}\" y=\"182\" class=\"chart-x-label\" text-anchor=\"middle\">{xlabel.Label}</text>")</g>
                                }
                            </svg>
                        </div>
                    </div>
                </div>
            </div>

            <div class="sidebar-section">
                <div class="section-card">
                    <div class="section-header">
                        <h2>🔔 Recent Alerts</h2>
                    </div>
                    <div class="alerts-list">
                        @foreach (var alert in RecentAlerts)
                        {
                            <div class="alert-item @alert.Severity.ToLower()">
                                <div class="alert-icon">@GetAlertIcon(alert.Severity)</div>
                                <div class="alert-content">
                                    <h4>@alert.Title</h4>
                                    <p>@alert.Description</p>
                                    <span class="alert-time">@alert.Time</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-header">
                        <h2>📋 Recent Measurements</h2>
                    </div>
                    <div class="measurements-list">
                        @foreach (var measurement in RecentMeasurements)
                        {
                            <div class="measurement-item">
                                <div class="measurement-icon">@measurement.Icon</div>
                                <div class="measurement-content">
                                    <h4>@measurement.Type</h4>
                                    <p class="measurement-value">@measurement.Value</p>
                                    <span class="measurement-time">@measurement.Time</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else if (IsLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading...</p>
        </div>
    }
    else
    {
        <div class="loading-state">
            <p>@(LoadError ?? "Monitored person not found.")</p>
            <button class="btn-back" @onclick="GoBack">
                <span class="back-icon">←</span> Go Back to Monitored List
            </button>
        </div>
    }
</div>
