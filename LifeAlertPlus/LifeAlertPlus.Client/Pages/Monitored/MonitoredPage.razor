@page "/monitored"

@using LifeAlertPlus.Domain.Entities
@using LifeAlertPlus.Client.Components.Header

<HeaderComponent UserName="@UserFullName" ProfilePictureUrl="@ProfilePictureUrl"/>

<div class="monitored-container">
    <div class="monitored-header">
        <div class="header-title-section">
            <h1>@T("monitored.title")</h1>
            <p class="monitored-subtitle">@T("monitored.subtitle")</p>
        </div>
        @if (CurrentView == ViewMode.Active)
        {
            <button class="add-person-btn" @onclick="OpenAddPersonModal">
                <span class="btn-icon">➕</span>
                @T("monitored.addPerson")
            </button>
        }
    </div>

    <div class="view-tabs">
        <button class="view-tab @(CurrentView == ViewMode.Active ? "active" : "")"
                @onclick='() => SwitchViewAsync(ViewMode.Active)'>
            <span class="tab-icon">👥</span> @T("archive.tabActive") (@_monitoredCards.Count)
        </button>
        <button class="view-tab @(CurrentView == ViewMode.Archive ? "active" : "")"
                @onclick='() => SwitchViewAsync(ViewMode.Archive)'>
            <span class="tab-icon">📦</span> @T("archive.tabArchive") (@_archivedPeople.Count)
        </button>
    </div>

@if (CurrentView == ViewMode.Active)
{
    <div class="filters-section">
        <div class="filter-group search-group">
            <div class="search-input-wrap">
                <span class="search-icon">🔍</span>
                <input type="text" class="search-input" placeholder="@T("monitored.search")" @bind="_searchQuery" @bind:event="oninput" />
                @if (!string.IsNullOrEmpty(_searchQuery))
                {
                    <button class="search-clear" @onclick='() => _searchQuery = ""'>✕</button>
                }
            </div>
        </div>
        <div class="filter-group">
            <label>@T("monitored.statusFilter")</label>
            <div class="filter-buttons">
                <button class="filter-btn @(FilterStatus == "All" ? "active" : "")" @onclick='() => FilterStatus = "All"'>
                    @T("monitored.all") (@_monitoredCards.Count)
                </button>
                <button class="filter-btn critical @(FilterStatus == "Critical" ? "active" : "")" @onclick='() => FilterStatus = "Critical"'>
                    @T("monitored.alert") (@CriticalCount)
                </button>
                <button class="filter-btn warning @(FilterStatus == "Warning" ? "active" : "")" @onclick='() => FilterStatus = "Warning"'>
                    @T("monitored.checkNeeded") (@WarningCount)
                </button>
                <button class="filter-btn ok @(FilterStatus == "OK" ? "active" : "")" @onclick='() => FilterStatus = "OK"'>
                    @T("monitored.stable") (@StableCount)
                </button>
            </div>
        </div>

        <div class="filter-group">
            <label>@T("monitored.connectionFilter")</label>
            <div class="filter-buttons">
                <button class="filter-btn @(FilterOnlineStatus == "All" ? "active" : "")" @onclick='() => FilterOnlineStatus = "All"'>
                    @T("monitored.all") (@_monitoredCards.Count)
                </button>
                <button class="filter-btn online @(FilterOnlineStatus == "Online" ? "active" : "")" @onclick='() => FilterOnlineStatus = "Online"'>
                    @T("monitored.online") (@OnlineCount)
                </button>
                <button class="filter-btn offline @(FilterOnlineStatus == "Offline" ? "active" : "")" @onclick='() => FilterOnlineStatus = "Offline"'>
                    @T("monitored.offline") (@OfflineCount)
                </button>
            </div>
        </div>
    </div>

    <div class="live-updates">
        @if (_isLoadingMonitored)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <p>@T("monitored.loading")</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(_dataError))
        {
            <div class="error-state">
                <p>@_dataError</p>
            </div>
        }
        else if (_monitoredCards.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">🔍</div>
                <h3>@T("monitored.noMonitored")</h3>
                <p>@T("monitored.addToStart")</p>
            </div>
        }
        else if (!FilteredCards.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">🔍</div>
                <h3>@T("monitored.noResults")</h3>
                <p>@T("monitored.noMatch")</p>
            </div>
        }
        else
        {
            <div class="people-grid">
                @foreach (var card in FilteredCards)
                {
                    <div class="person-card-detailed @GetCardStatusClass(card)" @onclick="() => ViewDetails(card.Person.Id)">
                        <button class="card-archive-btn"
                                title="@T("archive.archiveAction")"
                                @onclick="() => OpenArchiveConfirm(card.Person)"
                                @onclick:stopPropagation="true">
                            <span class="archive-btn-icon">📦</span>
                            <span class="archive-btn-label">@T("archive.archiveAction")</span>
                        </button>
                        <div class="card-header-colored @GetCardStatus(card).ToLower()">
                            <div class="header-top">
                                <div class="person-avatar-big">@GetInitials($"{card.Person.FirstName} {card.Person.LastName}")</div>
                                <div class="person-basic-info">
                                    <h3 class="person-name-big">@card.Person.FirstName @card.Person.LastName</h3>
                                    @if (!card.Person.IsArchived)
                                    {
                                        <div class="status-row">
                                            <span class="status-dot"></span>
                                            <span class="status-text">@GetStatusText(GetCardStatus(card))</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="status-row archived-badge">
                                            <span class="archived-text">📦 @T("monitored.archived")</span>
                                        </div>
                                    }
                                    <p class="person-details">
                                        @{
                                            var age = GetAge(card.Person);
                                            var ageText = age > 0 ? $"{age} {T("selected.years")}" : T("monitored.ageNA");
                                        }
                                        @ageText • @(card.Person.Gender ?? "N/A") • @(card.Person.Address ?? "N/A")
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="card-body-white">
                            <div class="vitals-grid">
                                <div class="vital-box @(GetPulse(card.LastData) == "N/A" ? "no-data" : "")">
                                    <span class="vital-icon-large">❤️</span>
                                    <div class="vital-info">
                                        <span class="vital-value-large">@GetPulse(card.LastData)</span>
                                        <span class="vital-label-large">@T("card.pulse")</span>
                                    </div>
                                </div>
                                <div class="vital-box @(GetOxygen(card.LastData) == "N/A" ? "no-data" : "")">
                                    <span class="vital-icon-large">🩸</span>
                                    <div class="vital-info">
                                        <span class="vital-value-large">@GetOxygen(card.LastData)</span>
                                        <span class="vital-label-large">@T("card.spo2")</span>
                                    </div>
                                </div>
                                <div class="vital-box @(GetTemperature(card.LastData) == "N/A" ? "no-data" : "")">
                                    <span class="vital-icon-large">🌡️</span>
                                    <div class="vital-info">
                                        <span class="vital-value-large">@GetTemperature(card.LastData)</span>
                                        <span class="vital-label-large">@T("card.temperature")</span>
                                    </div>
                                </div>
                            </div>

                            <div class="additional-info">
                                <div class="info-item">
                                    <span class="info-label">@T("card.gps")</span>
                                    <span class="info-value">@FormatGpsStatus(card.LastData?.Neo6m)</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">@T("card.fallDetection")</span>
                                    <span class="info-value">@FormatFallRisk(card)</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">@T("card.lastUpdate")</span>
                                    <span class="info-value">@FormatLastUpdate(card)</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}
else
{
    <div class="archive-intro">
        <p class="archive-explainer">@T("archive.explainer")</p>
    </div>

    <div class="live-updates">
        @if (_isLoadingArchive)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <p>@T("archive.loading")</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(_dataError))
        {
            <div class="error-state">
                <p>@_dataError</p>
            </div>
        }
        else if (_archivedPeople.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">📦</div>
                <h3>@T("archive.emptyTitle")</h3>
                <p>@T("archive.emptyHint")</p>
            </div>
        }
        else
        {
            <div class="people-grid">
                @foreach (var person in _archivedPeople)
                {
                    <div class="person-card-detailed archived-card" @onclick="() => ViewDetails(person.Id)">
                        <div class="card-header-colored archived">
                            <div class="header-top">
                                <div class="person-avatar-big">@GetInitials($"{person.FirstName} {person.LastName}")</div>
                                <div class="person-basic-info">
                                    <h3 class="person-name-big">@person.FirstName @person.LastName</h3>
                                    <div class="status-row">
                                        <span class="status-dot"></span>
                                        <span class="status-text">@T("archive.statusArchived")</span>
                                    </div>
                                    <p class="person-details">
                                        @{
                                            var ageA = GetAge(person);
                                            var ageAText = ageA > 0 ? $"{ageA} {T("selected.years")}" : T("monitored.ageNA");
                                        }
                                        @ageAText • @(person.Gender ?? "N/A") • @(person.Address ?? "N/A")
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="card-body-white">
                            <div class="additional-info">
                                <div class="info-item">
                                    <span class="info-label">@T("archive.archivedAt")</span>
                                    <span class="info-value">@FormatArchivedDate(person.ArchivedAt)</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">@T("modal.deviceSerial")</span>
                                    <span class="info-value">@person.DeviceSerialNumber</span>
                                </div>
                            </div>

                            <div class="archive-actions">
                                <button class="archive-action-btn restore"
                                        @onclick="() => OpenRestoreConfirm(person)"
                                        @onclick:stopPropagation="true">
                                    <span class="archive-action-icon">↩️</span>
                                    <span>@T("archive.restoreAction")</span>
                                </button>
                                <button class="archive-action-btn delete"
                                        @onclick="() => OpenDeleteConfirm(person)"
                                        @onclick:stopPropagation="true">
                                    <span class="archive-action-icon">🗑️</span>
                                    <span>@T("archive.deleteAction")</span>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}
</div>

@if (_showArchiveConfirm && _personPendingAction != null)
{
    <div class="modal-overlay" @onclick="CloseActionModal">
        <div class="modal-content modal-confirm" @onclick:stopPropagation="true">
            <div class="modal-icon-header archive">📦</div>
            <div class="modal-header">
                <h3>@T("archive.confirmArchiveTitle")</h3>
                <button class="close-btn" @onclick="CloseActionModal">✕</button>
            </div>
            <div class="modal-body">
                <p class="modal-message">@string.Format(T("archive.confirmArchiveBody"), $"{_personPendingAction.FirstName} {_personPendingAction.LastName}")</p>
                @if (!string.IsNullOrEmpty(_actionError))
                {
                    <div class="error-alert">@_actionError</div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="modal-btn secondary" @onclick="CloseActionModal" disabled="@_isProcessingAction">@T("modal.cancel")</button>
                <button type="button" class="modal-btn primary" @onclick="ConfirmArchiveAsync" disabled="@_isProcessingAction">
                    @(_isProcessingAction ? T("archive.processing") : T("archive.archiveAction"))
                </button>
            </div>
        </div>
    </div>
}

@if (_showRestoreConfirm && _personPendingAction != null)
{
    <div class="modal-overlay" @onclick="CloseActionModal">
        <div class="modal-content modal-confirm" @onclick:stopPropagation="true">
            <div class="modal-icon-header restore">✅</div>
            <div class="modal-header">
                <h3>@T("archive.confirmRestoreTitle")</h3>
                <button class="close-btn" @onclick="CloseActionModal">✕</button>
            </div>
            <div class="modal-body">
                <p class="modal-message">@string.Format(T("archive.confirmRestoreBody"), $"{_personPendingAction.FirstName} {_personPendingAction.LastName}")</p>
                @if (!string.IsNullOrEmpty(_actionError))
                {
                    <div class="error-alert">@_actionError</div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="modal-btn secondary" @onclick="CloseActionModal" disabled="@_isProcessingAction">@T("modal.cancel")</button>
                <button type="button" class="modal-btn primary" @onclick="ConfirmRestoreAsync" disabled="@_isProcessingAction">
                    @(_isProcessingAction ? T("archive.processing") : T("archive.restoreAction"))
                </button>
            </div>
        </div>
    </div>
}

@if (_showDeleteConfirm && _personPendingAction != null)
{
    <div class="modal-overlay" @onclick="CloseActionModal">
        <div class="modal-content modal-confirm" @onclick:stopPropagation="true">
            <div class="modal-icon-header delete">🗑️</div>
            <div class="modal-header">
                <h3>@T("archive.confirmDeleteTitle")</h3>
                <button class="close-btn" @onclick="CloseActionModal">✕</button>
            </div>
            <div class="modal-body">
                <p class="modal-message">@string.Format(T("archive.confirmDeleteBody"), $"{_personPendingAction.FirstName} {_personPendingAction.LastName}")</p>
                <p class="warning-text">@T("archive.confirmDeleteWarning")</p>
                @if (!string.IsNullOrEmpty(_actionError))
                {
                    <div class="error-alert">@_actionError</div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="modal-btn secondary" @onclick="CloseActionModal" disabled="@_isProcessingAction">@T("modal.cancel")</button>
                <button type="button" class="modal-btn danger" @onclick="ConfirmDeleteAsync" disabled="@_isProcessingAction">
                    @(_isProcessingAction ? T("archive.processing") : T("archive.deleteAction"))
                </button>
            </div>
        </div>
    </div>
}

@if (ShowAddPersonModal)
{
    <div class="modal-overlay" @onclick="CloseAddPersonModal">
        <div class="modal-content-large" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@T("modal.addPerson")</h3>
                <button class="close-btn" @onclick="CloseAddPersonModal">✕</button>
            </div>
            <div class="modal-body">
                <EditForm Model="@newPerson" OnValidSubmit="HandleAddPerson">
                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="error-alert">
                            @ErrorMessage
                        </div>
                    }
                    
                    <div class="form-group">
                        <label>@T("modal.firstName")</label>
                        <InputText class="form-control" @bind-Value="newPerson.FirstName" placeholder="@T("modal.firstName")" />
                    </div>
                    <div class="form-group">
                        <label>@T("modal.lastName")</label>
                        <InputText class="form-control" @bind-Value="newPerson.LastName" placeholder="@T("modal.lastName")" />
                    </div>
                    <div class="form-group">
                        <label>@T("modal.birthdate")</label>
                        <InputDate class="form-control" @bind-Value="newPerson.Birthdate" />
                    </div>
                    <div class="form-group">
                        <label>@T("modal.gender")</label>
                        <InputSelect class="form-control" @bind-Value="newPerson.Gender">
                            <option value="">@T("modal.select")</option>
                            <option value="Male">@T("modal.male")</option>
                            <option value="Female">@T("modal.female")</option>
                            <option value="Other">@T("modal.other")</option>
                        </InputSelect>
                    </div>
                    <div class="form-group">
                        <label>@T("modal.address")</label>
                        <InputText class="form-control" @bind-Value="newPerson.Address" placeholder="@T("modal.address")" />
                    </div>
                    <div class="form-group">
                        <label>@T("modal.deviceSerial")</label>
                        <InputText class="form-control" @bind-Value="newPerson.DeviceSerialNumber" placeholder="ESP32-XXXXXXXXX" />
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="modal-btn secondary" @onclick="CloseAddPersonModal">@T("modal.cancel")</button>
                        <button type="submit" class="modal-btn primary">@T("modal.addButton")</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}
