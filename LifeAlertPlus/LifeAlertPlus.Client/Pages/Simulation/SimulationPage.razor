@page "/simulations"
@using LifeAlertPlus.Client.Components.HeaderAdmin
@layout MainLayout
@implements IDisposable

<HeaderAdminComponent UserName="@UserFullName" ProfilePictureUrl="@ProfilePictureUrl" />

<div class="simulations-page">
	<div class="admin-container">
		<div class="admin-header">
			<div class="header-title-section">
				<h1>@T("sim.title")</h1>
				<p class="admin-subtitle">@T("sim.subtitle")</p>
			</div>
			<span class="tag chip-muted">@T("sim.tools")</span>
		</div>

		<div class="sim-warning-banner">
			<span class="sim-warning-icon">⚠️</span>
			<div>
				<strong>@T("sim.warningTitle")</strong>
				<p>@T("sim.warningText")</p>
			</div>
		</div>

		@if (IsLoading)
		{
			<div class="message-card">@T("sim.loading")</div>
		}
		else if (!string.IsNullOrEmpty(ErrorMessage))
		{
			<div class="message-card error">
				<span>@ErrorMessage</span>
				<button @onclick="RefreshAsync">@T("sim.retry")</button>
			</div>
		}
		else
		{
			<div class="section">
				<div class="section-header">
					<div>
						<h2>@T("sim.devicesTitle")</h2>
						<span class="section-note">@SelectedCount / @Persons.Count @T("sim.selected")</span>
					</div>
					<div class="section-actions">
						<button class="primary" @onclick="SendAllAsync" disabled="@(!SelectedPersons.Any(p => !p.IsRunning && !p.IsSending))">
							@T("sim.generateAll")
						</button>
						<button class="secondary" @onclick="StartAllAutoAsync" disabled="@(!SelectedPersons.Any(p => !p.IsRunning))">
							@T("sim.startAutoAll")
						</button>
						<button class="danger" @onclick="StopAllAutoAsync" disabled="@(!SelectedPersons.Any(p => p.IsRunning))">
							@T("sim.stopAutoAll")
						</button>
						<button class="ghost" @onclick="RefreshAsync">@T("sim.refresh")</button>
					</div>
				</div>

				<div class="sim-toolbar">
					<div class="sim-search-wrap">
						<span class="sim-search-icon">🔍</span>
						<input type="text" class="sim-search" placeholder="@T("sim.searchPh")"
							   @bind="SearchQuery" @bind:event="oninput" />
					</div>
					<div class="sim-filters">
						<button class="sim-filter-btn @(StatusFilter == "all" ? "active" : "")" @onclick='() => SetStatusFilter("all")'>
							@T("sim.all") (@Persons.Count)
						</button>
						<button class="sim-filter-btn selected @(StatusFilter == "selected" ? "active" : "")" @onclick='() => SetStatusFilter("selected")'>
							✅ @T("sim.selectedFilter") (@SelectedCount)
						</button>
						<button class="sim-filter-btn not-selected @(StatusFilter == "not-selected" ? "active" : "")" @onclick='() => SetStatusFilter("not-selected")'>
							⬜ @T("sim.notSelected") (@NotSelectedCount)
						</button>
						<button class="sim-filter-btn running @(StatusFilter == "running" ? "active" : "")" @onclick='() => SetStatusFilter("running")'>
							🟢 @T("sim.running") (@RunningCount)
						</button>
						<button class="sim-filter-btn idle @(StatusFilter == "idle" ? "active" : "")" @onclick='() => SetStatusFilter("idle")'>
							⚪ @T("sim.idle") (@IdleCount)
						</button>
					</div>
				</div>

				<div class="sim-select-actions">
					<button class="ghost small" @onclick="SelectAll">@T("sim.selectAll")</button>
					<button class="ghost small" @onclick="DeselectAll">@T("sim.deselectAll")</button>
				</div>

				@if (!Persons.Any())
				{
					<div class="message-card">@T("sim.noPersons")</div>
				}
				else if (!FilteredPersons.Any())
				{
					<div class="message-card">@T("sim.noMatch")</div>
				}
				else
				{
					<div class="sim-grid">
						@foreach (var person in FilteredPersons)
						{
							var p = person;
							<div class="sim-card @(p.IsSelected ? "selected" : "")">
								<div class="sim-card-top">
									<label class="sim-checkbox-wrap" @onclick:stopPropagation>
										<input type="checkbox" checked="@p.IsSelected" @onchange="() => ToggleSelection(p)" />
										<span class="sim-checkmark"></span>
									</label>
									<div class="avatar">@GetInitials(p.Name)</div>
									<div class="sim-card-meta">
										<h3>@p.Name</h3>
										<p class="muted">@T("sim.serial") <span class="mono">@p.Serial</span></p>
										<p class="muted">@T("sim.user") @p.UserName (@p.UserEmail)</p>
									</div>
								</div>
								<div class="sim-actions">
									<button class="primary" @onclick="() => SendSimulationAsync(p)" disabled="@(p.IsRunning || p.IsSending || !p.IsSelected)">
										@(p.IsSending ? T("sim.sending") : T("sim.generateOnce"))
									</button>
									<button class="secondary" @onclick="() => StartAutoAsync(p)" disabled="@(p.IsRunning || !p.IsSelected)">
										@(p.IsRunning ? T("sim.autoRunning") : T("sim.startAuto"))
									</button>
									<button class="danger" @onclick="() => StopAutoAsync(p)" disabled="@(!p.IsRunning)">
										@T("sim.stop")
									</button>
									<button class="secondary" @onclick="() => ClearDataAsync(p)" disabled="@(p.IsRunning || p.IsSending)" title="@T("sim.clearData")">
										🗑
									</button>
									@if (p.LastStatus != null)
									{
										<span class="status-chip @(p.LastStatus.Success ? "ok" : "warn")">@p.LastStatus.Message</span>
									}
								</div>
							</div>
						}
					</div>
				}
			</div>
		}
	</div>
</div>

