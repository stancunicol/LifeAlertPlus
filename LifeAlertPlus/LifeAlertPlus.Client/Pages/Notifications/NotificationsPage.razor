@page "/notifications"

@using LifeAlertPlus.Domain.Entities

<HeaderComponent UserName="@UserFullName" ProfilePictureUrl="@ProfilePictureUrl"/>

<div class="notifications-container">
    <div class="notifications-header">
        <div class="header-title-section">
            <h1>@T("notifications.title")</h1>
            <p class="notifications-subtitle">@T("notifications.subtitle")</p>
        </div>
    </div>

    <div class="stats-row">
        <div class="stat-mini-card critical">
            <span class="stat-label">@T("notifications.criticalAlerts")</span>
        </div>
        <div class="stat-mini-card warning">
            <span class="stat-label">@T("notifications.warnings")</span>
        </div>
        <div class="stat-mini-card info">
            <span class="stat-label">@T("notifications.infoMessages")</span>
        </div>
        <div class="stat-mini-card unread">
            <span class="stat-label">@T("notifications.unread")</span>
        </div>
    </div>
    <div class="notifications-feed">
        @if (AllNotifications.Count == 0)
        {
            <div class="no-notifications">@T("admin.noNotifications")</div>
        }
        else
        {
            @foreach (var notif in AllNotifications)
            {
                <div class="notification-card @notif.NotificationType.ToLower() @(notif.IsRead ? "read" : "unread")">
                    <div class="notification-content">
                        <div class="notification-header-row">
                            <span class="notification-type">@notif.NotificationType</span>
                            <span class="notification-date">@notif.CreatedAt.ToLocalTime().ToString("g")</span>
                        </div>
                        <div class="notification-message">@notif.Message</div>
                    </div>
                </div>
            }
        }
    </div>
</div>