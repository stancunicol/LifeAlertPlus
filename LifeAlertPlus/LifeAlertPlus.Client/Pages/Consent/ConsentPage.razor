@page "/consent"
@layout EmptyLayout

<div class="auth-bg"></div>

<div class="consent-page-wrapper">
    <div class="consent-page-card">
        <div class="consent-page-header">
            <div class="consent-page-logo">LifeAlert<span>+</span></div>
            <h2>🔒 @T("register.consentModalTitle")</h2>
            <p class="consent-page-subtitle">@T("consent.subtitle")</p>
        </div>

        <div class="consent-page-body">
            <p class="consent-lead">@T("register.consentLead")</p>

            <div class="consent-items">
                <div class="consent-item">
                    <span class="consent-item-icon">❤️</span>
                    <span>@T("register.consentItem1")</span>
                </div>
                <div class="consent-item">
                    <span class="consent-item-icon">📍</span>
                    <span>@T("register.consentItem2")</span>
                </div>
                <div class="consent-item">
                    <span class="consent-item-icon">🔔</span>
                    <span>@T("register.consentItem3")</span>
                </div>
            </div>

            <div class="consent-art9-box">
                <strong>⚠ @T("register.consentArt9Title")</strong>
                <p>@T("register.consentArt9Body")</p>
            </div>

            <label class="consent-checkbox-row">
                <input type="checkbox" @bind="ConsentChecked" class="consent-checkbox" />
                <span>@T("register.consentCheckboxLabel")</span>
            </label>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <p class="consent-error">@ErrorMessage</p>
            }
        </div>

        <div class="consent-page-footer">
            <button class="consent-cancel-btn" @onclick="DeclineAndLogout" disabled="@IsLoading">
                @T("register.consentDecline")
            </button>
            <button class="consent-accept-btn" @onclick="AcceptConsent"
                    disabled="@(!ConsentChecked || IsLoading)">
                @(IsLoading ? T("consent.saving") : T("register.consentAccept"))
            </button>
        </div>
    </div>
</div>
