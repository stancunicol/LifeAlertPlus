@page "/monitored-users"
@using System.Linq
@using Microsoft.AspNetCore.Components.Web
@using LifeAlertPlus.Client.Components.HeaderAdmin
@using LifeAlertPlus.Shared.DTOs.Responses.UserMonitored

<HeaderAdminComponent UserName="@UserFullName" ProfilePictureUrl="@ProfilePictureUrl" />

<div class="monitored-users-page">
	<div class="admin-container">
		<div class="admin-header">
    <div class="header-title-section">
        <h1>@T("monUsers.title")</h1>
        <p class="admin-subtitle">@T("monUsers.subtitle")</p>
    </div>
    <div class="admin-header-actions">
        <span class="tag chip-muted">@T("monUsers.liveOverview")</span>
    </div>
</div>

			<div class="stats-grid admin-stats">
				<div class="stat-card">
					<div class="stat-icon monitored">🩺</div>
					<div class="stat-info">
						<span class="stat-label">@T("monUsers.monitored")</span>
						<span class="stat-value">@TotalMonitored</span>
					</div>
				</div>
				<div class="stat-card">
					<div class="stat-icon online">🟢</div>
					<div class="stat-info">
						<span class="stat-label">@T("monUsers.online")</span>
						<span class="stat-value">@OnlineMonitoredCount</span>
					</div>
				</div>
				<div class="stat-card">
					<div class="stat-icon offline">🔴</div>
					<div class="stat-info">
						<span class="stat-label">@T("monUsers.offline")</span>
						<span class="stat-value critical">@OfflineMonitoredCount</span>
					</div>
				</div>
				<div class="stat-card">
					<div class="stat-icon alert">⚠️</div>
					<div class="stat-info">
						<span class="stat-label">@T("monUsers.alerts")</span>
						<span class="stat-value">@AlertsCount</span>
					</div>
				</div>
			</div>

		@if (IsLoading)
		{
			<div class="message-card">@T("monUsers.loading")</div>
		}
		else if (!string.IsNullOrEmpty(ErrorMessage))
		{
			<div class="message-card error">
				<span>@ErrorMessage</span>
				<button @onclick="LoadDataAsync">@T("monUsers.retry")</button>
			</div>
		}
		else if (Users == null || !Users.Any())
		{
			<div class="message-card">@T("monUsers.noPersons")</div>
		}
		else
		{
			<div class="section">
				<div class="section-header">
					<div>
						<h2>@T("monUsers.personsTitle")</h2>
						<span class="section-note">@T("monUsers.personsSubtitle")</span>
					</div>
					<div class="section-actions">
						<input class="search" @bind="SearchText" @bind:event="oninput" placeholder="@T("monUsers.searchPh")" />
						<div class="filters">
							<button class="@GetFilterClass("all")" @onclick='@(() => SetFilter("all"))'>@T("monUsers.all")</button>
							<button class="@GetFilterClass("online")" @onclick='@(() => SetFilter("online"))'>@T("monUsers.online")</button>
							<button class="@GetFilterClass("offline")" @onclick='@(() => SetFilter("offline"))'>@T("monUsers.offline")</button>
							<button class="@GetFilterClass("alerts")" @onclick='@(() => SetFilter("alerts"))'>@T("monUsers.alerts")</button>
						</div>
					</div>
				</div>

				@if (!FilteredRows.Any())
				{
					<div class="message-card">@T("monUsers.noFilter")</div>
				}
				else
				{
					<div class="table-container">
						<table class="admin-table">
							<thead>
								<tr>
									<th>@T("monUsers.thPerson")</th>
									<th>@T("monUsers.thDevice")</th>
									<th>@T("monUsers.thMonitoredBy")</th>
									<th>@T("monUsers.thStatus")</th>
									<th>@T("monUsers.thLastUpdate")</th>
									<th>@T("monUsers.thActions")</th>
								</tr>
							</thead>
							<tbody>
								@foreach (var row in FilteredRows)
								{
									<tr class="@GetRowClass(row.Online)">
										<td>
											<div class="person-inline">
												<div class="mini-avatar">@GetInitials(row.PersonName)</div>
												<div class="person-inline-info">
													<span class="person-name">@row.PersonName</span>
												</div>
											</div>
										</td>
										<td><span class="device-badge">@row.DeviceSerial</span></td>
										<td>
											<div class="user-inline">
												@foreach (var monitor in row.Monitors)
												{
													<div class="monitor-entry">
														<span class="user-name">@monitor.Name</span>
														<span class="user-email">@monitor.Email</span>
													</div>
												}
											</div>
										</td>
										<td>
											<span class="status-indicator @GetStatusClass(row.Online)">
												@GetStatusText(row.Online)
											</span>
											@if (row.HasAlert)
											{
												<span class="alert-badge">⚠️</span>
											}
										</td>
										<td class="date-cell">@row.LastUpdate</td>
										<td class="actions-cell">
											<button class="btn-details" @onclick='@(() => NavigateToSelected(row.PersonId))'>@T("monUsers.details")</button>
										</td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				}
			</div>
		}
	</div>
</div>
