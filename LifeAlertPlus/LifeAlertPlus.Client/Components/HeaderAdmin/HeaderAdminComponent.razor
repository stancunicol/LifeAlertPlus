@namespace LifeAlertPlus.Client.Components.HeaderAdmin
@using LifeAlertPlus.Client

<header class="header">
    <div class="header-container">
        <div class="header-left">
            <button class="mobile-menu-btn" @onclick="ToggleMobileMenu">
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
            </button>
            <div class="header-logo-wrap">
                <img src="final_logo.png" class="header-logo-img" alt="LifeAlert+" />
                <a href="/admin-dashboard" class="header-logo">LifeAlert +</a>
                <span class="header-version">v @Version</span>
            </div>
            <nav class="header-nav">
                <a href="/admin-dashboard" class="nav-link @(IsActive("/admin-dashboard") ? "active" : "")">@T("adminNav.dashboard")</a>
                <a href="/monitored-users" class="nav-link @(IsActive("/monitored-users") ? "active" : "")">@T("adminNav.monitoreds")</a>
                <a href="/users" class="nav-link @(IsActive("/users") ? "active" : "")">@T("adminNav.users")</a>
                <a href="/admin-history" class="nav-link @(IsActive("/admin-history") ? "active" : "")">@T("adminNav.history")</a>
                <a href="/admin-errors" class="nav-link @(IsActive("/admin-errors") ? "active" : "")">@T("adminNav.errorLog")</a>
                <a href="/simulations" class="nav-link @(IsActive("/simulations") ? "active" : "")">@T("adminNav.simulations")</a>
            </nav>
        </div>
        
        <div class="header-right">
            <div class="user-profile" @onclick="ToggleProfileMenu">
                @if (!string.IsNullOrEmpty(ProfilePictureUrl))
                {
                    <img src="@ProfilePictureUrl" class="user-avatar-img" />
                }
                else
                {
                    <div class="user-avatar">@GetUserInitials()</div>
                }
                <span class="user-name">@DisplayedName</span>
                <span class="dropdown-icon">▼</span>
            </div>

            @if (ShowProfileMenu)
            {
                <div class="profile-menu">
                    <a @onclick="OnLogout" class="profile-menu-item logout">@T("adminNav.logout")</a>
                </div>
            }
        </div>
    </div>
</header>

@if (ShowProfileMenu)
{
    <div class="menu-overlay" @onclick="CloseProfileMenu"></div>
}

@if (ShowMobileMenu)
{
    <div class="mobile-nav-overlay" @onclick="CloseMobileMenu"></div>
    <nav class="mobile-nav">
        <div class="mobile-nav-header">
            <span class="mobile-nav-title">@T("adminNav.menu")</span>
            <button class="mobile-nav-close" @onclick="CloseMobileMenu">✕</button>
        </div>
        <a href="/admin-dashboard" class="mobile-nav-link @(IsActive("/admin-dashboard") ? "active" : "")" @onclick="CloseMobileMenu">@T("adminNav.dashboard")</a>
        <a href="/monitored-users" class="mobile-nav-link @(IsActive("/monitored-users") ? "active" : "")" @onclick="CloseMobileMenu">@T("adminNav.monitoreds")</a>
        <a href="/users" class="mobile-nav-link @(IsActive("/users") ? "active" : "")" @onclick="CloseMobileMenu">@T("adminNav.users")</a>
        <a href="/admin-history" class="mobile-nav-link @(IsActive("/admin-history") ? "active" : "")" @onclick="CloseMobileMenu">@T("adminNav.history")</a>
        <a href="/admin-errors" class="mobile-nav-link @(IsActive("/admin-errors") ? "active" : "")" @onclick="CloseMobileMenu">@T("adminNav.errorLog")</a>
        <a href="/simulations" class="mobile-nav-link @(IsActive("/simulations") ? "active" : "")" @onclick="CloseMobileMenu">@T("adminNav.simulations")</a>
        <div class="mobile-nav-divider"></div>
        <a href="/profile" class="mobile-nav-link @(IsActive("/profile") ? "active" : "")" @onclick="CloseMobileMenu">@T("adminNav.profile")</a>
        <a href="/settings" class="mobile-nav-link @(IsActive("/settings") ? "active" : "")" @onclick="CloseMobileMenu">@T("adminNav.settings")</a>
        <div class="mobile-nav-divider"></div>
        <a class="mobile-nav-link logout" @onclick="OnLogout">@T("adminNav.logout")</a>
    </nav>
}