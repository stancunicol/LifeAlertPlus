@namespace LifeAlertPlus.Client.Components.Header
@using LifeAlertPlus.Client

<header class="header">
    <div class="header-container">
        <div class="header-left">
            <button class="mobile-menu-btn" @onclick="ToggleMobileMenu">
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
            </button>
            <div class="header-logo-wrap">
                <img src="logo_rounded.png" class="header-logo-img" alt="LifeAlert+" />
                <a href="/dashboard" class="header-logo">LifeAlert +</a>
                <span class="header-version">v @Version</span>
            </div>
            <nav class="header-nav">
                <a href="/dashboard" class="nav-link @(IsActive("/dashboard") ? "active" : "")">Dashboard</a>
                <a href="/monitored" class="nav-link @(IsActive("/monitored") ? "active" : "")">Monitored</a>
                <a href="/notifications" class="nav-link @(IsActive("/notifications") ? "active" : "")">Notifications</a>
            </nav>
        </div>
        
        <div class="header-right">
            <div class="user-profile" @onclick="ToggleProfileMenu">
                @if (!string.IsNullOrEmpty(ProfilePictureUrl))
                {
                    <img src="@ProfilePictureUrl" class="user-avatar-img" />
                }
                else
                {
                    <div class="user-avatar">@GetUserInitials()</div>
                }
                <span class="user-name">@UserName</span>
                <span class="dropdown-icon">▼</span>
            </div>

            @if (ShowProfileMenu)
            {
                <div class="profile-menu">
                    <a href="/profile" class="profile-menu-item">My Profile</a>
                    <a href="/settings" class="profile-menu-item">Settings</a>
                    <div class="profile-menu-divider"></div>
                    <a href="/about" class="profile-menu-item">About Us</a>
                    <a href="/support" class="profile-menu-item">Support</a>
                    <div class="profile-menu-divider"></div>
                    <a @onclick="OnLogout" class="profile-menu-item logout">Logout</a>
                </div>
            }
        </div>
    </div>
</header>

@if (ShowProfileMenu)
{
    <div class="menu-overlay" @onclick="CloseProfileMenu"></div>
}

@if (ShowMobileMenu)
{
    <div class="mobile-nav-overlay" @onclick="CloseMobileMenu"></div>
    <nav class="mobile-nav">
        <div class="mobile-nav-header">
            <span class="mobile-nav-title">Menu</span>
            <button class="mobile-nav-close" @onclick="CloseMobileMenu">✕</button>
        </div>
        <a href="/dashboard" class="mobile-nav-link @(IsActive("/dashboard") ? "active" : "")" @onclick="CloseMobileMenu">Dashboard</a>
        <a href="/monitored" class="mobile-nav-link @(IsActive("/monitored") ? "active" : "")" @onclick="CloseMobileMenu">Monitored</a>
        <a href="/notifications" class="mobile-nav-link @(IsActive("/notifications") ? "active" : "")" @onclick="CloseMobileMenu">Notifications</a>
        <div class="mobile-nav-divider"></div>
        <a href="/about" class="mobile-nav-link" @onclick="CloseMobileMenu">About Us</a>
        <a href="/support" class="mobile-nav-link" @onclick="CloseMobileMenu">Support</a>
    </nav>
}