@namespace LifeAlertPlus.Client.Components.Header

<header class="header">
    <div class="header-container">
        <div class="header-left">
            <a href="/dashboard" class="header-logo">LifeAlert +</a>
            <nav class="header-nav">
                <a href="/dashboard" class="nav-link @(IsActive("/dashboard") ? "active" : "")">Dashboard</a>
                <a href="/monitored" class="nav-link @(IsActive("/monitored") ? "active" : "")">Monitored</a>
                <a href="/history" class="nav-link @(IsActive("/history") ? "active" : "")">History</a>
                <a href="/notifications" class="nav-link @(IsActive("/notifications") ? "active" : "")">Notifications</a>
            </nav>
        </div>
        
        <div class="header-right">
            <div class="user-profile" @onclick="ToggleProfileMenu">
                <div class="user-avatar">@GetUserInitials()</div>
                <span class="user-name">@UserName</span>
                <span class="dropdown-icon">▼</span>
            </div>

            @if (ShowProfileMenu)
            {
                <div class="profile-menu">
                    <a href="/profile" class="profile-menu-item">My Profile</a>
                    <a href="/settings" class="profile-menu-item">Settings</a>
                    <div class="profile-menu-divider"></div>
                    <a @onclick="OnLogout" class="profile-menu-item logout">Logout</a>
                </div>
            }
        </div>
    </div>
</header>

@if (ShowProfileMenu)
{
    <div class="menu-overlay" @onclick="CloseProfileMenu"></div>
}