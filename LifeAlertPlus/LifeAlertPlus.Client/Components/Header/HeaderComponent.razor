@namespace LifeAlertPlus.Client.Components.Header
@using LifeAlertPlus.Client

<header class="header">
    <div class="header-container">
        <div class="header-left">
            <button class="mobile-menu-btn" @onclick="ToggleMobileMenu">
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
            </button>
            <div class="header-logo-wrap">
                <img src="logo_final.png" class="header-logo-img" alt="LifeAlert+" />
                <a href="/dashboard" class="header-logo">LifeAlert +</a>
                <span class="header-version">v @Version</span>
            </div>
            <nav class="header-nav">
                <a href="/dashboard" class="nav-link @(IsActive("/dashboard") ? "active" : "")">@T("nav.dashboard")</a>
                <a href="/monitored" class="nav-link @(IsActive("/monitored") ? "active" : "")">@T("nav.monitored")</a>
                <a href="/notifications" class="nav-link @(IsActive("/notifications") ? "active" : "")">
                    @T("nav.notifications")
                    @if (_unreadCount > 0)
                    {
                        <span class="notif-badge"></span>
                    }
                </a>
            </nav>
        </div>
        
        <div class="header-right">
            <div class="user-profile" @onclick="ToggleProfileMenu">
                @if (!string.IsNullOrEmpty(ProfilePictureUrl))
                {
                    <img src="@ProfilePictureUrl" class="user-avatar-img" />
                }
                else
                {
                    <div class="user-avatar">@GetUserInitials()</div>
                }
                <span class="user-name">@DisplayedName</span>
                <span class="dropdown-icon">▼</span>
            </div>

            @if (ShowProfileMenu)
            {
                <div class="profile-menu">
                    <a href="/profile" class="profile-menu-item">@T("nav.profile")</a>
                    <a href="/settings" class="profile-menu-item">@T("nav.settings")</a>
                    <div class="profile-menu-divider"></div>
                    <a href="/about" class="profile-menu-item">@T("nav.aboutUs")</a>
                    <a href="/support" class="profile-menu-item">@T("nav.support")</a>
                    <div class="profile-menu-divider"></div>
                    <a @onclick="OnLogout" class="profile-menu-item logout">@T("nav.logout")</a>
                </div>
            }
        </div>
    </div>
</header>

@if (ShowProfileMenu)
{
    <div class="menu-overlay" @onclick="CloseProfileMenu"></div>
}

@if (ShowMobileMenu)
{
    <div class="mobile-nav-overlay" @onclick="CloseMobileMenu"></div>
    <nav class="mobile-nav">
        <div class="mobile-nav-header">
            <span class="mobile-nav-title">@T("nav.menu")</span>
            <button class="mobile-nav-close" @onclick="CloseMobileMenu">✕</button>
        </div>
        <a href="/dashboard" class="mobile-nav-link @(IsActive("/dashboard") ? "active" : "")" @onclick="CloseMobileMenu">@T("nav.dashboard")</a>
        <a href="/monitored" class="mobile-nav-link @(IsActive("/monitored") ? "active" : "")" @onclick="CloseMobileMenu">@T("nav.monitored")</a>
        <a href="/notifications" class="mobile-nav-link @(IsActive("/notifications") ? "active" : "")" @onclick="CloseMobileMenu">
            @T("nav.notifications")
            @if (_unreadCount > 0)
            {
                <span class="notif-badge notif-badge--mobile"></span>
            }
        </a>
        <div class="mobile-nav-divider"></div>
        <a href="/profile" class="mobile-nav-link @(IsActive("/profile") ? "active" : "")" @onclick="CloseMobileMenu">@T("nav.profile")</a>
        <a href="/settings" class="mobile-nav-link @(IsActive("/settings") ? "active" : "")" @onclick="CloseMobileMenu">@T("nav.settings")</a>
        <div class="mobile-nav-divider"></div>
        <a href="/about" class="mobile-nav-link" @onclick="CloseMobileMenu">@T("nav.aboutUs")</a>
        <a href="/support" class="mobile-nav-link" @onclick="CloseMobileMenu">@T("nav.support")</a>
    </nav>
}