@using LifeAlertPlus.Client.Services
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject LifeAlertPlus.Client.Services.TokenParserService TokenParser
@inject LifeAlertPlus.Client.Services.ProfilePictureService ProfilePictureService
@inject LifeAlertPlus.Client.Services.LanguageService Lang

<Router AppAssembly="@typeof(App).Assembly" OnNavigateAsync="HandleNavigationAsync">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>@Lang.T("app.notFound")</PageTitle>
        <LayoutView Layout="@typeof(MainLayout)">
            <p role="alert">@Lang.T("app.notFoundText")</p>
        </LayoutView>
    </NotFound>
</Router>

@code {
    private static readonly string[] PublicRoutes =
    {
        string.Empty,
        "login",
        "register",
        "reset-password"
    };

    private static readonly string[] AdminRoutes =
    {
        "admin-dashboard",
        "users",
        "view-selected-user",
        "monitored-users",
        "simulations"
    };

    private static readonly string[] UserRoutes =
    {
        "dashboard",
        "history",
        "notifications",
        "monitored",
        "selected-monitored",
        "profile",
        "settings",
        "about",
        "support"
    };

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var savedLang = await JSRuntime.InvokeAsync<string>("getLanguage");
            if (!string.IsNullOrEmpty(savedLang))
            {
                Lang.SetLanguage(savedLang);
                StateHasChanged();
            }
        }
    }

    private async Task HandleNavigationAsync(NavigationContext context)
    {
        // Allow Google OAuth redirect that carries the token in the fragment to reach the client so it can persist it.
        if (context.Path.Contains("#token=", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var path = context.Path.Trim('/');
        if (PublicRoutes.Any(r => path.Equals(r, StringComparison.OrdinalIgnoreCase)))
        {
            // Navigating intentionally to login/register/reset-password should clear any stale auth data
            // so the next login is forced to create a new session.
            await JSRuntime.InvokeVoidAsync("sessionStorage.removeItem", "authToken");
            await JSRuntime.InvokeVoidAsync("sessionStorage.removeItem", "profilePictureUrl");
            ProfilePictureService.SetUrl(null);
            return;
        }

        var claims = await TokenParser.GetClaimsAsync();
        if (claims == null)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        // Seed profile picture service so shared components update without a full reload
        ProfilePictureService.SetUrl(claims.ProfilePictureUrl);

        EnforceRoleAccess(path, claims);
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await EnforceAuthAsync(e.Location);
    }

    private async Task EnforceAuthAsync(string uri)
    {
        if (uri.Contains("#token=", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var path = Navigation.ToBaseRelativePath(uri).Trim('/');
        if (PublicRoutes.Any(r => path.Equals(r, StringComparison.OrdinalIgnoreCase)))
        {
            return;
        }

        var claims = await TokenParser.GetClaimsAsync();
        if (claims == null)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        EnforceRoleAccess(path, claims);
    }

    private void EnforceRoleAccess(string path, TokenClaims claims)
    {
        var normalized = path.Trim('/');
        var isAdmin = IsAdminRole(claims.Role);

        if (isAdmin && MatchesRoute(normalized, UserRoutes))
        {
            // Allow admins to view monitored pages (read-only) — they should not be forcibly redirected
            // to the admin dashboard when opening a monitored person's view.
            if (normalized.StartsWith("monitored", StringComparison.OrdinalIgnoreCase)
                || normalized.StartsWith("selected-monitored", StringComparison.OrdinalIgnoreCase))
            {
                // allow access to these user routes for admins
            }
            else
            {
                Navigation.NavigateTo("/admin-dashboard", forceLoad: true);
                return;
            }
        }

        if (!isAdmin && MatchesRoute(normalized, AdminRoutes))
        {
            Navigation.NavigateTo("/dashboard", forceLoad: true);
        }
    }

    private bool IsAdminRole(string? role)
    {
        return !string.IsNullOrWhiteSpace(role) && role.IndexOf("admin", StringComparison.OrdinalIgnoreCase) >= 0;
    }

    private bool MatchesRoute(string path, string[] routes)
    {
        // Exact route match or nested path ("route/..."), avoids partial collisions like
        // "monitored" matching "monitored-users".
        return routes.Any(r => path.Equals(r, StringComparison.OrdinalIgnoreCase)
            || path.StartsWith(r + "/", StringComparison.OrdinalIgnoreCase));
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
