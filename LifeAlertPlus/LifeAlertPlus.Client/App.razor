@* Componenta rădăcină a aplicației — definește Router-ul Blazor și gardul de autentificare/autorizare pe rute.
   Fiecare navigare trece prin HandleNavigationAsync (Router) și OnLocationChanged (browser back/forward),
   care verifică tokenul JWT și restricționează rutele de Admin/User în funcție de rol. *@
@using LifeAlertPlus.Client.Services
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject HttpClient Http
@inject LifeAlertPlus.Client.Services.TokenParserService TokenParser
@inject LifeAlertPlus.Client.Services.ProfilePictureService ProfilePictureService
@inject LifeAlertPlus.Client.Services.LanguageService Lang
@inject LifeAlertPlus.Client.Services.UserApiClient UserApiClient

<Router AppAssembly="@typeof(App).Assembly" OnNavigateAsync="HandleNavigationAsync">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>@Lang.T("app.notFound")</PageTitle>
        <LayoutView Layout="@typeof(MainLayout)">
            <p role="alert">@Lang.T("app.notFoundText")</p>
        </LayoutView>
    </NotFound>
</Router>

@code {
    // Rute accesibile fără token JWT (necesită grijă: orice rută nouă de tip public trebuie adăugată aici explicit)
    private static readonly string[] AllowAnonymousRoutes =
    {
        string.Empty,
        "login",
        "register",
        "reset-password",
        "invite/accept", // păstrată pentru compatibilitate cu link-uri vechi
        "invite/patient",
        // Callback-ul OAuth ajunge aici DUPĂ Google, dar ÎNAINTE ca JWT-ul să fie scris în sessionStorage.
        // Fără această intrare, garda de autentificare a router-ului ar vedea "fără token" și ar forța /login,
        // anulând fetch-ul de schimb-de-cod-pentru-token în desfășurare (codul OAuth e single-use).
        "auth/callback",
        // Pagina de consimțământ GDPR pentru utilizatorii Google noi: tokenul e deja în sessionStorage,
        // dar garda de rută nu trebuie să redirecționeze la login înainte ca utilizatorul să confirme consimțământul.
        "consent"
    };

    // Rute care, la navigare intenționată, trebuie să curețe orice date de autentificare vechi rămase
    private static readonly string[] ClearAuthRoutes =
    {
        string.Empty,
        "login",
        "register",
        "reset-password"
    };

    // Rute restricționate exclusiv rolului Admin
    private static readonly string[] AdminRoutes =
    {
        "admin-dashboard",
        "users",
        "view-selected-user",
        "monitored-users",
        "simulations",
        "admin-history",
        "admin-errors"
    };

    // Rute restricționate exclusiv rolului User (un Admin care le accesează e redirecționat la admin-dashboard,
    // cu excepția vizualizării read-only a paginilor "monitored"/"selected-monitored")
    private static readonly string[] UserRoutes =
    {
        "dashboard",
        "history",
        "notifications",
        "monitored",
        "selected-monitored",
        "profile",
        "settings",
        "about",
        "support"
    };

    private bool _mapsLoaded; // Asigură că cheia Google Maps API e cerută o singură dată per sesiune

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged; // Re-validăm autentificarea/rolul la fiecare schimbare de URL (inclusiv back/forward)
    }

    // La primul render, stabilim limba aplicației: din localStorage (JS) dacă există,
    // altfel din preferința salvată în DB pentru utilizatorul autentificat
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var savedLang = await JSRuntime.InvokeAsync<string>("getLanguage");
            if (!string.IsNullOrEmpty(savedLang))
            {
                Lang.SetLanguage(savedLang);
                StateHasChanged();
            }
            else
            {
                // localStorage e gol — încărcăm preferința de limbă din DB
                var claims = await TokenParser.GetClaimsAsync();
                if (claims != null && claims.UserId != Guid.Empty)
                {
                    var user = await UserApiClient.GetUserByIdAsync(claims.UserId);
                    if (!string.IsNullOrEmpty(user?.Language))
                    {
                        Lang.SetLanguage(user.Language);
                        await JSRuntime.InvokeVoidAsync("setLanguage", user.Language);
                        StateHasChanged();
                    }
                }
            }
        }
    }

    // Interceptează navigarea ÎNAINTE ca Router-ul să afișeze componenta țintă — punctul principal al gardei de securitate
    private async Task HandleNavigationAsync(NavigationContext context)
    {
        // Permitem redirect-ul Google OAuth care duce tokenul în fragmentul URL-ului (#token=...), ca clientul să-l poată persista.
        if (context.Path.Contains("#token=", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var path = NormalizeRoute(context.Path);
        if (AllowAnonymousRoutes.Any(r => path.Equals(r, StringComparison.OrdinalIgnoreCase)))
        {
            if (ClearAuthRoutes.Any(r => path.Equals(r, StringComparison.OrdinalIgnoreCase)))
            {
                // Navigarea intenționată către login/register/reset-password trebuie să curețe orice date
                // de autentificare vechi, ca următorul login să forțeze crearea unei sesiuni noi.
                await JSRuntime.InvokeVoidAsync("sessionStorage.removeItem", "authToken");
                await JSRuntime.InvokeVoidAsync("sessionStorage.removeItem", "profilePictureUrl");
                ProfilePictureService.SetUrl(null);
            }

            // Rută publică — nu forțăm autentificarea.
            return;
        }

        var claims = await TokenParser.GetClaimsAsync();
        if (claims == null)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        // Inițializăm serviciul de poză de profil, ca componentele partajate (header) să se actualizeze fără reload complet
        ProfilePictureService.SetUrl(claims.ProfilePictureUrl);

        // Cerem cheia Google Maps API printr-un HttpClient autenticat, apoi o transmitem la JS (fetch-ul JS nu are autentificare).
        if (!_mapsLoaded)
        {
            _mapsLoaded = true;
            try
            {
                var data = await Http.GetFromJsonAsync<Dictionary<string, string>>("api/config/maps");
                if (data != null && data.TryGetValue("apiKey", out var key) && !string.IsNullOrEmpty(key))
                    await JSRuntime.InvokeVoidAsync("initGoogleMaps", key);
            }
            catch { }
        }

        EnforceRoleAccess(path, claims);
    }

    // Declanșat la navigare browser (back/forward) — Router-ul Blazor nu reapelează HandleNavigationAsync în acest caz
    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await EnforceAuthAsync(e.Location);
    }

    // Aceeași logică de gardă ca HandleNavigationAsync, dar pentru navigarea prin istoricul browserului
    private async Task EnforceAuthAsync(string uri)
    {
        if (uri.Contains("#token=", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var path = NormalizeRoute(Navigation.ToBaseRelativePath(uri));
        if (AllowAnonymousRoutes.Any(r => path.Equals(r, StringComparison.OrdinalIgnoreCase)))
        {
            return;
        }

        var claims = await TokenParser.GetClaimsAsync();
        if (claims == null)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        EnforceRoleAccess(path, claims);
    }

    private static string NormalizeRoute(string rawPath)
    {
        if (string.IsNullOrWhiteSpace(rawPath))
            return string.Empty;

        // Eliminăm query string și fragment, ca verificarea rutelor publice să funcționeze pentru URL-uri de tip
        // /invite/patient?token=... care altfel nu ar fi egale cu "invite/patient".
        var pathOnly = rawPath;
        var q = pathOnly.IndexOf('?');
        if (q >= 0) pathOnly = pathOnly.Substring(0, q);
        var hash = pathOnly.IndexOf('#');
        if (hash >= 0) pathOnly = pathOnly.Substring(0, hash);

        return pathOnly.Trim('/');
    }

    // Redirecționează utilizatorul dacă rolul lui nu corespunde rutei cerute (Admin → admin-dashboard, User → dashboard)
    private void EnforceRoleAccess(string path, TokenClaims claims)
    {
        var normalized = path.Trim('/');
        var isAdmin = IsAdminRole(claims.Role);

        if (isAdmin && MatchesRoute(normalized, UserRoutes))
        {
            // Permitem adminilor să vadă paginile de pacienți monitorizați (read-only) — nu trebuie
            // redirecționați forțat la dashboard-ul de admin când deschid vizualizarea unui pacient.
            if (normalized.StartsWith("monitored", StringComparison.OrdinalIgnoreCase)
                || normalized.StartsWith("selected-monitored", StringComparison.OrdinalIgnoreCase))
            {
                // permitem accesul adminilor la aceste rute de tip User
            }
            else
            {
                Navigation.NavigateTo("/admin-dashboard", forceLoad: true);
                return;
            }
        }

        if (!isAdmin && MatchesRoute(normalized, AdminRoutes))
        {
            Navigation.NavigateTo("/dashboard", forceLoad: true);
        }
    }

    private bool IsAdminRole(string? role)
    {
        return !string.IsNullOrWhiteSpace(role) && role.IndexOf("admin", StringComparison.OrdinalIgnoreCase) >= 0;
    }

    private bool MatchesRoute(string path, string[] routes)
    {
        // Match exact sau cale imbricată ("ruta/..."), evită coliziuni parțiale precum
        // "monitored" care s-ar potrivi din greșeală cu "monitored-users".
        return routes.Any(r => path.Equals(r, StringComparison.OrdinalIgnoreCase)
            || path.StartsWith(r + "/", StringComparison.OrdinalIgnoreCase));
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
